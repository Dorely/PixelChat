@namespace PixelChat.Components.Shared
@using System.Globalization
@using System.Security.Cryptography
@using PixelChat.Art
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IBackgroundRemovalService BackgroundRemoval
@inject IOptions<BackgroundRemovalOptions> BackgroundRemovalOptions
@inject IJSRuntime JS

@if (Inline)
{
    <section class="export-panel export-panel-inline">
        @RenderPanelContent()
    </section>
}
else if (_open)
{
    <div class="export-modal-backdrop" @onclick="CloseAsync">
        <section class="export-panel export-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="export-asset-title" @onclick:stopPropagation="true">
            @RenderPanelContent(showHeader: true)
        </section>
    </div>
}

@code {
    private static readonly string[] DefaultLocalAiModels =
    [
        "birefnet-massive",
        "birefnet-general",
        "birefnet-dis",
        "birefnet-hrsod",
        "isnet-general-use",
        "isnet-anime",
    ];

    [Parameter, EditorRequired]
    public Guid ProjectId { get; set; }

    [Parameter]
    public Guid? AssetId { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private IJSObjectReference? _module;
    private Guid? _loadedAssetId;
    private Guid? _loadedProjectId;
    private ArtAssetExportView? _exportAsset;
    private readonly List<ExportStepCacheView> _exportSteps = [];
    private CancellationTokenSource? _exportProcessingCts;
    private CancellationTokenSource? _exportTimerCts;
    private bool _open = true;
    private bool _exportProcessing;
    private bool _exportLocalAiRunning;
    private bool _exportLocalAiResultAvailable;
    private int _exportTolerance = 24;
    private long _exportRequestVersion;
    private string _exportFileName = string.Empty;
    private string _exportRemovalMethod = "key-color";
    private string _exportLocalAiModel = "birefnet-massive";
    private string _exportActualBackend = string.Empty;
    private string _exportOriginalDataUrl = string.Empty;
    private string _exportCurrentDataUrl = string.Empty;
    private string _exportCurrentImageSha256 = string.Empty;
    private string _exportPreviewBackground = "checkerboard";
    private string _exportAppliedMethod = string.Empty;
    private string _exportPreviewDataUrl = string.Empty;
    private bool _exportSpriteManifestAvailable;
    private ExportStepOutput? _exportPendingStepOutput;
    private string _exportPendingStepSourceHash = string.Empty;
    private string _exportPendingStepSelection = string.Empty;
    private string _exportPendingStepOptionsHash = string.Empty;
    private string _exportStatus = string.Empty;
    private string? _exportError;
    private DateTime? _exportStartedAt;
    private TimeSpan _exportElapsed = TimeSpan.Zero;
    private int? _exportCurrentWidth;
    private int? _exportCurrentHeight;

    protected override async Task OnParametersSetAsync()
    {
        _open = true;
        if (AssetId is not Guid assetId)
        {
            ResetExportState(clearLoaded: true);
            return;
        }

        if (_loadedAssetId == assetId && _loadedProjectId == ProjectId)
            return;

        await LoadExportAsync(assetId);
    }

    private RenderFragment RenderPanelContent(bool showHeader = false) => __builder =>
    {
        var asset = _exportAsset;
        var previewDataUrl = !string.IsNullOrWhiteSpace(_exportPreviewDataUrl)
            ? _exportPreviewDataUrl
            : asset?.DataUrl;

        if (showHeader)
        {
            <header class="export-modal-head">
                <div>
                    <h2 id="export-asset-title">Export</h2>
                    <span>@(asset?.Label ?? "Preparing asset")</span>
                </div>
                <button type="button" class="export-close-button" aria-label="Close export" @onclick="CloseAsync">x</button>
            </header>
        }
        else
        {
            <header class="export-inline-head">
                <div>
                    <h2>Export</h2>
                    <span>@(asset?.Label ?? "Build a sheet to export")</span>
                </div>
            </header>
        }

        if (AssetId is null)
        {
            <div class="export-loading">Build a sheet before exporting.</div>
        }
        else if (asset is null)
        {
            <div class="export-loading">Loading export asset...</div>
        }
        else
        {
            <div class="export-modal-grid">
                <div class="@ExportPreviewStageClass()">
                    @if (!string.IsNullOrWhiteSpace(previewDataUrl))
                    {
                        <img src="@previewDataUrl" alt="@asset.Label" />
                    }
                </div>

                <div class="export-controls">
                    <label>
                        <span>Filename</span>
                        <input class="form-control" value="@_exportFileName" @onchange="OnExportFileNameChanged" />
                    </label>

                    <label>
                        <span>Next step</span>
                        <select class="form-select"
                                value="@_exportRemovalMethod"
                                disabled="@_exportLocalAiRunning"
                                @onchange="OnExportRemovalMethodChanged">
                            <option value="none">None</option>
                            <option value="auto">Fast cleanup</option>
                            <option value="checkerboard">Patterned checkerboard</option>
                            <option value="edge">Edge colors</option>
                            <option value="key-color">Key color cleanup</option>
                            <option value="local-ai">Local AI</option>
                        </select>
                    </label>

                    @if (IsLocalAiRemovalMethod(_exportRemovalMethod))
                    {
                        <label>
                            <span>Local AI model</span>
                            <select class="form-select"
                                    value="@_exportLocalAiModel"
                                    disabled="@_exportLocalAiRunning"
                                    @onchange="OnExportLocalAiModelChanged">
                                @foreach (var model in LocalAiModelOptions())
                                {
                                    <option value="@model">@LocalAiModelLabel(model)</option>
                                }
                            </select>
                        </label>
                    }

                    @if (StepUsesTolerance(_exportRemovalMethod))
                    {
                        <label>
                            <span>Tolerance @_exportTolerance</span>
                            <input type="range"
                                   min="0"
                                   max="80"
                                   step="1"
                                   value="@_exportTolerance"
                                   disabled="@_exportLocalAiRunning"
                                   @onchange="OnExportToleranceChanged" />
                        </label>
                    }

                    <div class="export-meta">
                        <span>@FormatExportDimensions()</span>
                        <span>PNG</span>
                        @if (_exportSpriteManifestAvailable)
                        {
                            <span>Sprite JSON</span>
                        }
                    </div>

                    <div class="export-step-actions">
                        @if (_exportLocalAiRunning)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelExportProcessing">Stop</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-primary" disabled="@(!CanApplyExportStep())" @onclick="ApplyExportStepAsync">Apply step</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!CanResetExportSteps())" @onclick="ResetExportStepsAsync">Reset to original</button>
                        }
                    </div>

                    <div class="export-preview-controls" aria-label="Preview background">
                        <span>Preview background</span>
                        <div class="export-preview-options">
                            <button type="button" class="@ExportPreviewBackgroundClass("checkerboard")" @onclick='() => SetExportPreviewBackground("checkerboard")'>Checker</button>
                            <button type="button" class="@ExportPreviewBackgroundClass("black")" @onclick='() => SetExportPreviewBackground("black")'>Black</button>
                            <button type="button" class="@ExportPreviewBackgroundClass("white")" @onclick='() => SetExportPreviewBackground("white")'>White</button>
                            <button type="button" class="@ExportPreviewBackgroundClass("accent")" @onclick='() => SetExportPreviewBackground("accent")'>Accent</button>
                        </div>
                    </div>

                    @if (_exportSteps.Count > 0)
                    {
                        <div class="export-step-history">
                            <span>Applied steps</span>
                            @foreach (var step in _exportSteps.OrderBy(step => step.StepIndex))
                            {
                                <div class="export-step-row">
                                    <strong>@(step.StepIndex + 1)</strong>
                                    <span>@ExportRemovalMethodLabel(step.Method)</span>
                                    @if (!string.IsNullOrWhiteSpace(step.ModelName))
                                    {
                                        <small>@LocalAiModelLabel(step.ModelName)</small>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_exportStatus))
                    {
                        <div class="export-status">
                            <span>@_exportStatus</span>
                            @if (_exportLocalAiRunning)
                            {
                                <span class="export-local-ai-elapsed">@FormatElapsed(_exportElapsed)</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_exportError))
                    {
                        <div class="export-error">@_exportError</div>
                    }
                </div>
            </div>
        }

        <footer class="export-modal-actions">
            @if (!Inline)
            {
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Cancel</button>
            }
            <button type="button"
                    class="btn btn-primary"
                    disabled="@(!CanDownloadExport())"
                    @onclick="DownloadExportAsync">
                @(_exportSpriteManifestAvailable ? "Download PNG + JSON" : "Download PNG")
            </button>
        </footer>
    };

    private async Task LoadExportAsync(Guid assetId)
    {
        var refreshPreview = false;
        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        _loadedAssetId = assetId;
        _loadedProjectId = ProjectId;
        _exportAsset = null;
        _exportProcessing = true;
        _exportLocalAiRunning = false;
        _exportLocalAiResultAvailable = false;
        _exportTolerance = 24;
        _exportRemovalMethod = "key-color";
        _exportLocalAiModel = DefaultLocalAiModel();
        _exportActualBackend = string.Empty;
        _exportOriginalDataUrl = string.Empty;
        _exportCurrentDataUrl = string.Empty;
        _exportCurrentImageSha256 = string.Empty;
        _exportPreviewBackground = "checkerboard";
        _exportAppliedMethod = string.Empty;
        _exportSpriteManifestAvailable = false;
        ClearPendingExportStepPreview();
        _exportSteps.Clear();
        _exportElapsed = TimeSpan.Zero;
        _exportStartedAt = null;
        _exportFileName = "asset.png";
        _exportPreviewDataUrl = string.Empty;
        _exportStatus = "Loading export asset...";
        _exportError = null;

        try
        {
            var exportAsset = await Workflow.GetAssetForExportAsync(ProjectId, assetId, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            _exportAsset = exportAsset;
            _exportFileName = DefaultExportFileName(exportAsset.FileName, exportAsset.Label);
            _exportOriginalDataUrl = exportAsset.DataUrl;
            _exportCurrentDataUrl = exportAsset.DataUrl;
            _exportPreviewDataUrl = exportAsset.DataUrl;
            _exportCurrentImageSha256 = Sha256DataUrl(exportAsset.DataUrl);
            _exportCurrentWidth = exportAsset.Width;
            _exportCurrentHeight = exportAsset.Height;
            _exportSpriteManifestAvailable = false;
            _exportStatus = "Loading applied export steps...";
            if (version != _exportRequestVersion)
                return;

            var cachedSteps = await Workflow.GetExportStepCacheAsync(ProjectId, exportAsset.Id, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            ApplyExportStepStack(exportAsset, cachedSteps);
            _exportStatus = cachedSteps.Count > 0
                ? $"Restored {cachedSteps.Count.ToString("N0", CultureInfo.InvariantCulture)} applied export step(s)."
                : "Original image ready. Choose a step and click Apply step.";
            refreshPreview = true;
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }

        if (refreshPreview && version == _exportRequestVersion)
            await RefreshPendingExportPreviewAsync();
    }

    private async Task OnExportRemovalMethodChanged(ChangeEventArgs args)
    {
        if (_exportLocalAiRunning)
            CancelExportProcessing();

        _exportRemovalMethod = NormalizeExportRemovalMethod(args.Value?.ToString());
        await RefreshPendingExportPreviewAsync();
    }

    private async Task OnExportLocalAiModelChanged(ChangeEventArgs args)
    {
        if (_exportLocalAiRunning)
            CancelExportProcessing();

        _exportLocalAiModel = NormalizeLocalAiModel(args.Value?.ToString());
        _exportLocalAiResultAvailable = false;
        _exportActualBackend = string.Empty;
        await RefreshPendingExportPreviewAsync();
    }

    private async Task OnExportToleranceChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        if (int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var tolerance))
            _exportTolerance = Math.Clamp(tolerance, 0, 80);
        await RefreshPendingExportPreviewAsync();
    }

    private void OnExportFileNameChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        _exportFileName = string.IsNullOrWhiteSpace(value) ? _exportFileName : CleanExportFileName(value);
    }

    private void SetExportPreviewBackground(string background)
    {
        _exportPreviewBackground = background is "black" or "white" or "accent" ? background : "checkerboard";
    }

    private async Task RefreshPendingExportPreviewAsync()
    {
        var asset = _exportAsset;
        if (asset is null || string.IsNullOrWhiteSpace(_exportCurrentDataUrl))
            return;

        var method = NormalizeExportRemovalMethod(_exportRemovalMethod);
        ClearPendingExportStepPreview();

        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        if (IsNoExportStep(method))
        {
            _exportProcessing = false;
            _exportError = null;
            _exportPreviewDataUrl = _exportCurrentDataUrl;
            _exportStatus = "No processing selected. Download PNG will export the current preview.";
            CompleteExportOperation(operationCts);
            StateHasChanged();
            return;
        }

        if (IsLocalAiRemovalMethod(method))
        {
            _exportProcessing = false;
            _exportError = null;
            _exportPreviewDataUrl = _exportCurrentDataUrl;
            _exportStatus = "Local AI will process the current applied image when you click Apply step.";
            CompleteExportOperation(operationCts);
            StateHasChanged();
            return;
        }

        _exportProcessing = true;
        _exportError = null;
        _exportPreviewDataUrl = _exportCurrentDataUrl;
        _exportStatus = $"Previewing {ExportRemovalMethodLabel(method)}...";
        StateHasChanged();

        try
        {
            var output = await PrepareBrowserExportStepOutputAsync(_exportCurrentDataUrl, method, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            _exportPendingStepOutput = output;
            _exportPendingStepSourceHash = _exportCurrentImageSha256;
            _exportPendingStepSelection = method;
            _exportPendingStepOptionsHash = OptionsHashForExportStep(method);
            _exportPreviewDataUrl = output.DataUrl;
            _exportStatus = $"Previewing {ExportRemovalMethodLabel(method)}. Click Apply step to keep it.";
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportPreviewDataUrl = _exportCurrentDataUrl;
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }
    }

    private async Task<ExportStepOutput> PrepareBrowserExportStepOutputAsync(
        string inputDataUrl,
        string method,
        CancellationToken cancellationToken)
    {
        var normalized = NormalizeExportRemovalMethod(method);
        if (normalized == "key-color")
        {
            var cleaned = await PrepareKeyColorCleanupPreviewAsync(inputDataUrl, cleanKeyColor: true, cancellationToken);
            return new ExportStepOutput(
                cleaned.DataUrl,
                string.IsNullOrWhiteSpace(cleaned.Method) ? normalized : cleaned.Method,
                OptionsHashForExportStep(normalized),
                ModelName: string.Empty,
                ActualBackend: string.Empty,
                cleaned.Width,
                cleaned.Height);
        }

        var preview = await PrepareFastExportPreviewAsync(
            inputDataUrl,
            removeBackground: true,
            normalized,
            cleanKeyColor: false,
            cancellationToken);
        return new ExportStepOutput(
            preview.DataUrl,
            string.IsNullOrWhiteSpace(preview.Method) ? normalized : preview.Method,
            OptionsHashForExportStep(normalized),
            ModelName: string.Empty,
            ActualBackend: string.Empty,
            preview.Width,
            preview.Height);
    }

    private async Task<ExportPreviewResult> PrepareFastExportPreviewAsync(
        string dataUrl,
        bool? removeBackground,
        string removalMethod,
        bool? cleanKeyColor,
        CancellationToken cancellationToken)
    {
        var module = await EnsureModuleAsync();
        return await module.InvokeAsync<ExportPreviewResult>(
            "prepareExportPreview",
            cancellationToken,
            dataUrl,
            _exportTolerance,
            removeBackground,
            removalMethod,
            cleanKeyColor);
    }

    private async Task<ExportKeyCleanupResult> PrepareKeyColorCleanupPreviewAsync(
        string dataUrl,
        bool cleanKeyColor,
        CancellationToken cancellationToken)
    {
        var module = await EnsureModuleAsync();
        return await module.InvokeAsync<ExportKeyCleanupResult>(
            "prepareKeyColorCleanupPreview",
            cancellationToken,
            dataUrl,
            cleanKeyColor);
    }

    private async Task ApplyExportStepAsync()
    {
        var asset = _exportAsset;
        if (asset is null)
            return;
        if (IsNoExportStep(_exportRemovalMethod))
        {
            ClearPendingExportStepPreview();
            _exportPreviewDataUrl = CurrentExportInputDataUrl();
            _exportError = null;
            _exportStatus = "No processing selected. Download PNG will export the current preview.";
            return;
        }

        var refreshPreview = false;
        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        _exportProcessing = true;
        _exportLocalAiResultAvailable = false;
        _exportActualBackend = string.Empty;
        _exportError = null;
        _exportStatus = IsLocalAiRemovalMethod(_exportRemovalMethod)
            ? $"Starting Local AI with {LocalAiModelLabel(_exportLocalAiModel)}..."
            : $"Applying {ExportRemovalMethodLabel(_exportRemovalMethod)}...";
        StateHasChanged();

        try
        {
            ExportStepCacheView step = IsLocalAiRemovalMethod(_exportRemovalMethod)
                ? await ApplyLocalAiStepAsync(asset, operationCts.Token, version)
                : await ApplyBrowserExportStepAsync(asset, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            ApplyExportStep(step);
            _exportStatus = $"{ExportRemovalMethodLabel(step.Method)} applied.";
            refreshPreview = true;
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                StopExportTimer(reset: false);
                _exportLocalAiRunning = false;
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }

        if (refreshPreview && version == _exportRequestVersion)
            await RefreshPendingExportPreviewAsync();
    }

    private async Task<ExportStepCacheView> ApplyBrowserExportStepAsync(
        ArtAssetExportView asset,
        CancellationToken cancellationToken)
    {
        var method = NormalizeExportRemovalMethod(_exportRemovalMethod);
        var output = HasUsablePendingExportStepPreview(method)
            ? _exportPendingStepOutput!
            : await PrepareBrowserExportStepOutputAsync(CurrentExportInputDataUrl(), method, cancellationToken);

        return await SaveExportStepAsync(asset, output, cancellationToken);
    }

    private async Task<ExportStepCacheView> ApplyLocalAiStepAsync(
        ArtAssetExportView asset,
        CancellationToken cancellationToken,
        long version)
    {
        _exportLocalAiRunning = true;
        StartExportTimer();
        var inputDataUrl = CurrentExportInputDataUrl();
        var inputHash = _exportCurrentImageSha256;
        var cacheRequest = CurrentLocalAiCacheRequest(inputHash);
        var cache = await Workflow.GetBackgroundRemovalExportCacheAsync(
            ProjectId,
            asset.Id,
            cacheRequest,
            cancellationToken);
        if (cache is not null)
        {
            _exportActualBackend = cache.ActualBackend;
            return await SaveExportStepAsync(
                asset,
                new ExportStepOutput(
                    cache.DataUrl,
                    "local-ai",
                    OptionsHashForExportStep("local-ai", inputHash),
                    cache.ModelName,
                    cache.ActualBackend,
                    _exportCurrentWidth,
                    _exportCurrentHeight),
                cancellationToken);
        }

        var parsed = DataUrl.Parse(inputDataUrl);
        var progress = new Progress<BackgroundRemovalProgress>(update =>
        {
            if (version != _exportRequestVersion)
                return;

            _exportStatus = update.Message;
            _ = InvokeAsync(StateHasChanged);
        });

        var result = await BackgroundRemoval.RemoveBackgroundAsync(
            new BackgroundRemovalRequest(
                asset.FileName,
                parsed.ContentType,
                parsed.Data,
                _exportLocalAiModel,
                BackgroundRemovalOptions.Value.Acceleration),
            progress,
            cancellationToken);
        var dataUrl = DataUrl.ToDataUrl(result.ContentType, result.Data);
        var stats = await AnalyzePngAlphaAsync(dataUrl, cancellationToken);
        await Workflow.SaveBackgroundRemovalExportCacheAsync(
            ProjectId,
            asset.Id,
            new SaveBackgroundRemovalExportCacheRequest(
                "local-ai",
                result.Model,
                BackgroundRemovalOptions.Value.RembgPackageVersion,
                BackgroundRemovalOptions.Value.AlphaMatting,
                LocalAiOptionsHash(inputHash),
                result.ContentType,
                result.Data,
                stats.TransparentPixels,
                stats.SemiTransparentPixels,
                stats.OpaquePixels,
                result.ActualBackend),
            cancellationToken);

        _exportActualBackend = result.ActualBackend;
        _exportElapsed = result.Elapsed;
        return await SaveExportStepAsync(
            asset,
            new ExportStepOutput(
                dataUrl,
                "local-ai",
                OptionsHashForExportStep("local-ai", inputHash),
                result.Model,
                result.ActualBackend,
                stats.Width ?? _exportCurrentWidth,
                stats.Height ?? _exportCurrentHeight),
            cancellationToken);
    }

    private async Task<ExportStepCacheView> SaveExportStepAsync(
        ArtAssetExportView asset,
        ExportStepOutput output,
        CancellationToken cancellationToken)
    {
        var parsed = DataUrl.Parse(output.DataUrl);
        return await Workflow.SaveExportStepCacheAsync(
            ProjectId,
            asset.Id,
            new SaveExportStepCacheRequest(
                _exportSteps.Count,
                _exportCurrentImageSha256,
                output.Method,
                output.OptionsHash,
                output.ModelName,
                output.ActualBackend,
                parsed.ContentType,
                parsed.Data,
                output.Width,
                output.Height),
            cancellationToken);
    }

    private async Task DownloadExportAsync()
    {
        var asset = _exportAsset;
        if (asset is null || string.IsNullOrWhiteSpace(_exportPreviewDataUrl))
            return;

        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        _exportProcessing = true;
        _exportError = null;
        _exportStatus = "Preparing download...";
        StateHasChanged();

        try
        {
            var module = await EnsureModuleAsync();
            var fileName = CleanExportFileName(string.IsNullOrWhiteSpace(_exportFileName)
                ? DefaultExportFileName(asset.FileName, asset.Label)
                : _exportFileName);
            await module.InvokeVoidAsync("downloadExportPng", operationCts.Token, _exportPreviewDataUrl, fileName);

            if (version == _exportRequestVersion)
                _exportStatus = "Download prepared.";
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }
    }

    private CancellationTokenSource BeginExportOperation()
    {
        _exportProcessingCts?.Cancel();
        _exportProcessingCts?.Dispose();
        StopExportTimer(reset: false);
        _exportLocalAiRunning = false;
        _exportProcessingCts = new CancellationTokenSource();
        return _exportProcessingCts;
    }

    private void CompleteExportOperation(CancellationTokenSource operationCts)
    {
        if (!ReferenceEquals(_exportProcessingCts, operationCts))
            return;

        _exportProcessingCts.Dispose();
        _exportProcessingCts = null;
    }

    private void CancelExportProcessing()
    {
        if (!_exportProcessing)
            return;

        _exportStatus = "Cancelling export...";
        _exportProcessingCts?.Cancel();
        StateHasChanged();
    }

    private async Task CloseAsync()
    {
        ResetExportState(clearLoaded: true);
        _open = false;
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }

    private void ResetExportState(bool clearLoaded)
    {
        _exportRequestVersion++;
        _exportProcessingCts?.Cancel();
        _exportProcessingCts?.Dispose();
        _exportProcessingCts = null;
        StopExportTimer(reset: true);
        _exportProcessing = false;
        _exportLocalAiRunning = false;
        _exportLocalAiResultAvailable = false;
        _exportAsset = null;
        _exportPreviewDataUrl = string.Empty;
        _exportFileName = string.Empty;
        _exportRemovalMethod = "key-color";
        _exportLocalAiModel = DefaultLocalAiModel();
        _exportActualBackend = string.Empty;
        _exportPreviewBackground = "checkerboard";
        _exportAppliedMethod = string.Empty;
        _exportSpriteManifestAvailable = false;
        _exportStatus = string.Empty;
        _exportError = null;
        _exportOriginalDataUrl = string.Empty;
        _exportCurrentDataUrl = string.Empty;
        _exportCurrentImageSha256 = string.Empty;
        _exportSteps.Clear();
        ClearPendingExportStepPreview();
        _exportElapsed = TimeSpan.Zero;
        _exportStartedAt = null;
        _exportCurrentWidth = null;
        _exportCurrentHeight = null;
        if (clearLoaded)
        {
            _loadedAssetId = null;
            _loadedProjectId = null;
        }
    }

    private void ApplyExportStepStack(ArtAssetExportView asset, IReadOnlyList<ExportStepCacheView> steps)
    {
        _exportSteps.Clear();
        _exportSteps.AddRange(steps.OrderBy(step => step.StepIndex));
        if (_exportSteps.Count > 0)
        {
            ApplyExportStep(_exportSteps[^1], append: false);
            return;
        }

        _exportPreviewDataUrl = asset.DataUrl;
        _exportCurrentDataUrl = asset.DataUrl;
        _exportCurrentImageSha256 = Sha256DataUrl(asset.DataUrl);
        _exportCurrentWidth = asset.Width;
        _exportCurrentHeight = asset.Height;
        _exportAppliedMethod = string.Empty;
        ClearPendingExportStepPreview();
    }

    private void ApplyExportStep(ExportStepCacheView step, bool append = true)
    {
        if (append)
        {
            _exportSteps.RemoveAll(existing => existing.StepIndex >= step.StepIndex);
            _exportSteps.Add(step);
            _exportSteps.Sort((left, right) => left.StepIndex.CompareTo(right.StepIndex));
        }

        _exportPreviewDataUrl = step.DataUrl;
        _exportCurrentDataUrl = step.DataUrl;
        _exportCurrentImageSha256 = step.OutputImageSha256;
        _exportCurrentWidth = step.Width ?? _exportCurrentWidth;
        _exportCurrentHeight = step.Height ?? _exportCurrentHeight;
        _exportAppliedMethod = step.Method;
        _exportActualBackend = step.ActualBackend;
        _exportLocalAiResultAvailable = step.Method == "local-ai";
        ClearPendingExportStepPreview();
    }

    private async Task ResetExportStepsAsync()
    {
        var asset = _exportAsset;
        if (asset is null || _exportLocalAiRunning)
            return;

        var refreshPreview = false;
        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        _exportProcessing = true;
        _exportError = null;
        _exportStatus = "Resetting export steps...";
        StateHasChanged();

        try
        {
            await Workflow.ClearExportStepCacheAsync(ProjectId, asset.Id, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            _exportSteps.Clear();
            _exportCurrentDataUrl = string.IsNullOrWhiteSpace(_exportOriginalDataUrl) ? asset.DataUrl : _exportOriginalDataUrl;
            _exportPreviewDataUrl = _exportCurrentDataUrl;
            _exportCurrentImageSha256 = Sha256DataUrl(_exportCurrentDataUrl);
            _exportCurrentWidth = asset.Width;
            _exportCurrentHeight = asset.Height;
            _exportAppliedMethod = string.Empty;
            _exportLocalAiResultAvailable = false;
            _exportActualBackend = string.Empty;
            ClearPendingExportStepPreview();
            _exportStatus = "Reset to original image.";
            refreshPreview = true;
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }

        if (refreshPreview && version == _exportRequestVersion)
            await RefreshPendingExportPreviewAsync();
    }

    private bool CanApplyExportStep() =>
        _exportAsset is not null
        && !IsNoExportStep(_exportRemovalMethod)
        && !_exportLocalAiRunning
        && !string.IsNullOrWhiteSpace(_exportPreviewDataUrl);

    private bool CanResetExportSteps() =>
        _exportAsset is not null
        && _exportSteps.Count > 0
        && !_exportProcessing
        && !_exportLocalAiRunning;

    private bool CanDownloadExport()
    {
        if (_exportAsset is null || _exportProcessing || string.IsNullOrWhiteSpace(_exportPreviewDataUrl))
            return false;

        return true;
    }

    private bool HasUsablePendingExportStepPreview(string method)
    {
        var normalized = NormalizeExportRemovalMethod(method);
        if (_exportPendingStepOutput is null)
            return false;

        return _exportPendingStepSourceHash == _exportCurrentImageSha256
            && _exportPendingStepSelection == normalized
            && _exportPendingStepOptionsHash == OptionsHashForExportStep(normalized);
    }

    private void ClearPendingExportStepPreview()
    {
        _exportPendingStepOutput = null;
        _exportPendingStepSourceHash = string.Empty;
        _exportPendingStepSelection = string.Empty;
        _exportPendingStepOptionsHash = string.Empty;
    }

    private BackgroundRemovalExportCacheRequest CurrentLocalAiCacheRequest(string inputHash) =>
        new(
            "local-ai",
            _exportLocalAiModel,
            BackgroundRemovalOptions.Value.RembgPackageVersion,
            BackgroundRemovalOptions.Value.AlphaMatting,
            LocalAiOptionsHash(inputHash));

    private string LocalAiOptionsHash(string inputHash) =>
        $"rembg-cli-default-alpha-thresholds-v2;input={NormalizeHash(inputHash)}";

    private string OptionsHashForExportStep(string method, string? inputHash = null)
    {
        var normalized = NormalizeExportRemovalMethod(method);
        return normalized switch
        {
            "local-ai" => $"model={NormalizeLocalAiModel(_exportLocalAiModel)};input={NormalizeHash(inputHash ?? _exportCurrentImageSha256)};alpha={BackgroundRemovalOptions.Value.AlphaMatting.ToString().ToLowerInvariant()};rembg={BackgroundRemovalOptions.Value.RembgPackageVersion}",
            "key-color" => "key-color=#ff00ff;version=1",
            "checkerboard" or "edge" or "auto" => $"method={normalized};tolerance={_exportTolerance};version=1",
            _ => $"method={normalized};version=1",
        };
    }

    private string CurrentExportInputDataUrl() =>
        string.IsNullOrWhiteSpace(_exportCurrentDataUrl)
            ? _exportOriginalDataUrl
            : _exportCurrentDataUrl;

    private async Task<ExportAlphaStats> AnalyzePngAlphaAsync(string dataUrl, CancellationToken cancellationToken)
    {
        var module = await EnsureModuleAsync();
        return await module.InvokeAsync<ExportAlphaStats>("analyzePngAlpha", cancellationToken, dataUrl);
    }

    private static string NormalizeHash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "unknown" : value.Trim().ToLowerInvariant();

    private static string Sha256DataUrl(string dataUrl)
    {
        var parsed = DataUrl.Parse(dataUrl);
        return Convert.ToHexString(SHA256.HashData(parsed.Data)).ToLowerInvariant();
    }

    private IReadOnlyList<string> LocalAiModelOptions()
    {
        var configured = BackgroundRemovalOptions.Value.AllowedModels;
        var models = configured is { Length: > 0 }
            ? configured
            : DefaultLocalAiModels;
        var normalized = models
            .Select(NormalizeLocalAiModelName)
            .Where(model => !string.IsNullOrWhiteSpace(model))
            .Distinct(StringComparer.Ordinal)
            .ToList();

        return normalized.Count > 0 ? normalized : DefaultLocalAiModels;
    }

    private string DefaultLocalAiModel()
    {
        var models = LocalAiModelOptions();
        var configured = NormalizeLocalAiModelName(BackgroundRemovalOptions.Value.ModelName);
        return models.Contains(configured, StringComparer.Ordinal)
            ? configured
            : models[0];
    }

    private string NormalizeLocalAiModel(string? value)
    {
        var normalized = NormalizeLocalAiModelName(value);
        var models = LocalAiModelOptions();
        return models.Contains(normalized, StringComparer.Ordinal)
            ? normalized
            : models[0];
    }

    private static string NormalizeLocalAiModelName(string? value) =>
        string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToLowerInvariant();

    private static string LocalAiModelLabel(string model) =>
        model.Trim().ToLowerInvariant() switch
        {
            "birefnet-massive" => "BiRefNet Massive",
            "birefnet-general" => "BiRefNet General",
            "birefnet-dis" => "BiRefNet DIS",
            "birefnet-hrsod" => "BiRefNet HRSOD",
            "isnet-general-use" => "ISNet General",
            "isnet-anime" => "ISNet Anime",
            "bria-rmbg" => "BRIA RMBG",
            _ => model,
        };

    private static string FormatElapsed(TimeSpan elapsed)
    {
        if (elapsed.TotalHours >= 1)
            return $"{(int)elapsed.TotalHours}:{elapsed.Minutes:00}:{elapsed.Seconds:00}";

        return $"{(int)elapsed.TotalMinutes}:{elapsed.Seconds:00}";
    }

    private void StartExportTimer()
    {
        StopExportTimer(reset: true);
        _exportStartedAt = DateTime.UtcNow;
        _exportElapsed = TimeSpan.Zero;
        _exportTimerCts = new CancellationTokenSource();
        _ = RunExportTimerAsync(_exportTimerCts.Token);
    }

    private async Task RunExportTimerAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_exportStartedAt is DateTime startedAt)
                    _exportElapsed = DateTime.UtcNow - startedAt;

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopExportTimer(bool reset)
    {
        if (_exportStartedAt is DateTime startedAt && !reset)
            _exportElapsed = DateTime.UtcNow - startedAt;
        else if (reset)
            _exportElapsed = TimeSpan.Zero;

        _exportTimerCts?.Cancel();
        _exportTimerCts?.Dispose();
        _exportTimerCts = null;
        _exportStartedAt = null;
    }

    private async Task<IJSObjectReference> EnsureModuleAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
        return _module;
    }

    private static string FormatDimensions(ArtAssetExportView asset) =>
        asset.Width is int width && asset.Height is int height ? $"{width} x {height}" : "Unknown size";

    private string FormatExportDimensions() =>
        _exportCurrentWidth is int width && _exportCurrentHeight is int height
            ? $"{width} x {height}"
            : _exportAsset is { } asset
                ? FormatDimensions(asset)
                : "Unknown size";

    private string ExportPreviewStageClass() =>
        $"export-preview-stage export-preview-{_exportPreviewBackground}";

    private string ExportPreviewBackgroundClass(string background) =>
        _exportPreviewBackground == background ? "filter-button is-active" : "filter-button";

    private static string NormalizeExportRemovalMethod(string? value) =>
        value?.Trim().ToLowerInvariant() switch
        {
            "none" or "no-processing" or "noprocessing" => "none",
            "local-ai" or "localai" or "ai" or "rembg" => "local-ai",
            "key" or "keycolor" or "key-color" or "magenta" or "chroma" or "chromakey" or "chroma-key" => "key-color",
            "checkerboard" or "patternedcheckerboard" or "patterned-checkerboard" => "checkerboard",
            "edge" or "edgecolors" or "edge-colors" => "edge",
            _ => "auto",
        };

    private static bool IsNoExportStep(string? method) =>
        NormalizeExportRemovalMethod(method) == "none";

    private static bool IsLocalAiRemovalMethod(string? method) =>
        NormalizeExportRemovalMethod(method) == "local-ai";

    private static bool StepUsesTolerance(string? method) =>
        NormalizeExportRemovalMethod(method) is "auto" or "checkerboard" or "edge";

    private static string ExportRemovalMethodLabel(string method) =>
        NormalizeExportRemovalMethod(method) switch
        {
            "none" => "None",
            "local-ai" => "Local AI",
            "key-color" => "Key color cleanup",
            "checkerboard" => "Patterned checkerboard",
            "edge" => "Edge colors",
            _ => "Fast cleanup",
        };

    private static string DefaultExportFileName(string fileName, string label)
    {
        var stem = Path.GetFileNameWithoutExtension(fileName);
        if (string.IsNullOrWhiteSpace(stem))
            stem = string.IsNullOrWhiteSpace(label) ? "asset" : label.Trim();

        return CleanExportFileName(stem + ".png");
    }

    private static string CleanExportFileName(string value)
    {
        var fileName = Path.GetFileName(value.Trim());
        if (string.IsNullOrWhiteSpace(fileName))
            fileName = "asset.png";

        var invalid = Path.GetInvalidFileNameChars();
        var cleaned = new string(fileName
            .Select(character => invalid.Contains(character) ? '-' : character)
            .ToArray())
            .Trim();
        var stem = Path.GetFileNameWithoutExtension(cleaned);
        if (string.IsNullOrWhiteSpace(stem))
            stem = "asset";

        return stem + ".png";
    }

    private static string SpriteManifestFileName(string pngFileName)
    {
        var cleanPng = CleanExportFileName(pngFileName);
        var stem = Path.GetFileNameWithoutExtension(cleanPng);
        return (string.IsNullOrWhiteSpace(stem) ? "asset" : stem) + ".sprite.json";
    }

    public async ValueTask DisposeAsync()
    {
        _exportProcessingCts?.Cancel();
        _exportProcessingCts?.Dispose();
        _exportTimerCts?.Cancel();
        _exportTimerCts?.Dispose();
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch
            {
            }
        }
    }

