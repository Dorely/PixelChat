@namespace PixelChat.Components.Shared
@implements IAsyncDisposable
@inject IJSRuntime JS

<span class="lazy-image @CssClass" style="@RootStyle" @ref="_root">
    @if (!string.IsNullOrWhiteSpace(Src))
    {
        <img @ref="_image"
             alt="@Alt"
             width="@Width"
             height="@Height"
             loading="lazy"
             decoding="async" />
    }
</span>

@code {
    [Parameter, EditorRequired] public string Src { get; set; } = string.Empty;
    [Parameter] public string Alt { get; set; } = string.Empty;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public int? Width { get; set; }
    [Parameter] public int? Height { get; set; }

    private ElementReference _root;
    private ElementReference _image;
    private IJSObjectReference? _module;
    private string _observedSrc = string.Empty;

    private string RootStyle
    {
        get
        {
            var style = Style?.Trim().TrimEnd(';') ?? string.Empty;
            if (Width is int width)
                style = string.IsNullOrWhiteSpace(style) ? $"width: {width}px" : $"{style}; width: {width}px";
            if (Height is int height)
                style = string.IsNullOrWhiteSpace(style) ? $"height: {height}px" : $"{style}; height: {height}px";
            return style;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrWhiteSpace(Src))
            return;

        if (_module is null)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Shared/LazyImage.razor.js");

        if (!string.Equals(_observedSrc, Src, StringComparison.Ordinal))
        {
            _observedSrc = Src;
            await _module.InvokeVoidAsync("observeLazyImage", _root, _image, Src);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unobserveLazyImage", _image);
                await _module.DisposeAsync();
            }
            catch
            {
            }
        }
    }
}
