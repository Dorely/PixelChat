@namespace PixelChat.Components.Shared
@using PixelChat.Art
@using PixelChat.Models
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IJSRuntime JS

<div class="guide-modal-backdrop" @onclick="CloseAsync">
    <section class="guide-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="guide-builder-title" @onclick:stopPropagation="true">
        <header class="guide-modal-head">
            <div>
                <h2 id="guide-builder-title">Create Animation Guide</h2>
                <span>@GuideSubtitle</span>
            </div>
            <button type="button" class="guide-close-button" aria-label="Close guide builder" @onclick="CloseAsync">x</button>
        </header>

        <div class="guide-modal-grid">
            <main class="guide-stage">
                <div class="guide-stage-head">
                    <strong>@StageTitle</strong>
                    <span>@StageMeta</span>
                </div>
                <div class="guide-stage-body">
                    @if (_stageMode == GuideStageMode.Viewer)
                    {
                        <div class="guide-viewer-host" @ref="_viewerHost"></div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_renderedPreviewDataUrl))
                    {
                        <div class="guide-rendered-preview">
                            <img src="@_renderedPreviewDataUrl" alt="@_label" />
                        </div>
                    }
                    else
                    {
                        @RenderGridPreview()
                    }
                </div>
            </main>

            <aside class="guide-controls">
                <section class="guide-control-section">
                    <div class="guide-control-title">Grid</div>
                    <label>
                        <span>Label</span>
                        <input class="form-control" value="@_label" @onchange="OnLabelChanged" />
                    </label>
                    <div class="guide-control-pair">
                        <label>
                            <span>Frames</span>
                            <input class="form-control" type="number" min="1" max="16" @bind="_frameCount" @bind:after="OnGridChanged" />
                        </label>
                        <label>
                            <span>FPS</span>
                            <input class="form-control" type="number" min="1" max="60" @bind="_fps" @bind:after="OnGridChanged" />
                        </label>
                    </div>
                    <div class="guide-control-pair">
                        <label>
                            <span>Rows</span>
                            <input class="form-control" type="number" min="1" max="8" @bind="_rows" @bind:after="OnGridChanged" />
                        </label>
                        <label>
                            <span>Columns</span>
                            <input class="form-control" type="number" min="1" max="8" @bind="_columns" @bind:after="OnGridChanged" />
                        </label>
                    </div>
                    <div class="guide-control-pair">
                        <label>
                            <span>Cell width</span>
                            <input class="form-control" type="number" min="64" max="2048" step="16" @bind="_cellWidth" @bind:after="OnGridChanged" />
                        </label>
                        <label>
                            <span>Cell height</span>
                            <input class="form-control" type="number" min="64" max="2048" step="16" @bind="_cellHeight" @bind:after="OnGridChanged" />
                        </label>
                    </div>
                    <label>
                        <span>Safe margin @_safeMarginPercent.ToString("0")%</span>
                        <input type="range" min="0" max="30" step="1" @bind="_safeMarginPercent" @bind:after="OnGridChanged" />
                    </label>
                    <label class="guide-checkbox">
                        <input type="checkbox" @bind="_loop" @bind:after="InvalidateRenderedPreview" />
                        <span>Loop</span>
                    </label>
                </section>

                <section class="guide-control-section">
                    <div class="guide-control-title">Animation</div>
                    <label>
                        <span>Source</span>
                        <select class="form-select" value="@_sourceType" @onchange="OnSourceTypeChanged">
                            <option value="motion">Motion clip</option>
                            <option value="procedural">Procedural</option>
                        </select>
                    </label>

                    @if (_sourceType == "motion")
                    {
                        <label>
                            <span>Clip</span>
                            <select class="form-select" value="@_motionClipId" @onchange="OnMotionClipChanged">
                                <option value="">Select clip</option>
                                @foreach (var clip in _motionClips)
                                {
                                    <option value="@clip.MotionClipId">@clip.DisplayName</option>
                                }
                            </select>
                        </label>
                    }

                    <label>
                        <span>Animation kind</span>
                        <input class="form-control" value="@_animationKind" @onchange="OnAnimationKindChanged" />
                    </label>
                    <div class="guide-control-pair">
                        <label>
                            <span>Asset type</span>
                            <select class="form-select" @bind="_assetType" @bind:after="InvalidateRenderedPreview">
                                <option value="unit">Unit</option>
                                <option value="tower">Tower</option>
                                <option value="projectile">Projectile</option>
                                <option value="vfx">VFX</option>
                            </select>
                        </label>
                        <label>
                            <span>Structure</span>
                            <input class="form-control" value="@_structureType" @onchange="OnStructureTypeChanged" />
                        </label>
                    </div>
                    <label>
                        <span>Reference</span>
                        <select class="form-select" @bind="_referenceAssetText" @bind:after="InvalidateRenderedPreview">
                            <option value="">None</option>
                            @foreach (var asset in ReferenceAssets)
                            {
                                <option value="@asset.Id">@asset.Label</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Facing</span>
                        <select class="form-select" value="@_facing" @onchange="OnFacingChanged">
                            <option value="front">Front</option>
                            <option value="side_right">Side right</option>
                            <option value="side_left">Side left</option>
                            <option value="three_quarter_front_right">3/4 front right</option>
                            <option value="three_quarter_front_left">3/4 front left</option>
                            <option value="three_quarter_back_right">3/4 back right</option>
                            <option value="three_quarter_back_left">3/4 back left</option>
                            <option value="back">Back</option>
                        </select>
                    </label>
                    <label>
                        <span>Yaw @_yaw.ToString("0")°</span>
                        <input type="range" min="-180" max="180" step="1" @bind="_yaw" @bind:after="OnYawChangedAsync" />
                    </label>
                    <div class="guide-viewer-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_stageMode != GuideStageMode.Viewer)" @onclick="TogglePlaybackAsync">@(_playing ? "Pause" : "Play")</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetYawAsync">Reset Yaw</button>
                    </div>
                    <button type="button" class="btn btn-outline-primary" disabled="@RenderDisabled" @onclick="RenderFramesAsync">Render Frames</button>
                </section>

                @if (!string.IsNullOrWhiteSpace(_status))
                {
                    <div class="guide-status">@_status</div>
                }
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="guide-error">@_error</div>
                }
            </aside>
        </div>

        <footer class="guide-modal-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Cancel</button>
            <button type="button" class="btn btn-primary" disabled="@FinishDisabled" @onclick="FinishAsync">Finish</button>
        </footer>
    </section>
</div>

@code {
    private enum GuideStageMode
    {
        Grid,
        Viewer,
        Rendered,
    }

    [Parameter, EditorRequired]
    public Guid ProjectId { get; set; }

    [Parameter]
    public IReadOnlyList<ArtAssetView> ProjectAssets { get; set; } = [];

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<AnimationGuideRenderView> OnSaved { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<AnimationGuideBuilderModal>? _dotNetRef;
    private ElementReference _viewerHost;
    private IReadOnlyList<MotionClipView> _motionClips = [];
    private string _viewerKey = string.Empty;
    private GuideStageMode _stageMode = GuideStageMode.Grid;
    private string _label = "Walk 8-frame guide";
    private int _frameCount = 8;
    private int _rows = 2;
    private int _columns = 4;
    private int _cellWidth = 192;
    private int _cellHeight = 192;
    private int _fps = 8;
    private double _safeMarginPercent = 12d;
    private bool _loop = true;
    private string _sourceType = "motion";
    private string _motionClipId = string.Empty;
    private string _animationKind = "walk";
    private string _assetType = "unit";
    private string _structureType = "biped";
    private string _rootMotion = "in_place";
    private string _referenceAssetText = string.Empty;
    private string _facing = "side_right";
    private double _yaw = 90d;
    private bool _playing = true;
    private bool _busy;
    private string _status = string.Empty;
    private string? _error;
    private string _renderedPreviewDataUrl = string.Empty;

    private IEnumerable<ArtAssetView> ReferenceAssets =>
        ProjectAssets
            .Where(asset => asset.Kind != ArtAssetKind.SpriteGuide)
            .OrderByDescending(asset => asset.CreatedAt);

    private string GuideSubtitle =>
        _stageMode switch
        {
            GuideStageMode.Viewer => SelectedMotionClip()?.DisplayName ?? "Motion clip",
            GuideStageMode.Rendered => $"{_frameCount} frame(s), {_columns} x {_rows}",
            _ => $"{_frameCount} frame(s), {_columns} x {_rows}"
        };

    private string StageTitle =>
        _stageMode switch
        {
            GuideStageMode.Viewer => "3D Motion",
            GuideStageMode.Rendered => "Rendered Guide",
            _ => "Guide Grid"
        };

    private string StageMeta =>
        _stageMode == GuideStageMode.Viewer
            ? $"{_animationKind} - yaw {_yaw:0}°"
            : $"{_columns} columns x {_rows} rows - {_cellWidth} x {_cellHeight}";

    private bool RenderDisabled =>
        _busy || (_sourceType == "motion" && string.IsNullOrWhiteSpace(_motionClipId));

    private bool FinishDisabled =>
        _busy || string.IsNullOrWhiteSpace(_renderedPreviewDataUrl);

    protected override async Task OnInitializedAsync()
    {
        _motionClips = await Workflow.ListMotionClipsAsync(limit: 100);
        var defaultClip = _motionClips.FirstOrDefault(clip => clip.MotionClipId == "quaternius.ual2.walk.carry.loop")
            ?? _motionClips.FirstOrDefault();
        if (defaultClip is not null)
            ApplyMotionClip(defaultClip, switchToViewer: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var modulePath = "/js/" + "animation-guide-builder.js";
            _module = await JS.InvokeAsync<IJSObjectReference>("import", modulePath);
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        await RenderViewerIfNeededAsync();
    }

    private RenderFragment RenderGridPreview() => __builder =>
    {
        var safeInset = Math.Clamp(_safeMarginPercent, 0d, 40d);
        <div class="guide-grid-preview" style="@GridPreviewStyle">
            @for (var index = 0; index < _rows * _columns; index++)
            {
                var active = index < _frameCount;
                <div class="guide-grid-cell @(active ? "is-active" : "is-empty")" @key="index">
                    @if (active)
                    {
                        <span>@(index + 1).ToString("00")</span>
                        <i style="@($"inset:{safeInset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%;")"></i>
                    }
                </div>
            }
        </div>
    };

    private string GridPreviewStyle =>
        $"grid-template-columns:repeat({_columns}, minmax(0, 1fr)); aspect-ratio:{Math.Max(1, _columns)} / {Math.Max(1, _rows)};";

    private async Task RenderViewerIfNeededAsync()
    {
        if (_module is null || _dotNetRef is null || _stageMode != GuideStageMode.Viewer)
            return;

        var clip = SelectedMotionClip();
        if (clip is null)
            return;

        var key = $"{clip.MotionClipId}|{clip.AnimationName}";
        if (string.Equals(key, _viewerKey, StringComparison.Ordinal))
        {
            await _module.InvokeVoidAsync("setYaw", _viewerHost, _yaw);
            await _module.InvokeVoidAsync("setPlaying", _viewerHost, _playing);
            return;
        }

        _viewerKey = key;
        var assetUrl = $"/media/motion-clips/{Uri.EscapeDataString(clip.MotionClipId)}/asset";
        await _module.InvokeVoidAsync("startViewer", _viewerHost, new
        {
            assetUrl,
            clip.AnimationName,
            yaw = _yaw,
            playing = _playing,
        }, _dotNetRef);
    }

    private void OnGridChanged()
    {
        _frameCount = Math.Clamp(_frameCount, 1, 16);
        _columns = Math.Clamp(_columns, 1, 8);
        _rows = Math.Clamp(_rows, 1, 8);
        if (_rows * _columns < _frameCount)
            _rows = Math.Clamp((int)Math.Ceiling(_frameCount / (double)_columns), 1, 8);
        _cellWidth = Math.Clamp(_cellWidth, 64, 2048);
        _cellHeight = Math.Clamp(_cellHeight, 64, 2048);
        _fps = Math.Clamp(_fps, 1, 60);
        _safeMarginPercent = Math.Clamp(_safeMarginPercent, 0d, 30d);
        InvalidateRenderedPreview();
    }

    private void InvalidateRenderedPreview()
    {
        _renderedPreviewDataUrl = string.Empty;
        _status = string.Empty;
        if (_stageMode == GuideStageMode.Rendered)
            _stageMode = _sourceType == "motion" && !string.IsNullOrWhiteSpace(_motionClipId) ? GuideStageMode.Viewer : GuideStageMode.Grid;
    }

    private void OnLabelChanged(ChangeEventArgs args)
    {
        _label = string.IsNullOrWhiteSpace(args.Value?.ToString())
            ? "Animation guide"
            : args.Value.ToString()!.Trim();
        InvalidateRenderedPreview();
    }

    private void OnAnimationKindChanged(ChangeEventArgs args)
    {
        _animationKind = CleanToken(args.Value?.ToString(), "walk");
        InvalidateRenderedPreview();
    }

    private void OnStructureTypeChanged(ChangeEventArgs args)
    {
        _structureType = CleanToken(args.Value?.ToString(), "biped");
        InvalidateRenderedPreview();
    }

    private void OnSourceTypeChanged(ChangeEventArgs args)
    {
        _sourceType = args.Value?.ToString() == "procedural" ? "procedural" : "motion";
        InvalidateRenderedPreview();
        _stageMode = _sourceType == "motion" && !string.IsNullOrWhiteSpace(_motionClipId) ? GuideStageMode.Viewer : GuideStageMode.Grid;
        _viewerKey = string.Empty;
    }

    private void OnMotionClipChanged(ChangeEventArgs args)
    {
        _motionClipId = args.Value?.ToString() ?? string.Empty;
        if (SelectedMotionClip() is { } clip)
            ApplyMotionClip(clip, switchToViewer: true);
        else
            _stageMode = GuideStageMode.Grid;
    }

    private void ApplyMotionClip(MotionClipView clip, bool switchToViewer)
    {
        _motionClipId = clip.MotionClipId;
        _animationKind = clip.SupportedAnimationKinds.FirstOrDefault() ?? _animationKind;
        _rootMotion = string.IsNullOrWhiteSpace(clip.RecommendedRootMotion) ? "in_place" : clip.RecommendedRootMotion;
        _fps = Math.Clamp(clip.DefaultFps > 0 ? clip.DefaultFps : _fps, 1, 60);
        _loop = clip.LoopRecommended;
        if (clip.AllowedSampleCounts.Count > 0)
            _frameCount = clip.AllowedSampleCounts.OrderBy(count => Math.Abs(count - _frameCount)).ThenBy(count => count).First();
        _columns = SuggestedColumns(_frameCount);
        _rows = Math.Max(1, (int)Math.Ceiling(_frameCount / (double)_columns));
        _label = $"{clip.DisplayName.Replace("Quaternius UAL2 ", string.Empty, StringComparison.Ordinal)} {_frameCount}-frame guide";
        _stageMode = switchToViewer ? GuideStageMode.Viewer : GuideStageMode.Grid;
        _viewerKey = string.Empty;
        InvalidateRenderedPreview();
    }

    private void OnFacingChanged(ChangeEventArgs args)
    {
        _facing = args.Value?.ToString() ?? "side_right";
        _yaw = SpriteFacing.ToYawDegrees(_facing);
        InvalidateRenderedPreview();
    }

    private async Task OnYawChangedAsync()
    {
        _yaw = NormalizeYaw(_yaw);
        InvalidateRenderedPreview();
        if (_module is not null && _stageMode == GuideStageMode.Viewer)
            await _module.InvokeVoidAsync("setYaw", _viewerHost, _yaw);
    }

    private async Task ResetYawAsync()
    {
        _yaw = SpriteFacing.ToYawDegrees(_facing);
        await OnYawChangedAsync();
    }

    private async Task TogglePlaybackAsync()
    {
        _playing = !_playing;
        if (_module is not null && _stageMode == GuideStageMode.Viewer)
            await _module.InvokeVoidAsync("setPlaying", _viewerHost, _playing);
    }

    private async Task RenderFramesAsync()
    {
        if (RenderDisabled)
            return;

        _busy = true;
        _error = null;
        _status = "Rendering guide frames...";
        try
        {
            var preview = await Workflow.PreviewAnimationGuideAsync(ProjectId, BuildRequest());
            _renderedPreviewDataUrl = preview.ImageDataUrl;
            _stageMode = GuideStageMode.Rendered;
            _status = "Guide frames rendered.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task FinishAsync()
    {
        if (FinishDisabled)
            return;

        _busy = true;
        _error = null;
        _status = "Creating guide asset...";
        try
        {
            var saved = await Workflow.GenerateAnimationGuideAsync(ProjectId, BuildRequest());
            await OnSaved.InvokeAsync(saved);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }

    private GenerateAnimationGuideRequest BuildRequest() =>
        new(
            ReferenceAssetId(),
            _animationKind,
            _assetType,
            _structureType,
            _facing,
            _frameCount,
            _fps,
            _rootMotion,
            $"{_cellWidth}x{_cellHeight}",
            _sourceType == "motion" ? _motionClipId : null,
            _label,
            _rows,
            _columns,
            $"{_cellWidth}x{_cellHeight}",
            _yaw,
            _loop,
            _safeMarginPercent);

    private Guid? ReferenceAssetId() =>
        Guid.TryParse(_referenceAssetText, out var id) && id != Guid.Empty ? id : null;

    private MotionClipView? SelectedMotionClip() =>
        string.IsNullOrWhiteSpace(_motionClipId)
            ? null
            : _motionClips.FirstOrDefault(clip => string.Equals(clip.MotionClipId, _motionClipId, StringComparison.OrdinalIgnoreCase));

    private static int SuggestedColumns(int frameCount) =>
        frameCount switch
        {
            <= 1 => 1,
            2 => 2,
            <= 4 => 2,
            <= 6 => 3,
            _ => 4,
        };

    private static string CleanToken(string? value, string fallback)
    {
        var text = value?.Trim().ToLowerInvariant().Replace('-', '_').Replace(' ', '_');
        return string.IsNullOrWhiteSpace(text) ? fallback : text;
    }

    private static double NormalizeYaw(double yaw)
    {
        var normalized = yaw % 360d;
        if (normalized > 180d)
            normalized -= 360d;
        if (normalized < -180d)
            normalized += 360d;
        return Math.Round(normalized, 2);
    }

    [JSInvokable]
    public Task OnAnimationGuideYawChanged(double yaw)
    {
        _yaw = NormalizeYaw(yaw);
        _renderedPreviewDataUrl = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task CloseAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _viewerHost);
            }
            catch (InvalidOperationException)
            {
            }
            catch (JSDisconnectedException)
            {
            }
        }

        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _viewerHost);
                await _module.DisposeAsync();
            }
            catch (InvalidOperationException)
            {
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
