@namespace PixelChat.Components.Shared
@using System.Globalization
@using PixelChat.Art
@using PixelChat.Models
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IJSRuntime JS

<div class="guide-modal-backdrop" @onclick="CloseAsync">
    <section class="guide-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="guide-builder-title" @onclick:stopPropagation="true">
        <header class="guide-modal-head">
            <div>
                <h2 id="guide-builder-title">Create Animation Guide</h2>
                <span>@GuideSubtitle</span>
            </div>
            <button type="button" class="guide-close-button" aria-label="Close guide builder" @onclick="CloseAsync">x</button>
        </header>

        <div class="guide-modal-grid">
            <main class="guide-stage">
                <div class="guide-stage-head">
                    <strong>@StageTitle</strong>
                    <span>@StageMeta</span>
                </div>
                <div class="guide-stage-body">
                    @if (_stageMode == GuideStageMode.Viewer)
                    {
                        <div class="guide-viewer-host" @ref="_viewerHost"></div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_renderedPreviewDataUrl))
                    {
                        <div class="guide-rendered-preview">
                            <img src="@_renderedPreviewDataUrl" alt="@_label" />
                        </div>
                    }
                    else
                    {
                        @RenderGridPreview()
                    }
                </div>
            </main>

            <aside class="guide-controls">
                <section class="guide-control-section">
                    <div class="guide-control-title">Grid</div>
                    <label>
                        <span>Label</span>
                        <input class="form-control" value="@_label" @onchange="OnLabelChanged" />
                    </label>
                    <div class="guide-control-pair">
                        <label>
                            <span>Frames</span>
                            <input class="form-control" type="number" min="1" max="16" @bind="_frameCount" @bind:after="OnGridDimensionsChanged" />
                        </label>
                        <label>
                            <span>FPS</span>
                            <input class="form-control" type="number" min="1" max="60" @bind="_fps" @bind:after="OnGridSettingsChanged" />
                        </label>
                    </div>
                    <div class="guide-control-pair">
                        <label>
                            <span>Rows</span>
                            <input class="form-control" type="number" min="1" max="8" @bind="_rows" @bind:after="OnGridDimensionsChanged" />
                        </label>
                        <label>
                            <span>Columns</span>
                            <input class="form-control" type="number" min="1" max="8" @bind="_columns" @bind:after="OnGridDimensionsChanged" />
                        </label>
                    </div>
                    <label>
                        <span>Image size</span>
                        <select class="form-select" value="@_guideCanvasSize" @onchange="OnImageSizeChanged">
                            @foreach (var option in ImageSizeOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                    </label>
                    <div class="guide-control-pair">
                        <label>
                            <span>Cell width</span>
                            <input class="form-control" type="number" min="1" max="@SlotWidth" step="16" @bind="_cellWidth" @bind:after="OnCellSizeChanged" />
                        </label>
                        <label>
                            <span>Cell height</span>
                            <input class="form-control" type="number" min="1" max="@SlotHeight" step="16" @bind="_cellHeight" @bind:after="OnCellSizeChanged" />
                        </label>
                    </div>
                    <label>
                        <span>Safe margin @_safeMarginPercent.ToString("0")%</span>
                        <input type="range" min="0" max="30" step="1" @bind="_safeMarginPercent" @bind:after="OnGridSettingsChanged" />
                    </label>
                    <label class="guide-checkbox">
                        <input type="checkbox" @bind="_loop" @bind:after="InvalidateLayoutPreview" />
                        <span>Loop</span>
                    </label>
                    @if (!_animationEditorOpen)
                    {
                        <button type="button" class="btn btn-primary guide-add-animation-button" @onclick="AddAnimation">Add Animation</button>
                    }
                </section>

                @if (_animationEditorOpen)
                {
                <section class="guide-control-section">
                    <div class="guide-control-title">Animation</div>
                    <label>
                        <span>Animation</span>
                        <select class="form-select" value="@_motionClipId" @onchange="OnMotionClipChanged">
                            <option value="">Select animation</option>
                            @foreach (var clip in _motionClips)
                            {
                                <option value="@clip.MotionClipId">@clip.DisplayName</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Yaw @_yaw.ToString("0", CultureInfo.InvariantCulture) deg</span>
                        <input type="range" min="-180" max="180" step="1" @bind="_yaw" @bind:after="OnYawChangedAsync" />
                    </label>
                    <label>
                        <span>Pitch @_pitch.ToString("0", CultureInfo.InvariantCulture) deg</span>
                        <input type="range" min="-45" max="45" step="1" @bind="_pitch" @bind:after="OnPitchChangedAsync" />
                    </label>
                    <div class="guide-viewer-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_stageMode != GuideStageMode.Viewer)" @onclick="TogglePlaybackAsync">@(_playing ? "Pause" : "Play")</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetYawAsync">Reset Yaw</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetPitchAsync">Reset Pitch</button>
                    </div>
                    <button type="button" class="btn btn-outline-primary" disabled="@RenderDisabled" @onclick="RenderFramesAsync">Render Frames</button>
                </section>
                }

                @if (!string.IsNullOrWhiteSpace(_status))
                {
                    <div class="guide-status">@_status</div>
                }
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="guide-error">@_error</div>
                }
            </aside>
        </div>

        <footer class="guide-modal-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Cancel</button>
            <button type="button" class="btn btn-primary" disabled="@FinishDisabled" @onclick="FinishAsync">Finish</button>
        </footer>
    </section>
</div>

@code {
    private enum GuideStageMode
    {
        Grid,
        Viewer,
        Rendered,
    }

    private sealed record GuideImageSizeOption(string Value, string Label, int Width, int Height);

    private static readonly GuideImageSizeOption[] ImageSizeOptions =
    [
        new("1024x1024", "1024 x 1024", 1024, 1024),
        new("1536x1024", "1536 x 1024", 1536, 1024),
        new("1024x1536", "1024 x 1536", 1024, 1536),
        new("1536x864", "1536 x 864", 1536, 864),
        new("864x1536", "864 x 1536", 864, 1536),
        new("2048x1152", "2048 x 1152", 2048, 1152),
        new("1152x2048", "1152 x 2048", 1152, 2048),
        new("1344x1008", "1344 x 1008", 1344, 1008),
        new("1008x1344", "1008 x 1344", 1008, 1344),
    ];

    [Parameter, EditorRequired]
    public Guid ProjectId { get; set; }

    [Parameter]
    public IReadOnlyList<ArtAssetView> ProjectAssets { get; set; } = [];

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<AnimationGuideRenderView> OnSaved { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<AnimationGuideBuilderModal>? _dotNetRef;
    private ElementReference _viewerHost;
    private IReadOnlyList<MotionClipView> _motionClips = [];
    private string _viewerKey = string.Empty;
    private GuideStageMode _stageMode = GuideStageMode.Grid;
    private bool _animationEditorOpen;
    private bool _viewerModuleLoadFailed;
    private string _label = "8-frame layout guide";
    private int _frameCount = 8;
    private int _rows = 2;
    private int _columns = 4;
    private int _lastRows = 2;
    private int _lastColumns = 4;
    private string _guideCanvasSize = "1024x1024";
    private int _cellWidth = 256;
    private int _cellHeight = 512;
    private int _fps = 8;
    private double _safeMarginPercent = 12d;
    private bool _loop = true;
    private string _motionClipId = string.Empty;
    private string _animationKind = "walk";
    private string _rootMotion = "in_place";
    private double _yaw = 90d;
    private double _pitch;
    private bool _playing = true;
    private bool _busy;
    private string _status = string.Empty;
    private string? _error;
    private string _renderedPreviewDataUrl = string.Empty;

    private int SlotWidth => Math.Max(1, SelectedImageSize().Width / Math.Max(1, _columns));

    private int SlotHeight => Math.Max(1, SelectedImageSize().Height / Math.Max(1, _rows));

    private string GridBoxStyle
    {
        get
        {
            var widthPercent = Math.Clamp(_cellWidth / (double)SlotWidth * 100d, 1d, 100d);
            var heightPercent = Math.Clamp(_cellHeight / (double)SlotHeight * 100d, 1d, 100d);
            return string.Create(
                System.Globalization.CultureInfo.InvariantCulture,
                $"width:{widthPercent:0.###}%;height:{heightPercent:0.###}%;");
        }
    }

    private string GuideSubtitle =>
        _stageMode switch
        {
            GuideStageMode.Viewer => SelectedMotionClip()?.DisplayName ?? "Motion clip",
            GuideStageMode.Rendered => $"{_frameCount} frame(s), {_columns} x {_rows}",
            _ => $"{_frameCount} frame(s), {_columns} x {_rows}"
        };

    private string StageTitle =>
        _stageMode switch
        {
            GuideStageMode.Viewer => "3D Motion",
            GuideStageMode.Rendered => "Rendered Guide",
            _ => "Guide Grid"
        };

    private string StageMeta =>
        _stageMode == GuideStageMode.Viewer
            ? $"{_animationKind} - yaw {_yaw.ToString("0", CultureInfo.InvariantCulture)} deg, pitch {_pitch.ToString("0", CultureInfo.InvariantCulture)} deg"
            : $"{_guideCanvasSize} - {_columns} columns x {_rows} rows - {_cellWidth} x {_cellHeight}";

    private bool HasActiveMotionGuide =>
        _animationEditorOpen && !string.IsNullOrWhiteSpace(_motionClipId);

    private bool RenderDisabled =>
        _busy || !HasActiveMotionGuide;

    private bool FinishDisabled =>
        _busy;

    protected override async Task OnInitializedAsync()
    {
        _motionClips = await Workflow.ListMotionClipsAsync(limit: 100);
        var defaultClip = _motionClips.FirstOrDefault(clip => clip.MotionClipId == "quaternius.ual1.walk.loop")
            ?? _motionClips.FirstOrDefault(clip => clip.MotionClipId == "quaternius.ual2.walk.carry.loop")
            ?? _motionClips.FirstOrDefault();
        if (defaultClip is not null)
            ApplyMotionClip(defaultClip, switchToViewer: false, applyDefaults: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await RenderViewerIfNeededAsync();
    }

    private async Task<bool> EnsureViewerModuleAsync()
    {
        if (_module is not null && _dotNetRef is not null)
            return true;
        if (_viewerModuleLoadFailed)
            return false;

        try
        {
            var modulePath = "./js/animation-guide-builder.js?v=3";
            _module = await JS.InvokeAsync<IJSObjectReference>("import", modulePath);
            _dotNetRef = DotNetObjectReference.Create(this);
            return true;
        }
        catch (JSException ex)
        {
            _module = null;
            _dotNetRef?.Dispose();
            _dotNetRef = null;
            _viewerModuleLoadFailed = true;
            _error = $"The 3D viewer module could not load: {ex.Message}";
            await InvokeAsync(StateHasChanged);
            return false;
        }
    }

    private RenderFragment RenderGridPreview() => __builder =>
    {
        var safeInset = Math.Clamp(_safeMarginPercent, 0d, 40d);
        <div class="guide-grid-preview" style="@GridPreviewStyle">
            @for (var index = 0; index < _rows * _columns; index++)
            {
                var active = index < _frameCount;
                <div class="guide-grid-cell @(active ? "is-active" : "is-empty")" @key="index">
                    @if (active)
                    {
                        <span>@((index + 1).ToString("00", CultureInfo.InvariantCulture))</span>
                        <div class="guide-grid-box" style="@GridBoxStyle">
                            <i style="@($"inset:{safeInset.ToString("0.##", CultureInfo.InvariantCulture)}%;")"></i>
                        </div>
                    }
                </div>
            }
        </div>
    };

    private string GridPreviewStyle =>
        string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"--guide-aspect-ratio:{SelectedImageSize().Width / (double)SelectedImageSize().Height:0.########};grid-template-columns:repeat({_columns}, minmax(0, 1fr)); grid-template-rows:repeat({_rows}, minmax(0, 1fr)); aspect-ratio:{SelectedImageSize().Width} / {SelectedImageSize().Height};");

    private async Task RenderViewerIfNeededAsync()
    {
        if (_stageMode != GuideStageMode.Viewer)
            return;

        var clip = SelectedMotionClip();
        if (clip is null)
            return;

        if (!await EnsureViewerModuleAsync())
            return;

        var module = _module;
        var dotNetRef = _dotNetRef;
        if (module is null || dotNetRef is null)
            return;

        var key = $"{clip.MotionClipId}|{clip.AnimationName}";
        if (string.Equals(key, _viewerKey, StringComparison.Ordinal))
        {
            await module.InvokeVoidAsync("setYaw", _viewerHost, _yaw);
            await module.InvokeVoidAsync("setPitch", _viewerHost, _pitch);
            await module.InvokeVoidAsync("setPlaying", _viewerHost, _playing);
            return;
        }

        _viewerKey = key;
        var assetUrl = $"/media/motion-clips/{Uri.EscapeDataString(clip.MotionClipId)}/asset";
        await module.InvokeVoidAsync("startViewer", _viewerHost, new
        {
            assetUrl,
            clip.AnimationName,
            yaw = _yaw,
            pitch = _pitch,
            playing = _playing,
        }, dotNetRef);
    }

    private void OnGridDimensionsChanged()
    {
        ClampGridValues();
        if (_rows != _lastRows || _columns != _lastColumns)
            ResetCellSizeToSlot();
        else
            ClampCellSize();
        TrackGridDimensions();
        InvalidateLayoutPreview();
    }

    private void OnGridSettingsChanged()
    {
        ClampGridValues();
        ClampCellSize();
        TrackGridDimensions();
        InvalidateLayoutPreview();
    }

    private void ClampGridValues()
    {
        _frameCount = Math.Clamp(_frameCount, 1, 16);
        _columns = Math.Clamp(_columns, 1, 8);
        _rows = Math.Clamp(_rows, 1, 8);
        if (_rows * _columns < _frameCount)
            _rows = Math.Clamp((int)Math.Ceiling(_frameCount / (double)_columns), 1, 8);
        _fps = Math.Clamp(_fps, 1, 60);
        _safeMarginPercent = Math.Clamp(_safeMarginPercent, 0d, 30d);
    }

    private void OnCellSizeChanged()
    {
        ClampCellSize();
        InvalidateLayoutPreview();
    }

    private void OnImageSizeChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        _guideCanvasSize = ImageSizeOptions.Any(option => string.Equals(option.Value, value, StringComparison.Ordinal))
            ? value!
            : ImageSizeOptions[0].Value;
        ResetCellSizeToSlot();
        InvalidateLayoutPreview();
    }

    private void ResetCellSizeToSlot()
    {
        _cellWidth = SlotWidth;
        _cellHeight = SlotHeight;
    }

    private void ClampCellSize()
    {
        _cellWidth = Math.Clamp(_cellWidth, 1, SlotWidth);
        _cellHeight = Math.Clamp(_cellHeight, 1, SlotHeight);
    }

    private void TrackGridDimensions()
    {
        _lastRows = _rows;
        _lastColumns = _columns;
    }

    private void InvalidateLayoutPreview()
    {
        _renderedPreviewDataUrl = string.Empty;
        _status = string.Empty;
        _stageMode = GuideStageMode.Grid;
    }

    private void InvalidateAnimationPreview()
    {
        _renderedPreviewDataUrl = string.Empty;
        _status = string.Empty;
        _stageMode = _animationEditorOpen && !string.IsNullOrWhiteSpace(_motionClipId)
            ? GuideStageMode.Viewer
            : GuideStageMode.Grid;
    }

    private void AddAnimation()
    {
        _animationEditorOpen = true;
        _status = string.Empty;
        _error = null;
        if (string.IsNullOrWhiteSpace(_motionClipId) && _motionClips.FirstOrDefault() is { } clip)
            ApplyMotionClip(clip, switchToViewer: false, applyDefaults: true);

        _stageMode = !string.IsNullOrWhiteSpace(_motionClipId)
            ? GuideStageMode.Viewer
            : GuideStageMode.Grid;
        _viewerKey = string.Empty;
    }

    private void OnLabelChanged(ChangeEventArgs args)
    {
        _label = string.IsNullOrWhiteSpace(args.Value?.ToString())
            ? "Animation guide"
            : args.Value.ToString()!.Trim();
        InvalidateLayoutPreview();
    }

    private void OnMotionClipChanged(ChangeEventArgs args)
    {
        _motionClipId = args.Value?.ToString() ?? string.Empty;
        if (SelectedMotionClip() is { } clip)
        {
            ApplyMotionClip(clip, switchToViewer: _animationEditorOpen, applyDefaults: false);
        }
        else
        {
            _renderedPreviewDataUrl = string.Empty;
            _status = string.Empty;
            _stageMode = GuideStageMode.Grid;
            _viewerKey = string.Empty;
        }
    }

    private void ApplyMotionClip(MotionClipView clip, bool switchToViewer, bool applyDefaults)
    {
        _motionClipId = clip.MotionClipId;
        _animationKind = clip.SupportedAnimationKinds.FirstOrDefault() ?? _animationKind;
        _rootMotion = string.IsNullOrWhiteSpace(clip.RecommendedRootMotion) ? "in_place" : clip.RecommendedRootMotion;
        if (applyDefaults)
        {
            _fps = Math.Clamp(clip.DefaultFps > 0 ? clip.DefaultFps : _fps, 1, 60);
            _loop = clip.LoopRecommended;
        }

        _viewerKey = string.Empty;
        if (switchToViewer)
            InvalidateAnimationPreview();
        else
            InvalidateLayoutPreview();
    }

    private async Task OnYawChangedAsync()
    {
        _yaw = NormalizeYaw(_yaw);
        InvalidateAnimationPreview();
        if (_module is not null && _stageMode == GuideStageMode.Viewer)
            await _module.InvokeVoidAsync("setYaw", _viewerHost, _yaw);
    }

    private async Task OnPitchChangedAsync()
    {
        _pitch = NormalizePitch(_pitch);
        InvalidateAnimationPreview();
        if (_module is not null && _stageMode == GuideStageMode.Viewer)
            await _module.InvokeVoidAsync("setPitch", _viewerHost, _pitch);
    }

    private async Task ResetYawAsync()
    {
        _yaw = SpriteFacing.ToYawDegrees(SpriteFacing.SideRight);
        await OnYawChangedAsync();
    }

    private async Task ResetPitchAsync()
    {
        _pitch = 0d;
        await OnPitchChangedAsync();
    }

    private async Task TogglePlaybackAsync()
    {
        _playing = !_playing;
        if (_module is not null && _stageMode == GuideStageMode.Viewer)
            await _module.InvokeVoidAsync("setPlaying", _viewerHost, _playing);
    }

    private async Task RenderFramesAsync()
    {
        if (RenderDisabled)
            return;

        _busy = true;
        _error = null;
        _status = "Rendering guide frames...";
        try
        {
            var preview = await Workflow.PreviewAnimationGuideAsync(ProjectId, BuildRequest());
            _renderedPreviewDataUrl = preview.ImageDataUrl;
            _stageMode = GuideStageMode.Rendered;
            _status = "Guide frames rendered.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task FinishAsync()
    {
        if (FinishDisabled)
            return;

        _busy = true;
        _error = null;
        _status = "Creating guide asset...";
        try
        {
            var saved = await Workflow.GenerateAnimationGuideAsync(ProjectId, BuildRequest());
            await OnSaved.InvokeAsync(saved);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }

    private GenerateAnimationGuideRequest BuildRequest() =>
        HasActiveMotionGuide
            ? BuildMotionGuideRequest()
            : BuildLayoutOnlyRequest();

    private GenerateAnimationGuideRequest BuildMotionGuideRequest() =>
        new(
            ReferenceAssetId: null,
            AnimationKind: _animationKind,
            AssetType: "unit",
            StructureType: "humanoid",
            Facing: SpriteFacing.SideRight,
            FrameCount: _frameCount,
            Fps: _fps,
            RootMotion: _rootMotion,
            TargetCellSize: $"{_cellWidth}x{_cellHeight}",
            MotionClipId: _motionClipId,
            Label: _label,
            Rows: _rows,
            Columns: _columns,
            GuideCellSize: $"{_cellWidth}x{_cellHeight}",
            GuideCameraYawDegrees: _yaw,
            GuideCameraPitchDegrees: _pitch,
            Loop: _loop,
            SafeMarginPercent: _safeMarginPercent,
            GuideCanvasSize: _guideCanvasSize,
            LayoutOnly: false);

    private GenerateAnimationGuideRequest BuildLayoutOnlyRequest() =>
        new(
            ReferenceAssetId: null,
            AnimationKind: "layout",
            AssetType: "unit",
            StructureType: "humanoid",
            Facing: SpriteFacing.SideRight,
            FrameCount: _frameCount,
            Fps: _fps,
            RootMotion: "in_place",
            TargetCellSize: $"{_cellWidth}x{_cellHeight}",
            MotionClipId: null,
            Label: _label,
            Rows: _rows,
            Columns: _columns,
            GuideCellSize: $"{_cellWidth}x{_cellHeight}",
            GuideCameraYawDegrees: null,
            GuideCameraPitchDegrees: null,
            Loop: _loop,
            SafeMarginPercent: _safeMarginPercent,
            GuideCanvasSize: _guideCanvasSize,
            LayoutOnly: true);

    private MotionClipView? SelectedMotionClip() =>
        string.IsNullOrWhiteSpace(_motionClipId)
            ? null
            : _motionClips.FirstOrDefault(clip => string.Equals(clip.MotionClipId, _motionClipId, StringComparison.OrdinalIgnoreCase));

    private GuideImageSizeOption SelectedImageSize() =>
        ImageSizeOptions.FirstOrDefault(option => string.Equals(option.Value, _guideCanvasSize, StringComparison.Ordinal))
            ?? ImageSizeOptions[0];

    private static double NormalizeYaw(double yaw)
    {
        var normalized = yaw % 360d;
        if (normalized > 180d)
            normalized -= 360d;
        if (normalized < -180d)
            normalized += 360d;
        return Math.Round(normalized, 2);
    }

    private static double NormalizePitch(double pitch) =>
        Math.Round(Math.Clamp(pitch, -45d, 45d), 2);

    [JSInvokable]
    public Task OnAnimationGuideYawChanged(double yaw)
    {
        _yaw = NormalizeYaw(yaw);
        _renderedPreviewDataUrl = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnAnimationGuideCameraChanged(double yaw, double pitch)
    {
        _yaw = NormalizeYaw(yaw);
        _pitch = NormalizePitch(pitch);
        _renderedPreviewDataUrl = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task CloseAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _viewerHost);
            }
            catch (InvalidOperationException)
            {
            }
            catch (JSDisconnectedException)
            {
            }
        }

        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _viewerHost);
                await _module.DisposeAsync();
            }
            catch (InvalidOperationException)
            {
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
