@namespace PixelChat.Components.Shared
@using PixelChat.Art
@implements IAsyncDisposable
@inject IJSRuntime JS

<canvas class="@CssClass" title="@Title" aria-label="@Title" @ref="_canvas" @onclick="OnClick"></canvas>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<AnimationPreviewFrame> Frames { get; set; } = [];

    [Parameter]
    public int Fps { get; set; } = 8;

    [Parameter]
    public bool Loop { get; set; } = true;

    // Stable identity so the preview only restarts when the underlying frames change.
    [Parameter]
    public string PreviewKey { get; set; } = string.Empty;

    [Parameter]
    public string CssClass { get; set; } = "sprite-animation-preview";

    [Parameter]
    public string Title { get; set; } = "Sprite animation preview";

    [Parameter]
    public EventCallback OnClick { get; set; }

    private IJSObjectReference? _module;
    private ElementReference _canvas;
    private string _renderedKey = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Shared/SpriteAnimationPreview.razor.js");

        await RenderPreviewIfNeededAsync();
    }

    private async Task RenderPreviewIfNeededAsync()
    {
        if (_module is null)
            return;

        var frames = Frames
            .Where(frame => !string.IsNullOrWhiteSpace(frame.Url))
            .Select(frame => new
            {
                previewImageUrl = frame.Url,
                frame.Label,
                duration = frame.DurationMs / 1000d,
            })
            .ToList();
        var key = $"{PreviewKey}:{Fps}:{Loop}:{frames.Count}:{string.Join('|', frames.Select(frame => frame.previewImageUrl))}";
        if (string.Equals(key, _renderedKey, StringComparison.Ordinal))
            return;

        _renderedKey = key;
        await _module.InvokeVoidAsync("start", _canvas, frames, Fps, Loop);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("dispose", _canvas);
            await _module.DisposeAsync();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
