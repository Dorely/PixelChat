        string.IsNullOrWhiteSpace(frame.WorkingState) || frame.WorkingState == "none" ? "Source" : Capitalize(frame.WorkingState);

    private static string WorkingBadgeClass(FrameView frame) =>
        string.IsNullOrWhiteSpace(frame.WorkingState) || frame.WorkingState == "none" ? "frame-work-badge is-empty" : "frame-work-badge";

    private string EditModalTitle() => _editTargetKind == SpriteEditTargetKind.Frame ? "Edit Frame" : "Edit Source";

    private string EditModalSubtitle()
    {
        if (_editTargetKind == SpriteEditTargetKind.Frame && SelectedFrame() is { } frame)
            return $"{frame.Name} / mask, prompt, and candidates";
        return SelectedSourceArtAsset() is { } source ? $"{source.Label} / mask, prompt, and candidates" : "Mask, prompt, and candidates";
    }

    private string EditResultsLabel()
    {
        var outputs = EditCandidateOutputs();
        if (_editGenerating)
            return outputs.Count == 0 ? "Generating candidates..." : $"Generating / {outputs.Count} output(s)";
        return outputs.Count == 0 ? "Results" : $"{outputs.Count} output(s)";
    }

    private string EditCandidateClass(SpriteEditCandidateOutput candidate)
    {
        var selected = _selectedEditOutputIndex == candidate.OutputIndex && _editPreviewOverlayActive ? " is-selected" : "";
        var state = candidate.IsFinal ? " is-final" : candidate.HasPartial ? " is-partial" : candidate.StatusLabel == "failed" ? " is-failed" : "";
        return string.Concat(selected, state);
    }

    private static int FrameEditPadding(FrameView frame)
    {
        var largest = Math.Max(frame.LogicalWidth, frame.LogicalHeight);
        return Math.Clamp(Math.Max(32, largest / 2), 32, 512);
    }

    private static string Capitalize(string value) =>
        string.IsNullOrEmpty(value) ? value : char.ToUpperInvariant(value[0]) + value[1..];

    private static bool IsTerminalGenerationOutputStatus(GenerationOutputStatus status) =>
        status is GenerationOutputStatus.Succeeded or GenerationOutputStatus.Failed or GenerationOutputStatus.Cancelled;

    private static Guid? ParseGuid(string? value) => Guid.TryParse(value, out var id) ? id : null;

    public async ValueTask DisposeAsync()
    {
        StopAnimation();
        ImageRuntime.StateChanged -= OnImageGenerationRuntimeStateChanged;
        try
        {
            if (_module is not null)
                await _module.DisposeAsync();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            _dotNetRef?.Dispose();
        }
    }

    private enum SpriteEditTargetKind
    {
        Source,
        Frame
    }

    private enum SpriteMode
    {
        Source,
        Frames,
        Sheet,
        Export
    }

    public sealed record SourceCanvasPayload(IReadOnlyList<CanvasRegion> Regions, IReadOnlyList<string> SelectedIds);

    public sealed record CanvasRegion(
        string? Id,
        string Name,
        int X,
        int Y,
        int Width,
        int Height,
        IReadOnlyList<SpriteSheetShapePath> ShapePaths,
        string RegionType,
        int Order)
    {
        public static CanvasRegion From(SourceRegionView view) =>
            new(view.Id.ToString(), view.Name, view.X, view.Y, view.Width, view.Height, view.ShapePaths, view.RegionType, view.Order);

        public SourceRegionView ToView(Guid sourceAssetId, int fallbackOrder) =>
            new(ParseGuid(Id) ?? Guid.NewGuid(), sourceAssetId, Name, X, Y, Width, Height, ShapePaths, string.IsNullOrWhiteSpace(RegionType) ? "frame" : RegionType, Order >= 0 ? Order : fallbackOrder);
    }

    public sealed record CanvasFrame(
        string Id,
        int Index,
        string Name,
        int LogicalWidth,
        int LogicalHeight,
        int SourceWidth,
        int SourceHeight,
        int WorkingWidth,
        int WorkingHeight,
        int ContentOffsetX,
        int ContentOffsetY,
        bool HasMask)
    {
        public static CanvasFrame From(FrameView frame) =>
            new(frame.Id.ToString(), frame.Index, frame.Name, frame.LogicalWidth, frame.LogicalHeight, frame.SourceWidth, frame.SourceHeight, frame.WorkingWidth, frame.WorkingHeight, frame.ContentOffsetX, frame.ContentOffsetY, frame.HasMask);
    }

    private sealed record SpriteEditCandidateOutput(
        int OutputIndex,
        Guid? AssetId,
        string Label,
        string? ImageUrl,
        string StatusLabel,
        string Error,
        bool HasPartial,
        bool IsFinal);

    private sealed record SpriteEditCrop(
        int EditSourceWidth,
        int EditSourceHeight,
        int CropX,
        int CropY,
        int CropWidth,
        int CropHeight)
    {
        public static SpriteEditCrop SourceDefault(ArtAssetView? asset)
        {
            var width = Math.Max(0, asset?.Width ?? 0);
            var height = Math.Max(0, asset?.Height ?? 0);
            return new SpriteEditCrop(width, height, 0, 0, width, height);
        }
    }
}
