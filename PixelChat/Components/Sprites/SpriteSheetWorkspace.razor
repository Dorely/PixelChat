    private async Task SetFrameOffsetAsync(FrameView frame, string axis, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var value))
            return;
        var nextX = axis == "x" ? value : frame.ContentOffsetX;
        var nextY = axis == "y" ? value : frame.ContentOffsetY;
        await SetFrameOffsetAsync(frame.Id, nextX, nextY);
    }

    private async Task NudgeSelectedFrameAsync(int dx, int dy)
    {
        if (SelectedFrame() is not { } frame)
            return;
        await SetFrameOffsetAsync(frame.Id, frame.ContentOffsetX + dx, frame.ContentOffsetY + dy);
    }

    private async Task SetFrameOffsetAsync(Guid frameId, int x, int y)
    {
        if (_frameSet is not { } set)
            return;
        var updated = await FrameSets.TranslateFrameContentAsync(Workbench.Project.Id, new TranslateFrameContentRequest(set.Id, frameId, x, y));
        ApplyFrameSet(updated);
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task BuildSheetAsync()
    {
        if (_frameSet is not { } set)
            return;

        await RunAsync("Building sheet...", async () =>
        {
            var result = await FrameSets.BuildSheetAsync(Workbench.Project.Id, new BuildSheetRequest(
                set.Id,
                _rows,
                _columns,
                Padding: 0,
                _gutter,
                _outerMargin,
                _ordering));
