    private async Task ExtractSelectedRegionAsAssetAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceId || SelectedRegion() is not { } region)
            return;

        await RunAsync("Extracting region...", async () =>
        {
            var result = await Workflow.ExtractRegionAsAssetAsync(Workbench.Project.Id, new ExtractRegionAsAssetRequest(
                sourceId,
                region.X,
                region.Y,
                region.Width,
                region.Height,
                Name: region.Name,
