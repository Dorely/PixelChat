    private async Task PersistEditSessionAsync()
    {
        if (_editTargetSourceAssetId is not Guid)
            return;

        var outputStates = CurrentEditOutputStates();
        var candidateIds = EditCandidateOutputs()
            .Where(candidate => candidate.AssetId is Guid)
            .Select(candidate => candidate.AssetId!.Value)
            .Distinct()
            .ToList();
        var view = await FrameSets.SaveSpriteEditSessionAsync(Workbench.Project.Id, new SaveSpriteEditSessionRequest(
            _editModalOpen,
            _editTargetKind == SpriteEditTargetKind.Frame ? "frame" : "source",
            _editTargetSourceAssetId,
            _editTargetFrameSetId,
            _editTargetFrameId,
            _editBatchId,
            _editMaskId,
            _selectedEditCandidateId,
            _selectedEditOutputIndex,
            _editPreviewOverlayActive,
            _editPrompt,
            Math.Clamp(_editCount, 1, Math.Max(1, ImageOptions.Value.MaxOutputs)),
            _editCrop is null
                ? null
                : new SpriteEditSessionCrop(
                    _editCrop.EditSourceWidth,
                    _editCrop.EditSourceHeight,
                    _editCrop.CropX,
                    _editCrop.CropY,
                    _editCrop.CropWidth,
                    _editCrop.CropHeight),
            candidateIds,
            outputStates));
        _editSessionId = view.Id;
        _editPersistedOutputStates = view.OutputStates.ToList();
        _editCandidateAssetIds = view.CandidateAssetIds.ToList();
    }

    private void RefreshEditImageUrls()
    {
        _editImageUrl = _editTargetKind == SpriteEditTargetKind.Frame && _editTargetFrameId is Guid frameId
            ? FramePreviewUrl(frameId)
            : _editTargetSourceAssetId is Guid sourceAssetId
                ? AssetFullUrl(sourceAssetId)
                : null;
        _editMaskUrl = _editMaskId is Guid maskId
            ? MaskUrl(maskId)
            : _editTargetKind == SpriteEditTargetKind.Frame
                && _editTargetFrameId is Guid targetFrameId
                && _frameSet?.Frames.FirstOrDefault(frame => frame.Id == targetFrameId) is { HasMask: true }
                    ? FrameMaskUrl(targetFrameId)
                    : null;
    }

    private bool RefreshEditCandidatesFromWorkbench()
    {
        if (_editBatchId is not Guid batchId)
            return false;

        var ids = Workbench.Assets
            .Where(asset => asset.SourceBatchId == batchId || _editCandidateAssetIds.Contains(asset.Id))
            .OrderBy(asset => asset.BatchOutputIndex ?? int.MaxValue)
            .ThenBy(asset => asset.CreatedAt)
            .Select(asset => asset.Id)
            .Distinct()
            .ToList();
        if (_editCandidateAssetIds.SequenceEqual(ids))
            return false;

        _editCandidateAssetIds = ids;
        if (_selectedEditCandidateId is Guid selectedAssetId
            && !_editCandidateAssetIds.Contains(selectedAssetId))
        {
            _selectedEditCandidateId = null;
            _selectedEditOutputIndex = null;
            _editPreviewOverlayActive = false;
        }
        if (_selectedEditOutputIndex is int outputIndex
            && EditCandidateAssetsByOutput().TryGetValue(outputIndex, out var selectedAsset))
        {
            if (_selectedEditCandidateId != selectedAsset.Id)
            {
                _selectedEditCandidateId = selectedAsset.Id;
                if (_editPreviewOverlayActive)
                    _editCanvasLoadVersion++;
            }
        }
        return true;
    }

    private void RefreshEditGeneratingState()
    {
        if (_editBatchId is not Guid batchId)
        {
            _editGenerating = false;
            return;
        }

        var runtimeRunning = _generationRuntimeSnapshot.Batches.Any(batch => batch.BatchId == batchId && batch.IsRunning);
        var persistedRunning = Workbench.Batches.FirstOrDefault(batch => batch.Id == batchId)?.Status is GenerationBatchStatus.Queued or GenerationBatchStatus.Running;
        _editGenerating = runtimeRunning || persistedRunning;
    }

    private void OnImageGenerationRuntimeStateChanged(object? sender, EventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            var snapshot = ImageRuntime.GetSnapshot();
            _generationRuntimeSnapshot = snapshot;
            if (_editBatchId is Guid batchId)
            {
                RefreshEditGeneratingState();
                var activeBatch = snapshot.Batches.FirstOrDefault(batch => batch.BatchId == batchId);
                var sawTerminalOutput = false;
                if (activeBatch is not null)
                {
                    foreach (var output in activeBatch.Outputs.Where(output => IsTerminalGenerationOutputStatus(output.Status)))
                    {
                        if (_observedEditTerminalOutputs.Add(output.OutputIndex))
                            sawTerminalOutput = true;
                    }
                }

                if (sawTerminalOutput)
                    await OnChanged.InvokeAsync();

                _editPersistedOutputStates = CurrentEditOutputStates().ToList();
                await PersistEditSessionAsync();
                await PublishSpritesStateAsync();
            }
            StateHasChanged();
        });
    }

    private IReadOnlyList<SpriteEditCandidateOutput> EditCandidateOutputs()
    {
        if (_editBatchId is not Guid batchId && _editCandidateAssetIds.Count == 0)
            return [];

        var runtimeBatch = _editBatchId is Guid id
            ? _generationRuntimeSnapshot.Batches.FirstOrDefault(batch => batch.BatchId == id)
            : null;
        var persistedBatch = _editBatchId is Guid persistedId
            ? Workbench.Batches.FirstOrDefault(batch => batch.Id == persistedId)
            : null;
        var assetsByOutput = EditCandidateAssetsByOutput();
        var statesByIndex = CurrentEditOutputStates().ToDictionary(state => state.OutputIndex);
        var maxIndex = new[]
            {
                Math.Max(0, _editCount - 1),
                runtimeBatch?.Outputs.Select(output => output.OutputIndex).DefaultIfEmpty(-1).Max() ?? -1,
                persistedBatch?.OutputStates.Select(state => state.OutputIndex).DefaultIfEmpty(-1).Max() ?? -1,
                assetsByOutput.Keys.DefaultIfEmpty(-1).Max(),
            }
            .Max();

        var outputs = new List<SpriteEditCandidateOutput>();
        for (var index = 0; index <= maxIndex; index++)
        {
            assetsByOutput.TryGetValue(index, out var asset);
            var runtime = runtimeBatch?.Outputs.FirstOrDefault(output => output.OutputIndex == index);
            statesByIndex.TryGetValue(index, out var state);
            var imageUrl = asset is not null
                ? AssetFullUrl(asset.Id)
                : runtime?.PartialImageDataUrl;
            var status = asset is not null
                ? "saved"
                : !string.IsNullOrWhiteSpace(runtime?.PartialImageDataUrl)
                    ? "partial"
                    : (runtime?.Status ?? state?.Status ?? GenerationOutputStatus.Queued).ToString().ToLowerInvariant();
            var error = runtime?.Error;
            if (string.IsNullOrWhiteSpace(error))
                error = state?.Error;
            outputs.Add(new SpriteEditCandidateOutput(
                index,
                asset?.Id,
                asset?.Label ?? $"Image {index + 1}",
                imageUrl,
                status,
                error ?? string.Empty,
                asset is null && !string.IsNullOrWhiteSpace(runtime?.PartialImageDataUrl),
                asset is not null));
        }

        return outputs;
    }

    private Dictionary<int, ArtAssetView> EditCandidateAssetsByOutput()
    {
        var candidates = Workbench.Assets
            .Where(asset => (_editBatchId is Guid batchId && asset.SourceBatchId == batchId) || _editCandidateAssetIds.Contains(asset.Id))
            .OrderBy(asset => asset.BatchOutputIndex ?? int.MaxValue)
            .ThenBy(asset => asset.CreatedAt)
            .ToList();
        var result = new Dictionary<int, ArtAssetView>();
        var fallbackIndex = 0;
        foreach (var asset in candidates)
        {
            var outputIndex = asset.BatchOutputIndex ?? fallbackIndex;
            while (result.ContainsKey(outputIndex))
                outputIndex++;
            result[outputIndex] = asset;
            fallbackIndex = Math.Max(fallbackIndex + 1, outputIndex + 1);
        }

        return result;
    }

    private IReadOnlyList<GenerationOutputStateView> CurrentEditOutputStates()
    {
        var byIndex = _editPersistedOutputStates.ToDictionary(state => state.OutputIndex);
        if (_editBatchId is Guid batchId
            && Workbench.Batches.FirstOrDefault(batch => batch.Id == batchId) is { } persistedBatch)
        {
            foreach (var state in persistedBatch.OutputStates)
                byIndex[state.OutputIndex] = state;
        }

        if (_editBatchId is Guid runtimeBatchId
            && _generationRuntimeSnapshot.Batches.FirstOrDefault(batch => batch.BatchId == runtimeBatchId) is { } runtimeBatch)
        {
            foreach (var output in runtimeBatch.Outputs)
            {
                byIndex[output.OutputIndex] = new GenerationOutputStateView(
                    output.OutputIndex,
                    output.Status,
                    output.Attempt,
                    output.Message,
                    output.Error,
                    output.ErrorKind,
                    output.RequestId,
                    output.ResponseId,
                    output.CallId,
                    output.LastEventType,
                    output.EventCount,
                    UpdatedAt: DateTime.UtcNow,
                    CompletedAt: IsTerminalGenerationOutputStatus(output.Status) ? DateTime.UtcNow : null);
            }
        }

        return byIndex.Values.OrderBy(state => state.OutputIndex).ToList();
    }

    private SpriteEditCandidateOutput? SelectedEditCandidateOutput()
    {
        if (_selectedEditOutputIndex is int outputIndex)
            return EditCandidateOutputs().FirstOrDefault(candidate => candidate.OutputIndex == outputIndex);
        if (_selectedEditCandidateId is Guid assetId)
            return EditCandidateOutputs().FirstOrDefault(candidate => candidate.AssetId == assetId);
        return null;
    }

