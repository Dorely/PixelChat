    private async Task DropFrameAsync(int targetIndex)
    {
        if (_dragFrameId is not Guid frameId)
            return;
        _dragFrameId = null;
        await ReorderFrameAsync(frameId, targetIndex);
    }

    private async Task DeleteFrameAsync(Guid frameId)
