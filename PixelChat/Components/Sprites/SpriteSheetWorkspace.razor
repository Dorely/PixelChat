    private object BuildLayoutPayload()
    {
        NormalizeLayout();
        return new
        {
            Rows = _rows,
            Columns = _columns,
            FrameCount = _frames.Count,
            CellWidth = _cellWidth,
            CellHeight = _cellHeight,
            Padding = _padding,
            Gutter = _gutter,
            Fps = _fps,
            Loop = _loop,
            HorizontalAnchor = _horizontalAnchor,
            VerticalAnchor = _verticalAnchor,
            AnchorRect = _stabilizationAnchor is { } anchor
                ? new { anchor.X, anchor.Y, anchor.Width, anchor.Height }
                : null,
            Frames = _frames
                .OrderBy(frame => frame.Index)
                .Select(frame => new
                {
                    frame.Index,
                    frame.Label,
                    SourceRect = new { X = frame.X, Y = frame.Y, Width = frame.Width, Height = frame.Height },
                    frame.ShapePaths,
                })
                .ToList(),
        };
    }

    private void ApplyFrameWorkingView(SpriteFrameWorkingView view)
    {
        var frame = _frames.FirstOrDefault(item => item.Index == view.Index);
        if (frame is not null)
        {
            frame.WorkingState = NormalizeWorkingState(view.State);
            frame.WorkingWidth = view.WorkingWidth;
            frame.WorkingHeight = view.WorkingHeight;
            frame.WorkingMargin = view.WorkingMargin;
            frame.WorkingUpdatedAt = view.WorkingUpdatedAt;
        }

        _loadedFrameWorkIndex = view.Index;
        _loadedFrameWorkUpdatedAt = view.WorkingUpdatedAt;
        _frameWorkImageDataUrl = view.WorkingPngDataUrl;
        _frameWorkImageWidth = view.WorkingWidth;
        _frameWorkImageHeight = view.WorkingHeight;
        if (string.IsNullOrWhiteSpace(view.WorkingPngDataUrl))
            ResetFrameEraseMode();
    }

    private void NormalizeLayout()
    {
        _rows = Math.Clamp(_rows, 1, 32);
        _columns = Math.Clamp(_columns, 1, 64);
        _cellWidth = Math.Clamp(_cellWidth, 1, 8192);
        _cellHeight = Math.Clamp(_cellHeight, 1, 8192);
        _padding = Math.Clamp(_padding, 0, 2048);
        _gutter = Math.Clamp(_gutter, 0, 2048);
        _fps = Math.Clamp(_fps, 1, 60);
        _horizontalAnchor = NormalizeHorizontalAnchor(_horizontalAnchor);
        _verticalAnchor = NormalizeVerticalAnchor(_verticalAnchor);
    }

    private void FitCellsToFrames(bool onlyWhenTooSmall = false)
    {
        if (_frames.Count == 0)
            return;

        var width = _frames.Max(frame => Math.Max(1, frame.Width)) + (_padding * 2);
        var height = _frames.Max(frame => Math.Max(1, frame.Height)) + (_padding * 2);
        if (!onlyWhenTooSmall || _cellWidth < width)
            _cellWidth = width;
        if (!onlyWhenTooSmall || _cellHeight < height)
            _cellHeight = height;
    }

    private void ReindexFrames()
    {
        for (var index = 0; index < _frames.Count; index++)
        {
            _frames[index].Index = index;
            if (string.IsNullOrWhiteSpace(_frames[index].Label))
                _frames[index].Label = $"Frame {index + 1}";
        }

        if (_frames.Count > 0 && _rows * _columns < _frames.Count)
            _columns = Math.Max(1, (int)Math.Ceiling(_frames.Count / (double)_rows));
    }

    private SpriteSheetEditorFrame? SelectedFrame() =>
        _selectedFrameIndex >= 0 && _selectedFrameIndex < _frames.Count ? _frames[_selectedFrameIndex] : null;

    private ArtAssetView? CurrentWorkingAsset() =>
        Workbench.ActiveSpriteSheet is { } active ? CurrentWorkingAsset(active) : null;

    private ArtAssetView? CurrentWorkingAsset(SpriteSheetDefinitionView active) =>
        active.WorkingAssetId is Guid assetId
            ? Workbench.Assets.FirstOrDefault(asset => asset.Id == assetId)
            : null;

    private string HeaderSummary()
    {
        if (Workbench.ActiveSpriteSheet is null)
            return "No sprite sheet selected";

        var source = Workbench.Assets.FirstOrDefault(asset => asset.Id == Workbench.ActiveSpriteSheet.SourceAssetId);
        var outputSize = $"{_columns * _cellWidth + Math.Max(0, _columns - 1) * _gutter} x {_rows * _cellHeight + Math.Max(0, _rows - 1) * _gutter}";
        return $"{source?.Label ?? Workbench.ActiveSpriteSheet.Label} / {_frames.Count} frame(s) / {outputSize}";
    }

    private int ReferenceFrameNumber() =>
        _stabilizationReferenceFrameNumber is int frameNumber && frameNumber > 0
            ? frameNumber
            : _selectedFrameIndex >= 0 && _selectedFrameIndex < _frames.Count ? _selectedFrameIndex + 1 : 1;

    private bool CanRunStabilization() =>
        HasActiveSheet
        && _frames.Count > 0
        && _selectedFrameIndex >= 0
        && ReferenceFrameNumber() <= _frames.Count
        && _stabilizationAnchor is not null
        && !_stabilizationRunning
        && !_framePersistenceRunning;

    private bool CanApplyStabilization() =>
        CanRunStabilization() && _stabilizationPreview is not null;

    private void NormalizeStabilizationInputs()
    {
        _stabilizationSearchPadding = Math.Clamp(_stabilizationSearchPadding, 0, 512);
        _stabilizationMinScore = Math.Clamp(_stabilizationMinScore, -1d, 1d);
    }

    private static int StabilizationLowConfidenceCount(SpriteSheetStabilizationView stabilization) =>
        stabilization.Matches.Count(match => match.LowConfidence);

    private static int StabilizationClampedCount(SpriteSheetStabilizationView stabilization) =>
        stabilization.Matches.Count(match => match.Clamped);

    private static int StabilizationAppliedCount(SpriteSheetStabilizationView stabilization) =>
        stabilization.Applied ? stabilization.Matches.Count : 0;

