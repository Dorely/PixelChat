    protected override void OnInitialized()
    {
        _generationRuntimeSnapshot = ImageRuntime.GetSnapshot();
        ImageRuntime.StateChanged += OnImageGenerationRuntimeStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        var projectChanged = _loadedProjectId != Workbench.Project.Id;
        if (_loadedProjectId != Workbench.Project.Id)
        {
            _loadedProjectId = Workbench.Project.Id;
            _appliedSourceAssetId = null;
            _frameSet = null;
            _regions = [];
            _selectedRegionIds.Clear();
            _selectedIndex = -1;
            _builtSheetAssetId = null;
            _builtSheetManifest = null;
            ResetEditModal();
            await LoadActiveFrameSetAsync();
            await LoadPendingEditSessionAsync();
        }

        if (SourceAssetId is Guid sourceId && (projectChanged || _appliedSourceAssetId != sourceId))
        {
            await SelectSourceAssetAsync(sourceId, clearMismatchedFrameSet: true);
            _status = $"Loaded {SelectedSourceArtAsset()?.Label ?? "source image"}.";
        }

        if (RefreshEditCandidatesFromWorkbench())
            await PersistEditSessionAsync();
        RefreshEditGeneratingState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Sprites/SpriteSheetWorkspace.razor.js");
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        await RenderCanvasAsync();
        await RenderEditModalCanvasAsync();
    }

    private async Task LoadActiveFrameSetAsync()
    {
        try
        {
            var set = await FrameSets.GetActiveFrameSetAsync(Workbench.Project.Id);
            ApplyFrameSet(set);
            if (set?.SourceAssetId is Guid sourceId)
            {
                await SelectSourceAssetAsync(sourceId, clearMismatchedFrameSet: false);
            }
            await PublishSpritesStateAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void ApplyFrameSet(FrameSetView? set)
    {
        _frameSet = set;
        _rev++;
        if (set is null)
        {
            _selectedIndex = -1;
            return;
        }

        _cellWidth = set.DefaultCellWidth > 0 ? set.DefaultCellWidth : _cellWidth;
        _cellHeight = set.DefaultCellHeight > 0 ? set.DefaultCellHeight : _cellHeight;
        _builtSheetAssetId = set.LatestBuiltSheetAssetId ?? _builtSheetAssetId;
        _builtSheetManifest = set.LatestBuiltSheetManifest ?? _builtSheetManifest;
        if (set.Frames.Count == 0)
            _selectedIndex = -1;
        else if (_selectedIndex < 0 || _selectedIndex >= set.Frames.Count)
            _selectedIndex = 0;
        if (_anchorReferenceFrameId is null || !set.Frames.Any(frame => frame.Id == _anchorReferenceFrameId))
            _anchorReferenceFrameId = SelectedFrame()?.Id ?? set.Frames.FirstOrDefault()?.Id;
    }

    private async Task ImportSourceAsync(InputFileChangeEventArgs args)
    {
        if (args.File is null)
            return;

        await RunAsync("Importing image...", async () =>
        {
            await using var stream = args.File.OpenReadStream(50 * 1024 * 1024);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            var contentType = string.IsNullOrWhiteSpace(args.File.ContentType) ? "image/png" : args.File.ContentType;
            var asset = await Workflow.ImportAssetAsync(Workbench.Project.Id, new ImportAssetRequest(
                args.File.Name,
                contentType,
                memory.ToArray(),
                Path.GetFileNameWithoutExtension(args.File.Name)));
            await SelectSourceAssetAsync(asset.Id, clearMismatchedFrameSet: true);
            _frameSet = null;
            _status = $"Imported {asset.Label}. Draw or detect regions to create frames.";
            await OnChanged.InvokeAsync();
            await PublishSpritesStateAsync();
        });
    }

    private async Task SelectSourceAssetAsync(Guid sourceId, bool clearMismatchedFrameSet)
    {
        _sourceAssetIdText = sourceId.ToString();
        _appliedSourceAssetId = sourceId;
        _regions = [];
        _selectedRegionIds.Clear();
        _regions = (await FrameSets.ListSourceRegionsAsync(Workbench.Project.Id, sourceId)).ToList();
        if (clearMismatchedFrameSet && _frameSet?.SourceAssetId != sourceId)
        {
            StopAnimation();
            _frameSet = null;
            _selectedIndex = -1;
            _builtSheetAssetId = null;
            _builtSheetManifest = null;
        }
        _mode = SpriteMode.Source;
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DetectRegionsAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceId)
            return;

        await RunAsync("Detecting source regions...", async () =>
        {
            _regions = (await FrameSets.DetectSourceRegionsAsync(Workbench.Project.Id, new DetectSourceRegionsRequest(sourceId))).ToList();
            _selectedRegionIds.Clear();
            _status = $"Detected {_regions.Count} region(s).";
            await PublishSpritesStateAsync();
        });
    }

    private async Task CreateFrameSetFromRegionsAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceId || _regions.Count == 0)
            return;

        var regionIds = _regions
            .OrderBy(region => region.Order)
            .Select(region => region.Id)
            .ToList();

        await RunAsync("Creating frame set...", async () =>
        {
            var set = await FrameSets.CreateFrameSetFromRegionsAsync(Workbench.Project.Id, new CreateFrameSetFromRegionsRequest(sourceId, regionIds));
            ApplyFrameSet(set);
            _mode = SpriteMode.Frames;
            _status = $"Created {set.FrameCount} editable frame workspace(s).";
            await OnChanged.InvokeAsync();
            await PublishSpritesStateAsync();
        });
    }

    private async Task NormalizeCellSizeAsync(bool auto)
    {
        if (_frameSet is not { } set)
            return;

        await RunAsync("Normalizing cells...", async () =>
        {
            var updated = await FrameSets.SetCommonCellSizeAsync(Workbench.Project.Id, new SetCommonCellSizeRequest(set.Id, auto ? 0 : _cellWidth, auto ? 0 : _cellHeight));
            ApplyFrameSet(updated);
            _status = $"Cells set to {updated.DefaultCellWidth} x {updated.DefaultCellHeight}.";
            await PublishSpritesStateAsync();
        });
    }

    private bool CanRunAnchorAlignment() =>
        !_busy
        && _frameSet is not null
        && AnchorReferenceFrame() is not null
        && _anchorRect is not null;

    private async Task AlignByAnchorRectAsync(bool apply)
    {
        if (_frameSet is not { } set || AnchorReferenceFrame() is not { } reference || _anchorRect is not { } rect)
            return;

        await RunAsync(apply ? "Applying anchor alignment..." : "Previewing anchor alignment...", async () =>
        {
            var result = await FrameSets.AlignFramesByAnchorRectAsync(Workbench.Project.Id, new AlignFramesByAnchorRectRequest(
                set.Id,
                reference.Id,
                rect,
                _anchorSearchPadding,
                _anchorMinScore,
                _anchorAxisX,
                _anchorAxisY,
                apply));
            _anchorDiagnostics = result;
            ApplyFrameSet(result.FrameSet);
            _status = apply
                ? $"Applied anchor alignment to {result.Matches.Count} frame(s)."
                : $"Previewed anchor alignment for {result.Matches.Count} frame(s).";
            await PublishSpritesStateAsync();
            await RenderCanvasAsync();
        });
    }

    private async Task ClearAnchorRectAsync()
    {
        _anchorRect = null;
        _anchorDiagnostics = null;
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task SetAnchorReferenceFrameAsync(ChangeEventArgs args)
    {
        if (_frameSet is not { } set || !Guid.TryParse(args.Value?.ToString(), out var frameId))
            return;

        var index = set.Frames.ToList().FindIndex(frame => frame.Id == frameId);
        if (index < 0)
            return;

        _selectedIndex = index;
        _anchorReferenceFrameId = frameId;
        _anchorRect = null;
        _anchorDiagnostics = null;
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task ReorderFrameAsync(Guid frameId, int targetIndex)
    {
        if (_frameSet is not { } set)
            return;

        await RunAsync("Reordering frame...", async () =>
        {
            var updated = await FrameSets.ReorderFrameAsync(Workbench.Project.Id, set.Id, frameId, targetIndex);
            ApplyFrameSet(updated);
            await PublishSpritesStateAsync();
        });
