        }
    }

    private void LoadSheet(SpriteSheetDefinitionView sheet, ArtAssetView working)
    {
        var changedSheet = _loadedSpriteSheetId != sheet.Id;
        _loadedSpriteSheetId = sheet.Id;
        _loadedSpriteSheetUpdatedAt = sheet.UpdatedAt;
        _workingImageDataUrl = working.FullImageUrl;
        _rows = Math.Max(1, sheet.Rows);
        _columns = Math.Max(1, sheet.Columns);
        _cellWidth = Math.Max(1, sheet.CellWidth);
        _cellHeight = Math.Max(1, sheet.CellHeight);
        _padding = Math.Max(0, sheet.Padding);
        _gutter = Math.Max(0, sheet.Gutter);
        _fps = Math.Clamp(sheet.Fps, 1, 60);
        _loop = sheet.Loop;
        _horizontalAnchor = NormalizeHorizontalAnchor(sheet.HorizontalAnchor);
        _verticalAnchor = NormalizeVerticalAnchor(sheet.VerticalAnchor);
        if (sheet.Stabilization is { } stabilization)
        {
            _stabilizationAnchor = stabilization.AnchorRect;
            _stabilizationReferenceFrameNumber = stabilization.ReferenceFrameNumber;
            _stabilizationSearchPadding = Math.Clamp(stabilization.SearchPadding, 0, 512);
            _stabilizationMinScore = Math.Clamp(stabilization.MinScore, -1d, 1d);
        }
        else if (changedSheet)
        {
            _stabilizationAnchor = null;
            _stabilizationReferenceFrameNumber = null;
            _stabilizationPreview = null;
            _stabilizationSearchPadding = 24;
            _stabilizationMinScore = 0.68d;
        }
        _frames.Clear();
        _frames.AddRange(sheet.Frames
            .OrderBy(frame => frame.Index)
            .Select(frame => new SpriteSheetEditorFrame
            {
                Id = frame.Id,
                Index = frame.Index,
                Label = frame.Label,
                X = frame.SourceRect.X,
                Y = frame.SourceRect.Y,
                Width = frame.SourceRect.Width,
                Height = frame.SourceRect.Height,
                ShapePaths = frame.ShapePaths.ToList(),
                PreviewImageUrl = frame.PreviewImageUrl,
                SourceImageAssetId = frame.SourceImageAssetId,
                SourceImageRect = frame.SourceImageRect,
                WorkingState = frame.WorkingState,
                WorkingWidth = frame.WorkingWidth,
                WorkingHeight = frame.WorkingHeight,
                WorkingMargin = frame.WorkingMargin,
                WorkingUpdatedAt = frame.WorkingUpdatedAt,
            }));
        ReindexFrames();
        if (_frames.Count == 0)
            _selectedFrameIndex = -1;
        else if (_selectedFrameIndex < 0 || _selectedFrameIndex >= _frames.Count)
            _selectedFrameIndex = 0;
        _error = null;
        if (SelectedFrame() is not { } selected || !HasWorkingImage(selected))
        {
            _loadedFrameWorkIndex = null;
            _loadedFrameWorkUpdatedAt = null;
            _frameWorkImageDataUrl = string.Empty;
            _frameWorkImageWidth = 0;
            _frameWorkImageHeight = 0;
            ResetFrameEraseMode();
        }
    }

