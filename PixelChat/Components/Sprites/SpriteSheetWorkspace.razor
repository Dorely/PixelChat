                    _editBatchId,
                    EditCandidateOutputs().Where(candidate => candidate.AssetId is Guid).Select(candidate => candidate.AssetId!.Value).ToList(),
                    _selectedEditCandidateId,
                    _editGenerating,
                    _editCount,
                    EditCandidateSetState(),
                    _selectedEditOutputIndex,
                    _editPreviewOverlayActive,
                    _editSessionId is null ? "" : "pending",
                    CanAcceptEditCandidate(),
                    EditCandidateOutputs()
                        .Select(candidate => new WorkspaceSpriteEditCandidateSummary(
                            candidate.OutputIndex,
                            candidate.AssetId,
                            candidate.StatusLabel,
                            candidate.HasPartial,
                            candidate.IsFinal,
                            candidate.Error))
                        .ToList())
                : null,
            Anchor: new WorkspaceSpriteAnchorSummary(
                _anchorReferenceFrameId,
                _anchorRect,
                _anchorSearchPadding,
                _anchorMinScore,
                _anchorAxisX,
                _anchorAxisY,
                _anchorDiagnostics?.Matches.Count ?? 0,
                _anchorDiagnostics?.Matches.Count(match => match.LowConfidence) ?? 0,
