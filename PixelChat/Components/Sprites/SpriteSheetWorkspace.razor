            SelectedFrames: SelectedFrame() is { } frame ? [new WorkspaceFrameSummary(frame.Id, frame.Index, frame.Name, frame.SourceX, frame.SourceY, frame.SourceWidth, frame.SourceHeight, frame.LogicalWidth, frame.LogicalHeight, frame.ContentOffsetX, frame.ContentOffsetY, frame.DurationMs, frame.WorkingState, frame.HideFromOnionSkin, frame.HasMask)] : [],
            SelectedMaskId: SelectedFrame()?.MaskId,
            BuiltSheet: BuiltSheetAssetId() is Guid built ? new WorkspaceBuiltSheetSummary(built, BuiltSheetManifest() ?? string.Empty) : null,
            Mode: ModeLabel(_mode),
            EditModal: _editModalOpen
                ? new WorkspaceSpriteEditModalSummary(
                    _editTargetKind == SpriteEditTargetKind.Frame ? "frame" : "source",
