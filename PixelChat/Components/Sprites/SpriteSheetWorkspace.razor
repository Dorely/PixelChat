@namespace PixelChat.Components.Sprites
@using PixelChat.Art
@using PixelChat.Models
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IJSRuntime JS

<div class="sprite-workspace">
    <div class="panel-head">
        <div>
            <h1>Sprites</h1>
            <span>@HeaderSummary()</span>
        </div>
        <div class="sprite-head-actions">
            <InputFile OnChange="ImportSourceAsync" accept="image/png,image/jpeg" />
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet)" @onclick="AutoDetectAsync">Auto Detect</button>
            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!HasActiveSheet)" @onclick="ResetToOriginalAsync">Reset</button>
            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(CurrentWorkingAsset() is null)" @onclick="ExportWorkingAsync">Export...</button>
        </div>
    </div>

    @if (!HasActiveSheet)
    {
        <div class="empty-state">Select Sprite Sheet on an asset card or import an image to start.</div>
    }
    else
    {
        <div class="sprite-editor-grid">
            <section class="sprite-editor-main">
                <div class="sprite-canvas-panel">
                    <div class="section-title">Source Boxes</div>
                    <canvas class="sprite-source-canvas" @ref="_sourceCanvas"></canvas>
                </div>

                <div class="sprite-tool-strip">
                    <div class="tool-button-row">
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Select)" @onclick="() => SetToolAsync(SpriteEditTool.Select)">Select</button>
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Draw)" @onclick="() => SetToolAsync(SpriteEditTool.Draw)">Draw</button>
                        <button type="button" class="btn btn-sm btn-primary" disabled="@(_frames.Count == 0)" @onclick="NormalizeSheetAsync">Normalize Sheet</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(_selectedFrameIndex < 0 || _frames.Count == 0)" @onclick="DeleteSelectedFrameAsync">Delete</button>
                    </div>

                    <div class="selected-frame-readout">
                        @if (SelectedFrame() is { } selected)
                        {
                            <span>@selected.Label</span>
                            <span>X @selected.X</span>
                            <span>Y @selected.Y</span>
                            <span>W @selected.Width</span>
                            <span>H @selected.Height</span>
                        }
                        else
                        {
                            <span>No frame selected</span>
                        }
                    </div>
                </div>
            </section>

            <aside class="sprite-side-panel">
                <div class="sprite-canvas-panel sprite-animation-panel">
                    <div class="section-title">Animation</div>
                    <canvas class="sprite-animation-canvas" @ref="_animationCanvas"></canvas>
                </div>

                <div class="sprite-settings-panel">
                    <div class="section-title">Sheet Settings</div>
                    <div class="sprite-grid-controls">
                        <label>
                            <span>Rows</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="32" @bind="_rows" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Columns</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="64" @bind="_columns" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Cell W</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellWidth" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Cell H</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellHeight" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Padding</span>
                            <input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_padding" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Gutter</span>
                            <input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_gutter" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>FPS</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="60" @bind="_fps" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label class="sprite-loop-toggle">
                            <input type="checkbox" @bind="_loop" @bind:after="OnLayoutFieldChangedAsync" />
                            <span>Loop</span>
                        </label>
                    </div>
                </div>

                <div class="frame-list-head">
                    <span>@_frames.Count frame(s)</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_frames.Count == 0)" @onclick="AttachAllFramesAsync">Attach all</button>
                </div>

                <div class="sprite-frame-list">
                    @foreach (var frame in _frames)
                    {
                        <div class="sprite-frame-row @(frame.Index == _selectedFrameIndex ? "is-selected" : "")">
                            <button type="button" class="frame-thumb" @onclick="() => SelectFrameAsync(frame.Index)">
                                @if (!string.IsNullOrWhiteSpace(frame.PreviewDataUrl))
                                {
                                    <img src="@frame.PreviewDataUrl" alt="@frame.Label" />
                                }
                                else
                                {
                                    <span>@(frame.Index + 1)</span>
                                }
                            </button>
                            <input class="form-control form-control-sm" @bind="frame.Label" @bind:after="OnFrameLabelChangedAsync" />
                            <div class="frame-row-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Move up" disabled="@(frame.Index == 0)" @onclick="() => MoveFrameAsync(frame.Index, -1)">Up</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Move down" disabled="@(frame.Index >= _frames.Count - 1)" @onclick="() => MoveFrameAsync(frame.Index, 1)">Down</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Attach frame" disabled="@(frame.Id is null)" @onclick="() => AttachFrameAsync(frame)">Attach</button>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_status))
                {
                    <div class="sprite-status">@_status</div>
                }
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="sprite-error">@_error</div>
                }
            </aside>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public WorkbenchView Workbench { get; set; } = null!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [Parameter]
    public EventCallback<ArtAssetView> OnExportAsset { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<SpriteSheetWorkspace>? _dotNetRef;
    private ElementReference _sourceCanvas;
    private ElementReference _animationCanvas;
    private CancellationTokenSource? _autosaveCts;

    private Guid? _loadedSpriteSheetId;
    private DateTime? _loadedSpriteSheetUpdatedAt;
    private string _workingImageDataUrl = string.Empty;
    private int _rows = 1;
    private int _columns = 1;
    private int _cellWidth = 128;
    private int _cellHeight = 128;
    private int _padding = 8;
    private int _gutter = 16;
    private int _fps = 8;
    private bool _loop = true;
    private int _selectedFrameIndex = -1;
    private SpriteEditTool _tool = SpriteEditTool.Select;
    private string _status = string.Empty;
    private string? _error;
    private readonly List<SpriteSheetEditorFrame> _frames = [];

    private bool HasActiveSheet => Workbench.ActiveSpriteSheet is not null && CurrentWorkingAsset() is not null;

    protected override void OnParametersSet()
    {
        var active = Workbench.ActiveSpriteSheet;
        if (active is null || CurrentWorkingAsset(active) is not { } working)
        {
            _loadedSpriteSheetId = null;
            _loadedSpriteSheetUpdatedAt = null;
            _workingImageDataUrl = string.Empty;
            _frames.Clear();
            _selectedFrameIndex = -1;
            return;
        }

        if (_loadedSpriteSheetId == active.Id && _loadedSpriteSheetUpdatedAt == active.UpdatedAt && _workingImageDataUrl == working.PreviewDataUrl)
            return;

        LoadSheet(active, working);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Sprites/SpriteSheetWorkspace.razor.js");
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        await DrawAsync();
    }

    private async Task ImportSourceAsync(InputFileChangeEventArgs args)
    {
        if (args.File is null)
            return;

        _error = null;
        _status = "Importing sprite sheet source...";
        try
        {
            await using var stream = args.File.OpenReadStream(50 * 1024 * 1024);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            var asset = await Workflow.ImportAssetAsync(Workbench.Project.Id, new ImportAssetRequest(
                args.File.Name,
                args.File.ContentType,
                memory.ToArray(),
                Path.GetFileNameWithoutExtension(args.File.Name)));
            await Workflow.StartSpriteSheetEditAsync(Workbench.Project.Id, asset.Id);
            _status = $"Imported {asset.Label}.";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task AutoDetectAsync()
    {
        if (_module is null || CurrentWorkingAsset() is not { } working)
            return;

        _error = null;
        _status = "Detecting sprite frames...";
        try
        {
            var detection = await _module.InvokeAsync<BrowserSpriteDetectionResult>(
                "detectSpriteSheetFrames",
                working.PreviewDataUrl,
                null,
                "rows",
                "auto");
            if (detection.Frames.Count == 0)
                throw new InvalidOperationException("No foreground frames were detected.");

            _rows = Math.Max(1, detection.Rows);
            _columns = Math.Max(1, detection.Columns);
            _frames.Clear();
            _frames.AddRange(detection.Frames
                .OrderBy(frame => frame.Index)
                .Select(frame => new SpriteSheetEditorFrame
                {
                    Index = frame.Index,
                    Label = $"Frame {frame.Index + 1}",
                    X = frame.SourceRect.X,
                    Y = frame.SourceRect.Y,
                    Width = frame.SourceRect.Width,
                    Height = frame.SourceRect.Height,
                }));
            FitCellsToFrames();
            _selectedFrameIndex = _frames.Count > 0 ? 0 : -1;
            await AutosaveLayoutNowAsync();
            _status = $"Detected {_frames.Count} frame(s).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task ResetToOriginalAsync()
    {
        var active = Workbench.ActiveSpriteSheet;
        if (active is null)
            return;

        _error = null;
        _status = "Resetting sprite sheet...";
        try
        {
            var reset = await Workflow.ResetSpriteSheetToOriginalAsync(Workbench.Project.Id, active.Id);
            _loadedSpriteSheetId = null;
            _loadedSpriteSheetUpdatedAt = null;
            _frames.Clear();
            _selectedFrameIndex = -1;
            _status = $"{reset.Label} reset.";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task ExportWorkingAsync()
    {
        if (CurrentWorkingAsset() is { } asset)
            await OnExportAsset.InvokeAsync(asset);
    }

    private async Task NormalizeSheetAsync()
    {
        if (_module is null || Workbench.ActiveSpriteSheet is not { } active || string.IsNullOrWhiteSpace(_workingImageDataUrl) || _frames.Count == 0)
            return;

        _error = null;
        _status = "Normalizing sprite sheet...";
        try
        {
            NormalizeLayout();
            var output = await _module.InvokeAsync<SpriteSheetRenderOutput>(
                "renderSpriteSheetNormalize",
                _workingImageDataUrl,
                BuildLayoutPayload());
            if (string.IsNullOrWhiteSpace(output.DataUrl))
                throw new InvalidOperationException("Sprite sheet render did not produce a PNG.");

            var saved = await Workflow.NormalizeSpriteSheetAsync(Workbench.Project.Id, new NormalizeSpriteSheetRequest(
                active.Id,
                output.DataUrl,
                _rows,
                _columns,
                _cellWidth,
                _cellHeight,
                _padding,
                _gutter,
                _fps,
                _loop,
                output.Frames));
            _workingImageDataUrl = output.DataUrl;
            LoadSheet(saved, new ArtAssetView(
                saved.WorkingAssetId ?? Guid.Empty,
                saved.Label,
                "sprite-sheet.png",
                ArtAssetKind.SpriteSheet,
                "image/png",
                output.DataUrl,
                output.Width,
                output.Height,
                saved.SourceAssetId,
                null,
                null,
                null,
                false,
                string.Empty,
                string.Empty,
                DateTime.UtcNow));
            _status = "Sprite sheet normalized.";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task SetToolAsync(SpriteEditTool tool)
    {
        _tool = tool;
        await DrawAsync();
    }

    private async Task SelectFrameAsync(int index)
    {
        _selectedFrameIndex = index;
        await DrawAsync();
    }

    private async Task DeleteSelectedFrameAsync()
    {
        var frame = SelectedFrame();
        if (frame is null)
            return;

        _frames.Remove(frame);
        ReindexFrames();
        _selectedFrameIndex = _frames.Count == 0 ? -1 : Math.Clamp(frame.Index, 0, _frames.Count - 1);
        await AutosaveLayoutNowAsync();
    }

    private async Task MoveFrameAsync(int index, int delta)
    {
        var target = index + delta;
        if (index < 0 || index >= _frames.Count || target < 0 || target >= _frames.Count)
            return;

        (_frames[index], _frames[target]) = (_frames[target], _frames[index]);
        ReindexFrames();
        _selectedFrameIndex = target;
        await AutosaveLayoutNowAsync();
    }

    private async Task AttachFrameAsync(SpriteSheetEditorFrame frame)
    {
        if (Workbench.ActiveSpriteSheet is null || frame.Id is not Guid frameId)
            return;

        await Workflow.AttachSpriteSheetFramesAsync(Workbench.Project.Id, Workbench.ActiveSpriteSheet.Id, [frameId]);
        await OnChanged.InvokeAsync();
    }

    private async Task AttachAllFramesAsync()
    {
        if (Workbench.ActiveSpriteSheet is null || _frames.Count == 0)
            return;

        await Workflow.AttachSpriteSheetFramesAsync(Workbench.Project.Id, Workbench.ActiveSpriteSheet.Id);
        await OnChanged.InvokeAsync();
    }

    private async Task OnLayoutFieldChangedAsync()
    {
        NormalizeLayout();
        if (_frames.Count > 0 && _rows * _columns < _frames.Count)
            _columns = Math.Max(1, (int)Math.Ceiling(_frames.Count / (double)_rows));
        await DrawAsync();
        ScheduleAutosave();
    }

    private async Task OnFrameLabelChangedAsync()
    {
        await DrawAsync();
        ScheduleAutosave();
    }

    [JSInvokable]
    public async Task OnSpriteBoxesChanged(SpriteCanvasChange change)
    {
        _frames.Clear();
        _frames.AddRange(change.Frames
            .OrderBy(frame => frame.Index)
            .Select(frame => new SpriteSheetEditorFrame
            {
                Index = frame.Index,
                Label = string.IsNullOrWhiteSpace(frame.Label) ? $"Frame {frame.Index + 1}" : frame.Label,
                X = Math.Max(0, frame.SourceRect.X),
                Y = Math.Max(0, frame.SourceRect.Y),
                Width = Math.Max(1, frame.SourceRect.Width),
                Height = Math.Max(1, frame.SourceRect.Height),
            }));
        ReindexFrames();
        _selectedFrameIndex = change.SelectedIndex;
        FitCellsToFrames(onlyWhenTooSmall: true);
        await AutosaveLayoutNowAsync();
    }

    [JSInvokable]
    public async Task OnSpriteBoxSelected(int selectedIndex)
    {
        _selectedFrameIndex = selectedIndex;
        await InvokeAsync(StateHasChanged);
    }

    private void ScheduleAutosave()
    {
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
        _autosaveCts = new CancellationTokenSource();
        var token = _autosaveCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(600, token);
                await InvokeAsync(AutosaveLayoutNowAsync);
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

    private async Task AutosaveLayoutNowAsync()
    {
        if (_module is null || Workbench.ActiveSpriteSheet is not { } active || string.IsNullOrWhiteSpace(_workingImageDataUrl))
            return;

        _autosaveCts?.Cancel();
        NormalizeLayout();
        try
        {
            var output = await _module.InvokeAsync<SpriteSheetFramePreviewOutput>(
                "renderSpriteFramePreviews",
                _workingImageDataUrl,
                BuildLayoutPayload());

            var saved = await Workflow.AutosaveSpriteSheetLayoutAsync(Workbench.Project.Id, new AutosaveSpriteSheetLayoutRequest(
                active.Id,
                _rows,
                _columns,
                _cellWidth,
                _cellHeight,
                _padding,
                _gutter,
                _fps,
                _loop,
                output.Frames));
            LoadSheet(saved, new ArtAssetView(
                saved.WorkingAssetId ?? Guid.Empty,
                saved.Label,
                "sprite-sheet.png",
                ArtAssetKind.SpriteSheet,
                "image/png",
                _workingImageDataUrl,
                null,
                null,
                saved.SourceAssetId,
                null,
                null,
                null,
                false,
                string.Empty,
                string.Empty,
                DateTime.UtcNow));
            _status = "Layout autosaved.";
            _error = null;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private void LoadSheet(SpriteSheetDefinitionView sheet, ArtAssetView working)
    {
        _loadedSpriteSheetId = sheet.Id;
        _loadedSpriteSheetUpdatedAt = sheet.UpdatedAt;
        _workingImageDataUrl = working.PreviewDataUrl;
        _rows = Math.Max(1, sheet.Rows);
        _columns = Math.Max(1, sheet.Columns);
        _cellWidth = Math.Max(1, sheet.CellWidth);
        _cellHeight = Math.Max(1, sheet.CellHeight);
        _padding = Math.Max(0, sheet.Padding);
        _gutter = Math.Max(0, sheet.Gutter);
        _fps = Math.Clamp(sheet.Fps, 1, 60);
        _loop = sheet.Loop;
        _frames.Clear();
        _frames.AddRange(sheet.Frames
            .OrderBy(frame => frame.Index)
            .Select(frame => new SpriteSheetEditorFrame
            {
                Id = frame.Id,
                Index = frame.Index,
                Label = frame.Label,
                X = frame.SourceRect.X,
                Y = frame.SourceRect.Y,
                Width = frame.SourceRect.Width,
                Height = frame.SourceRect.Height,
                PreviewDataUrl = frame.PreviewDataUrl,
            }));
        ReindexFrames();
        if (_frames.Count == 0)
            _selectedFrameIndex = -1;
        else if (_selectedFrameIndex < 0 || _selectedFrameIndex >= _frames.Count)
            _selectedFrameIndex = 0;
        _error = null;
    }

    private async Task DrawAsync()
    {
        if (_module is null || _dotNetRef is null || !HasActiveSheet || string.IsNullOrWhiteSpace(_workingImageDataUrl))
            return;

        try
        {
            await _module.InvokeVoidAsync(
                "drawSpriteBoxEditor",
                _sourceCanvas,
                _animationCanvas,
                _dotNetRef,
                _workingImageDataUrl,
                BuildLayoutPayload(),
                _selectedFrameIndex,
                _tool.ToString().ToLowerInvariant());
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private object BuildLayoutPayload()
    {
        NormalizeLayout();
        return new
        {
            Rows = _rows,
            Columns = _columns,
            FrameCount = _frames.Count,
            CellWidth = _cellWidth,
            CellHeight = _cellHeight,
            Padding = _padding,
            Gutter = _gutter,
            Fps = _fps,
            Loop = _loop,
            Frames = _frames
                .OrderBy(frame => frame.Index)
                .Select(frame => new
                {
                    frame.Index,
                    frame.Label,
                    SourceRect = new { X = frame.X, Y = frame.Y, Width = frame.Width, Height = frame.Height },
                })
                .ToList(),
        };
    }

    private void NormalizeLayout()
    {
        _rows = Math.Clamp(_rows, 1, 32);
        _columns = Math.Clamp(_columns, 1, 64);
        _cellWidth = Math.Clamp(_cellWidth, 1, 8192);
        _cellHeight = Math.Clamp(_cellHeight, 1, 8192);
        _padding = Math.Clamp(_padding, 0, 2048);
        _gutter = Math.Clamp(_gutter, 0, 2048);
        _fps = Math.Clamp(_fps, 1, 60);
    }

    private void FitCellsToFrames(bool onlyWhenTooSmall = false)
    {
        if (_frames.Count == 0)
            return;

        var width = _frames.Max(frame => Math.Max(1, frame.Width)) + (_padding * 2);
        var height = _frames.Max(frame => Math.Max(1, frame.Height)) + (_padding * 2);
        if (!onlyWhenTooSmall || _cellWidth < width)
            _cellWidth = width;
        if (!onlyWhenTooSmall || _cellHeight < height)
            _cellHeight = height;
    }

    private void ReindexFrames()
    {
        for (var index = 0; index < _frames.Count; index++)
        {
            _frames[index].Index = index;
            if (string.IsNullOrWhiteSpace(_frames[index].Label))
                _frames[index].Label = $"Frame {index + 1}";
        }

        if (_frames.Count > 0 && _rows * _columns < _frames.Count)
            _columns = Math.Max(1, (int)Math.Ceiling(_frames.Count / (double)_rows));
    }

    private SpriteSheetEditorFrame? SelectedFrame() =>
        _selectedFrameIndex >= 0 && _selectedFrameIndex < _frames.Count ? _frames[_selectedFrameIndex] : null;

    private ArtAssetView? CurrentWorkingAsset() =>
        Workbench.ActiveSpriteSheet is { } active ? CurrentWorkingAsset(active) : null;

    private ArtAssetView? CurrentWorkingAsset(SpriteSheetDefinitionView active) =>
        active.WorkingAssetId is Guid assetId
            ? Workbench.Assets.FirstOrDefault(asset => asset.Id == assetId)
            : null;

    private string HeaderSummary()
    {
        if (Workbench.ActiveSpriteSheet is null)
            return "No sprite sheet selected";

        var source = Workbench.Assets.FirstOrDefault(asset => asset.Id == Workbench.ActiveSpriteSheet.SourceAssetId);
        var outputSize = $"{_columns * _cellWidth + Math.Max(0, _columns - 1) * _gutter} x {_rows * _cellHeight + Math.Max(0, _rows - 1) * _gutter}";
        return $"{source?.Label ?? Workbench.ActiveSpriteSheet.Label} / {_frames.Count} frame(s) / {outputSize}";
    }

    private string ToolButtonClass(SpriteEditTool tool) =>
        _tool == tool ? "btn btn-sm btn-primary" : "btn btn-sm btn-outline-secondary";

    public async ValueTask DisposeAsync()
    {
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposeSpriteBoxEditor", _sourceCanvas, _animationCanvas);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }

    private enum SpriteEditTool
    {
        Select,
        Draw
    }

    private sealed class SpriteSheetEditorFrame
    {
        public Guid? Id { get; set; }
        public int Index { get; set; }
        public string Label { get; set; } = string.Empty;
        public int X { get; set; }
        public int Y { get; set; }
        public int Width { get; set; }
        public int Height { get; set; }
        public string PreviewDataUrl { get; set; } = string.Empty;
    }

    private sealed class BrowserSpriteDetectionResult
    {
        public int Rows { get; set; }
        public int Columns { get; set; }
        public List<BrowserSpriteFrameDetection> Frames { get; set; } = [];
    }

    private sealed class BrowserSpriteFrameDetection
    {
        public int Index { get; set; }
        public SpriteSheetRect SourceRect { get; set; } = new(0, 0, 1, 1);
    }

    private sealed class SpriteSheetRenderOutput
    {
        public string DataUrl { get; set; } = string.Empty;
        public int Width { get; set; }
        public int Height { get; set; }
        public List<SpriteSheetFrameView> Frames { get; set; } = [];
    }

    private sealed class SpriteSheetFramePreviewOutput
    {
        public List<SpriteSheetFrameView> Frames { get; set; } = [];
    }

    public sealed class SpriteCanvasChange
    {
        public int SelectedIndex { get; set; }
        public List<SpriteCanvasFrame> Frames { get; set; } = [];
    }

    public sealed class SpriteCanvasFrame
    {
        public int Index { get; set; }
        public string Label { get; set; } = string.Empty;
        public SpriteSheetRect SourceRect { get; set; } = new(0, 0, 1, 1);
    }
}
