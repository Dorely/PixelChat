                _cellWidth,
                _cellHeight,
                _padding,
                _gutter,
                _fps,
                _loop,
                _horizontalAnchor,
                _verticalAnchor,
                BuildFrameUpdates()));
            LoadSheet(saved, new ArtAssetView(
                saved.WorkingAssetId ?? Guid.Empty,
                saved.Label,
                "sprite-sheet.png",
                ArtAssetKind.SpriteSheet,
                "image/png",
                _workingImageDataUrl,
                _workingImageDataUrl,
                null,
                null,
                saved.SourceAssetId,
                null,
                null,
                null,
                null,
                false,
                string.Empty,
                string.Empty,
                DateTime.UtcNow));
            _status = "Layout autosaved.";
