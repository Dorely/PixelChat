    private async Task DeleteSelectedRegionsAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceId || _selectedRegionIds.Count == 0)
            return;
        _regions = _regions.Where(region => !_selectedRegionIds.Contains(region.Id)).ToList();
        _selectedRegionIds.Clear();
        await SaveRegionsAsync(sourceId);
    }

    private async Task RenameRegionAsync(Guid id, string? name)
    {
        if (SelectedSourceAssetId() is not Guid sourceId)
            return;
        _regions = _regions.Select(region => region.Id == id ? region with { Name = string.IsNullOrWhiteSpace(name) ? region.Name : name.Trim() } : region).ToList();
        await SaveRegionsAsync(sourceId);
    }

    private async Task UpdateSelectedRegionNumberAsync(Guid id, string field, ChangeEventArgs args)
    {
        if (SelectedSourceAssetId() is not Guid sourceId || !int.TryParse(args.Value?.ToString(), out var value))
            return;
        _regions = _regions.Select(region => region.Id == id
            ? field switch
            {
                "x" => region with { X = value },
                "y" => region with { Y = value },
                "w" => region with { Width = Math.Max(1, value) },
                "h" => region with { Height = Math.Max(1, value) },
                _ => region
            }
            : region).ToList();
        await SaveRegionsAsync(sourceId);
    }

    private async Task SaveRegionsAsync(Guid sourceId)
    {
        _regions = (await FrameSets.SaveSourceRegionsAsync(Workbench.Project.Id, new SaveSourceRegionsRequest(
            sourceId,
            _regions
                .OrderBy(region => region.Order)
                .Select((region, index) => new SourceRegionEditRequest(
                    region.Id,
                    region.Name,
                    region.X,
                    region.Y,
                    region.Width,
                    region.Height,
                    region.ShapePaths,
                    region.RegionType,
                    index))
                .ToList()))).ToList();
        _rev++;
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task ClearFrameMaskAsync(Guid frameId)
    {
        await FrameSets.ClearFrameMaskAsync(Workbench.Project.Id, frameId);
        if (_frameSet is { } set)
            ApplyFrameSet(await FrameSets.GetFrameSetAsync(Workbench.Project.Id, set.Id));
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task ExportBuiltSheetAsync()
    {
        if (BuiltSheetAssetId() is not Guid assetId)
            return;
        await OnChanged.InvokeAsync();
        var asset = Workbench.Assets.FirstOrDefault(a => a.Id == assetId);
        if (asset is not null)
            await OnExportAsset.InvokeAsync(asset);
    }

    private async Task RunAsync(string status, Func<Task> action)
    {
        _error = null;
        _status = status;
        _busy = true;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SetModeAsync(SpriteMode mode)
    {
        _mode = mode;
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetSourceToolAsync(string tool)
    {
        _sourceTool = tool;
        await RenderCanvasAsync();
    }

    private async Task SetFrameToolAsync(string tool)
    {
        _frameTool = tool;
        await RenderCanvasAsync();
    }

    private async Task SelectRegionAsync(Guid id)
    {
        if (!_selectedRegionIds.Remove(id))
        {
            _selectedRegionIds.Clear();
            _selectedRegionIds.Add(id);
        }
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task SelectFrameAsync(int index)
    {
        _selectedIndex = index;
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task RenderCanvasAsync()
    {
        if (_module is null || _dotNetRef is null)
            return;

        if (_mode == SpriteMode.Source && SourceImageUrl() is { } sourceUrl)
        {
            await _module.InvokeVoidAsync(
                "loadSourceCanvas",
                _sourceCanvas,
                _dotNetRef,
                sourceUrl,
                _regions.Select(CanvasRegion.From).ToList(),
                _selectedRegionIds.Select(id => id.ToString()).ToList(),
                _sourceTool);
        }
        else if (_mode == SpriteMode.Frames && SelectedFrame() is { } frame)
        {
            var previous = NeighborFrame(-1);
            var next = NeighborFrame(1);
            await _module.InvokeVoidAsync(
                "loadFrameCanvas",
                _frameCanvas,
                _dotNetRef,
                FramePreviewUrl(frame.Id),
                frame.HasMask ? FrameMaskUrl(frame.Id) : null,
                CanvasFrame.From(frame),
                previous is null ? null : FramePreviewUrl(previous.Id),
                next is null ? null : FramePreviewUrl(next.Id),
                _frameTool,
                _brushSize,
                _showOnion);
        }
    }

    [JSInvokable]
    public async Task OnSourceRegionsChanged(SourceCanvasPayload payload)
    {
        if (SelectedSourceAssetId() is not Guid sourceId)
            return;
        _regions = payload.Regions
            .Select((region, index) => region.ToView(sourceId, index))
            .ToList();
        _selectedRegionIds.Clear();
        foreach (var id in payload.SelectedIds.Select(ParseGuid).Where(id => id is not null).Select(id => id!.Value))
            _selectedRegionIds.Add(id);
        await SaveRegionsAsync(sourceId);
    }

    [JSInvokable]
    public async Task OnSourceRegionSelected(string? id)
    {
        _selectedRegionIds.Clear();
        if (ParseGuid(id) is Guid regionId)
            _selectedRegionIds.Add(regionId);
        await PublishSpritesStateAsync();
    }

    [JSInvokable]
    public async Task OnFrameContentOffsetChanged(int x, int y)
    {
        if (SelectedFrame() is { } frame)
            await SetFrameOffsetAsync(frame.Id, x, y);
    }

    [JSInvokable]
    public async Task OnFrameContentNudged(int dx, int dy)
    {
        if (SelectedFrame() is { } frame)
            await SetFrameOffsetAsync(frame.Id, frame.ContentOffsetX + dx, frame.ContentOffsetY + dy);
    }

    [JSInvokable]
    public async Task OnFrameMaskChanged(string maskDataUrl)
    {
        if (SelectedFrame() is not { } frame)
            return;
        await FrameSets.UpsertFrameMaskAsync(Workbench.Project.Id, new UpsertFrameMaskRequest(frame.Id, maskDataUrl, $"{frame.Name} mask"));
        if (_frameSet is { } set)
            ApplyFrameSet(await FrameSets.GetFrameSetAsync(Workbench.Project.Id, set.Id));
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task PublishSpritesStateAsync()
    {
        if (!OnVisibleStateChanged.HasDelegate)
            return;
        await OnVisibleStateChanged.InvokeAsync(new WorkspaceSpritesVisibleState(
            ActiveSpriteSheet: null,
            ActiveFrameSet: _frameSet is null ? null : new WorkspaceFrameSetSummary(_frameSet.Id, _frameSet.Name, _frameSet.SourceAssetId, _frameSet.DefaultCellWidth, _frameSet.DefaultCellHeight, _frameSet.FrameCount),
            SourceAsset: SelectedSourceAsset(),
            SelectedRegions: _regions.Where(region => _selectedRegionIds.Contains(region.Id)).Select(region => new WorkspaceSpriteRegionSummary(region.Id, region.Name, region.X, region.Y, region.Width, region.Height, region.RegionType, region.Order)).ToList(),
            SelectedFrames: SelectedFrame() is { } frame ? [new WorkspaceFrameSummary(frame.Id, frame.Index, frame.Name, frame.SourceX, frame.SourceY, frame.SourceWidth, frame.SourceHeight, frame.LogicalWidth, frame.LogicalHeight, frame.ContentOffsetX, frame.ContentOffsetY, frame.DurationMs, frame.WorkingState, frame.HasMask)] : [],
            SelectedMaskId: SelectedFrame()?.MaskId,
            BuiltSheet: BuiltSheetAssetId() is Guid built ? new WorkspaceBuiltSheetSummary(built, BuiltSheetManifest() ?? string.Empty) : null,
            Mode: ModeLabel(_mode)));
    }

    private FrameView? SelectedFrame() =>
        _frameSet is { } set && _selectedIndex >= 0 && _selectedIndex < set.Frames.Count ? set.Frames[_selectedIndex] : null;

    private SourceRegionView? SelectedRegion() =>
        _regions.FirstOrDefault(region => _selectedRegionIds.Contains(region.Id));

    private FrameView? NeighborFrame(int offset)
    {
        if (_frameSet is not { } set || _selectedIndex < 0)
            return null;
        var index = _selectedIndex + offset;
        return index >= 0 && index < set.Frames.Count ? set.Frames[index] : null;
    }

    private FrameView? AnimationFrame()
    {
        if (_frameSet is not { } set || set.Frames.Count == 0)
            return null;
        var index = _animPlaying ? _animIndex % set.Frames.Count : Math.Max(0, _selectedIndex);
        return index >= 0 && index < set.Frames.Count ? set.Frames[index] : set.Frames[0];
    }

    private async Task ToggleAnimationAsync()
    {
        if (_animPlaying)
        {
            StopAnimation();
            return;
        }

        if (_frameSet is null || _frameSet.Frames.Count == 0)
            return;

        _animPlaying = true;
        _animCts = new CancellationTokenSource();
        _ = RunAnimationLoopAsync(_animCts.Token);
        await Task.CompletedTask;
    }

    private async Task RunAnimationLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && _frameSet is { Frames.Count: > 0 })
            {
                await Task.Delay(Math.Max(16, 1000 / Math.Clamp(_fps, 1, 60)), token);
                _animIndex = (_animIndex + 1) % Math.Max(1, _frameSet?.Frames.Count ?? 1);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopAnimation()
    {
        _animCts?.Cancel();
        _animCts?.Dispose();
        _animCts = null;
        _animPlaying = false;
    }

    private int FrameCount() => _frameSet?.FrameCount ?? 0;

    private Guid? SelectedSourceAssetId() =>
        Guid.TryParse(_sourceAssetIdText, out var id) ? id : _frameSet?.SourceAssetId;

    private WorkspaceAssetSummary? SelectedSourceAsset() =>
        SelectedSourceArtAsset() is { } asset
            ? new WorkspaceAssetSummary(asset.Id, asset.Label, asset.Kind, asset.ContentType, asset.Width, asset.Height, asset.ParentAssetId, asset.SourceBatchId, asset.BatchOutputIndex, asset.SourcePromptRecipeId, asset.SourcePromptRecipeVersion, asset.IsFavorite, asset.Notes, Preview(asset.Prompt, 240), asset.CreatedAt)
            : null;

    private static string Preview(string value, int maxLength)
    {
        value = value.Trim();
        return value.Length <= maxLength ? value : string.Concat(value.AsSpan(0, Math.Max(0, maxLength - 1)), "...");
    }

    private ArtAssetView? SelectedSourceArtAsset() =>
        SelectedSourceAssetId() is Guid assetId ? Workbench.Assets.FirstOrDefault(asset => asset.Id == assetId) : null;

    private static string SourceAssetMeta(ArtAssetView asset)
    {
        var dimensions = asset.Width is int width && asset.Height is int height ? $"{width} x {height}" : "size unknown";
        return $"{asset.Kind} / {dimensions}";
    }

    private string? SourceImageUrl()
    {
        var id = SelectedSourceAssetId() ?? _frameSet?.SourceAssetId;
        return id is Guid assetId ? AssetFullUrl(assetId) : null;
    }

    private Guid? BuiltSheetAssetId() => _builtSheetAssetId ?? _frameSet?.LatestBuiltSheetAssetId;

    private string? BuiltSheetManifest() => _builtSheetManifest ?? _frameSet?.LatestBuiltSheetManifest;

    private string AssetFullUrl(Guid assetId) => $"/media/projects/{Workbench.Project.Id}/assets/{assetId}/full?v={_rev}";

    private string FramePreviewUrl(Guid frameId) => $"/media/projects/{Workbench.Project.Id}/frame-set-frames/{frameId}/preview?v={_rev}";

    private string FrameMaskUrl(Guid frameId) => $"/media/projects/{Workbench.Project.Id}/frame-set-frames/{frameId}/mask?v={_rev}";

    private string HeaderSummary()
    {
        if (_frameSet is not { } set)
            return SelectedSourceAssetId() is Guid ? $"{_regions.Count} source region(s)" : "No source selected";
        return $"{set.Name} / {set.FrameCount} frame(s) / {set.DefaultCellWidth} x {set.DefaultCellHeight}";
    }

    private string ToolRailHint() => _mode switch
    {
        SpriteMode.Sheet => "Configure and build.",
        SpriteMode.Export => "Export final files.",
        _ => string.Empty,
    };

    private static string ModeLabel(SpriteMode mode) => mode switch
    {
        SpriteMode.Source => "Source",
        SpriteMode.Frames => "Frames",
        SpriteMode.Sheet => "Sheet",
        SpriteMode.Export => "Export",
        _ => mode.ToString(),
    };

    private string ModeTabClass(SpriteMode mode) => _mode == mode ? "sprite-mode-tab is-active" : "sprite-mode-tab";

    private static string ToolButtonClass(string current, string tool) => current == tool ? "sprite-tool-button is-active" : "sprite-tool-button";

    private string StageTitle() => _mode switch
    {
        SpriteMode.Source => "Source regions",
        SpriteMode.Frames => "Frame workspace",
        SpriteMode.Sheet => "Sheet preview",
        SpriteMode.Export => "Export",
        _ => string.Empty,
    };

    private static string WorkingLabel(FrameView frame) =>
        string.IsNullOrWhiteSpace(frame.WorkingState) || frame.WorkingState == "none" ? "Source" : Capitalize(frame.WorkingState);

    private static string WorkingBadgeClass(FrameView frame) =>
        string.IsNullOrWhiteSpace(frame.WorkingState) || frame.WorkingState == "none" ? "frame-work-badge is-empty" : "frame-work-badge";

    private static string Capitalize(string value) =>
        string.IsNullOrEmpty(value) ? value : char.ToUpperInvariant(value[0]) + value[1..];

    private static Guid? ParseGuid(string? value) => Guid.TryParse(value, out var id) ? id : null;

    public async ValueTask DisposeAsync()
    {
        StopAnimation();
        if (_module is not null)
            await _module.DisposeAsync();
        _dotNetRef?.Dispose();
    }

    private enum SpriteMode
    {
        Source,
        Frames,
        Sheet,
        Export
    }

    public sealed record SourceCanvasPayload(IReadOnlyList<CanvasRegion> Regions, IReadOnlyList<string> SelectedIds);

    public sealed record CanvasRegion(
        string? Id,
        string Name,
        int X,
        int Y,
        int Width,
        int Height,
        IReadOnlyList<SpriteSheetShapePath> ShapePaths,
        string RegionType,
        int Order)
    {
        public static CanvasRegion From(SourceRegionView view) =>
            new(view.Id.ToString(), view.Name, view.X, view.Y, view.Width, view.Height, view.ShapePaths, view.RegionType, view.Order);

        public SourceRegionView ToView(Guid sourceAssetId, int fallbackOrder) =>
            new(ParseGuid(Id) ?? Guid.NewGuid(), sourceAssetId, Name, X, Y, Width, Height, ShapePaths, string.IsNullOrWhiteSpace(RegionType) ? "frame" : RegionType, Order >= 0 ? Order : fallbackOrder);
    }

    public sealed record CanvasFrame(
        string Id,
        int Index,
        string Name,
        int LogicalWidth,
        int LogicalHeight,
        int SourceWidth,
        int SourceHeight,
        int ContentOffsetX,
        int ContentOffsetY,
        bool HasMask)
    {
        public static CanvasFrame From(FrameView frame) =>
            new(frame.Id.ToString(), frame.Index, frame.Name, frame.LogicalWidth, frame.LogicalHeight, frame.SourceWidth, frame.SourceHeight, frame.ContentOffsetX, frame.ContentOffsetY, frame.HasMask);
    }
