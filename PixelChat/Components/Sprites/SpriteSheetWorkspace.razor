@namespace PixelChat.Components.Sprites
@using PixelChat.Art
@using PixelChat.Models
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IJSRuntime JS

<div class="sprite-workspace">
    <div class="panel-head">
        <div>
            <h1>Sprites</h1>
            <span>@HeaderSummary()</span>
        </div>
        <div class="sprite-head-actions">
            <label class="sprite-file-control">
                <span>Import Sheet</span>
                <InputFile OnChange="ImportSourceAsync" accept="image/png,image/jpeg" />
            </label>
            <label class="sprite-file-control">
                <span>Import Frames</span>
                <InputFile OnChange="ImportFramesAsync" accept="image/png" multiple />
            </label>
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet || _framePersistenceRunning)" @onclick="AutoDetectAsync">Auto Detect</button>
            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!HasActiveSheet || _framePersistenceRunning)" @onclick="ResetToOriginalAsync">Reset</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet)" @onclick="PreviewSheetAsync">Preview Sheet</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet)" @onclick="AddSheetToReviewAsync">Add Sheet to Review</button>
            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(CurrentWorkingAsset() is null)" @onclick="ExportWorkingAsync">Export...</button>
        </div>
    </div>

    @if (!HasActiveSheet)
    {
        <div class="empty-state">Select Sprite Sheet on an asset card or import an image to start.</div>
    }
    else
    {
        <div class="sprite-editor-grid">
            <section class="sprite-editor-main">
                <div class="sprite-canvas-panel">
                    <div class="section-title">Source Regions</div>
                    <canvas class="sprite-source-canvas" @ref="_sourceCanvas"></canvas>
                </div>

                <div class="sprite-tool-strip">
                    <div class="tool-button-row">
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Select)" title="@ToolTitle(SpriteEditTool.Select)" aria-pressed="@(_tool == SpriteEditTool.Select)" @onclick="() => SetToolAsync(SpriteEditTool.Select)">Select</button>
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Draw)" title="@ToolTitle(SpriteEditTool.Draw)" aria-pressed="@(_tool == SpriteEditTool.Draw)" @onclick="() => SetToolAsync(SpriteEditTool.Draw)">Draw Box</button>
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Outline)" title="@ToolTitle(SpriteEditTool.Outline)" aria-pressed="@(_tool == SpriteEditTool.Outline)" @onclick="() => SetToolAsync(SpriteEditTool.Outline)">Outline</button>
                        <button type="button" class="@ToolButtonClass(SpriteEditTool.Anchor)" title="@ToolTitle(SpriteEditTool.Anchor)" aria-pressed="@(_tool == SpriteEditTool.Anchor)" @onclick="() => SetToolAsync(SpriteEditTool.Anchor)">Anchor</button>
                        <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(_frames.Count == 0 || _framePersistenceRunning)" @onclick="ExpandToCellsAsync">Expand to Cells</button>
                        <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(_frames.Count == 0 || _frameEditRunning || _framePersistenceRunning)" @onclick="SplitAllFramesAsync">Split Frames</button>
                        <button type="button" class="btn btn-sm btn-primary" disabled="@(_frames.Count == 0 || _frameEditRunning || _framePersistenceRunning)" @onclick="ReassembleSheetAsync">Reassemble</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(_selectedFrameIndex < 0 || _frames.Count == 0 || _framePersistenceRunning)" @onclick="DeleteSelectedFrameAsync">Delete</button>
                    </div>

                    <div class="selected-frame-readout">
                        @if (SelectedFrame() is { } selected)
                        {
                            <span>@selected.Label</span>
                            <span class="@GeometryReadoutClass(selected)">@FrameGeometryLabel(selected)</span>
                            <span>X @selected.X</span>
                            <span>Y @selected.Y</span>
                            <span>W @selected.Width</span>
                            <span>H @selected.Height</span>
                            <span>@WorkingStateLabel(selected)</span>
                            @if (Workbench.ActiveSpriteSheet?.Stabilization is { } stabilization)
                            {
                                <span>Stabilized F@stabilization.ReferenceFrameNumber</span>
                                <span>@stabilization.AnchorRect.X,@stabilization.AnchorRect.Y @stabilization.AnchorRect.Width x @stabilization.AnchorRect.Height</span>
                                <span>@StabilizationAppliedCount(stabilization) applied</span>
                                <span>@StabilizationLowConfidenceCount(stabilization) low</span>
                            }
                        }
                        else
                        {
                            <span>No frame selected</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_status))
                    {
                        <div class="sprite-status">@_status</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <div class="sprite-error">@_error</div>
                    }
                </div>
            </section>

            <aside class="sprite-side-panel">
                <div class="sprite-canvas-panel sprite-animation-panel">
                    <div class="sprite-section-title-row">
                        <div class="section-title">Animation</div>
                        <div class="sprite-section-actions">
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet || _frames.Count == 0)" @onclick="PreviewAnimationAsync">Preview</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasActiveSheet || _frames.Count == 0)" @onclick="AddAnimationToReviewAsync">Add to Review</button>
                        </div>
                    </div>
                    <canvas class="@AnimationCanvasClass()" @ref="_animationCanvas" @onclick="PreviewAnimationAsync"></canvas>
                </div>

                <div class="sprite-settings-panel sprite-stabilization-panel">
                    <div class="sprite-section-title-row">
                        <div class="section-title">Stabilization</div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!HasSavedStabilization || _stabilizationRunning)" @onclick="ClearStabilizationAsync">Clear</button>
                    </div>
                    <div class="stabilization-readout">
                        @if (_stabilizationAnchor is { } anchor)
                        {
                            <span>Reference F@ReferenceFrameNumber()</span>
                            <span>X @anchor.X</span>
                            <span>Y @anchor.Y</span>
                            <span>W @anchor.Width</span>
                            <span>H @anchor.Height</span>
                        }
                        else
                        {
                            <span>No anchor</span>
                        }
                    </div>
                    <div class="sprite-grid-controls">
                        <label>
                            <span>Search</span>
                            <input class="form-control form-control-sm" type="number" min="0" max="512" @bind="_stabilizationSearchPadding" @bind:after="OnStabilizationSettingsChanged" />
                        </label>
                        <label>
                            <span>Min Score</span>
                            <input class="form-control form-control-sm" type="number" min="-1" max="1" step="0.01" @bind="_stabilizationMinScore" @bind:after="OnStabilizationSettingsChanged" />
                        </label>
                    </div>
                    <div class="stabilization-actions">
                        <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(!CanRunStabilization())" @onclick="PreviewStabilizationAsync">Preview Stabilize</button>
                        <button type="button" class="btn btn-sm btn-primary" disabled="@(!CanApplyStabilization())" @onclick="ApplyStabilizationAsync">Apply</button>
                    </div>
                    @if (_stabilizationPreview is { } preview)
                    {
                        <div class="stabilization-summary">
                            <span>@preview.Stabilization.Matches.Count match(es)</span>
                            <span>@StabilizationLowConfidenceCount(preview.Stabilization) low confidence</span>
                            <span>@StabilizationClampedCount(preview.Stabilization) clamped</span>
                        </div>
                        @if (preview.Warnings.Count > 0)
                        {
                            <ul class="stabilization-warnings">
                                @foreach (var warning in preview.Warnings.Take(4))
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        }
                        <img class="stabilization-diagnostic" src="@preview.DiagnosticImage.DataUrl" alt="Stabilization diagnostic" />
                        <div class="stabilization-match-list">
                            @foreach (var match in preview.Stabilization.Matches.OrderBy(match => match.Index))
                            {
                                <div class="stabilization-match-row @(match.LowConfidence ? "is-low-confidence" : "")">
                                    <span>F@match.FrameNumber</span>
                                    <span>@match.Score.ToString("0.000")</span>
                                    <span>dx @match.DeltaX</span>
                                    <span>dy @match.DeltaY</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="sprite-settings-panel">
                    <div class="section-title">Sheet Settings</div>
                    <div class="sprite-grid-controls">
                        <label>
                            <span>Rows</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="32" @bind="_rows" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Columns</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="64" @bind="_columns" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Output W</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellWidth" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Output H</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellHeight" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Padding</span>
                            <input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_padding" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>Gutter</span>
                            <input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_gutter" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label>
                            <span>FPS</span>
                            <input class="form-control form-control-sm" type="number" min="1" max="60" @bind="_fps" @bind:after="OnLayoutFieldChangedAsync" />
                        </label>
                        <label class="sprite-loop-toggle">
                            <input type="checkbox" @bind="_loop" @bind:after="OnLayoutFieldChangedAsync" />
                            <span>Loop</span>
                        </label>
                        <label>
                            <span>H Anchor</span>
                            <select class="form-select form-select-sm" @bind="_horizontalAnchor" @bind:after="OnLayoutFieldChangedAsync">
                                <option value="left">Left</option>
                                <option value="center">Center</option>
                                <option value="right">Right</option>
                            </select>
                        </label>
                        <label>
                            <span>V Anchor</span>
                            <select class="form-select form-select-sm" @bind="_verticalAnchor" @bind:after="OnLayoutFieldChangedAsync">
                                <option value="top">Top</option>
                                <option value="middle">Middle</option>
                                <option value="bottom">Bottom</option>
                            </select>
                        </label>
                    </div>
                </div>

                <div class="frame-list-head">
                    <span>@_frames.Count frame(s)</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_frames.Count == 0)" @onclick="AttachAllFramesAsync">Attach all</button>
                </div>

                <div class="sprite-frame-list">
                    @foreach (var frame in _frames)
                    {
                        <div class="sprite-frame-row @(frame.Index == _selectedFrameIndex ? "is-selected" : "")">
                            <button type="button" class="frame-thumb" @onclick="() => SelectFrameAsync(frame.Index)" @ondblclick="() => PreviewFrameAsync(frame)">
                                @if (!string.IsNullOrWhiteSpace(frame.PreviewImageUrl))
                                {
                                    <LazyImage Src="@frame.PreviewImageUrl" Alt="@frame.Label" Width="58" Height="58" />
                                }
                                else
                                {
                                    <span>@(frame.Index + 1)</span>
                                }
                                <span class="@FrameMarkerClass(frame)" title="@FrameGeometryLabel(frame)" aria-hidden="true"></span>
                            </button>
                            <div class="frame-label-stack">
                                <input class="form-control form-control-sm" @bind="frame.Label" @bind:after="OnFrameLabelChangedAsync" />
                                @if (!string.IsNullOrWhiteSpace(FrameSourceLabel(frame)))
                                {
                                    <small>@FrameSourceLabel(frame)</small>
                                }
                            </div>
                            <span class="@WorkingBadgeClass(frame)">@WorkingStateLabel(frame)</span>
                            <div class="frame-row-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Move up" disabled="@(frame.Index == 0)" @onclick="() => MoveFrameAsync(frame.Index, -1)">Up</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Move down" disabled="@(frame.Index >= _frames.Count - 1)" @onclick="() => MoveFrameAsync(frame.Index, 1)">Down</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Preview frame" disabled="@(!CanPreviewFrame(frame))" @onclick="() => PreviewFrameAsync(frame)">Preview</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Attach frame" disabled="@(frame.Id is null)" @onclick="() => AttachFrameAsync(frame)">Attach</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="frame-work-panel">
                    <div class="section-title">Frame Work</div>
                    @if (SelectedFrame() is { } selectedFrame)
                    {
                        <div class="frame-work-meta">
                            <span>@selectedFrame.Label</span>
                            <span>@WorkingStateLabel(selectedFrame)</span>
                            @if (_frameWorkImageWidth > 0 && _frameWorkImageHeight > 0)
                            {
                                <span>@_frameWorkImageWidth x @_frameWorkImageHeight</span>
                            }
                        </div>
                        <canvas class="@FrameWorkCanvasClass()" @ref="_frameWorkCanvas"></canvas>
                        <div class="frame-work-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@_frameEditRunning" @onclick="IsolateSelectedFrameAsync">@(HasWorkingImage(selectedFrame) ? "Re-isolate" : "Isolate")</button>
                            <div class="frame-erase-controls" role="group" aria-label="Frame erase mode">
                                <button type="button" class="@FrameEraseButtonClass(FrameWorkEraseMode.Rect)" disabled="@FrameEraseModeDisabled(selectedFrame)" @onclick="() => SetFrameEraseModeAsync(FrameWorkEraseMode.Rect)">Rect</button>
                                <button type="button" class="@FrameEraseButtonClass(FrameWorkEraseMode.Polygon)" disabled="@FrameEraseModeDisabled(selectedFrame)" @onclick="() => SetFrameEraseModeAsync(FrameWorkEraseMode.Polygon)">Polygon</button>
                                <button type="button" class="@FrameEraseButtonClass(FrameWorkEraseMode.Lasso)" disabled="@FrameEraseModeDisabled(selectedFrame)" @onclick="() => SetFrameEraseModeAsync(FrameWorkEraseMode.Lasso)">Lasso</button>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!HasWorkingImage(selectedFrame) || _frameEditRunning)" @onclick="ClearSelectedFrameWorkAsync">Revert</button>
                        </div>
                        <textarea class="form-control form-control-sm frame-edit-prompt" rows="2" placeholder="Frame edit prompt" @bind="_frameEditPrompt"></textarea>
                        <button type="button" class="btn btn-sm btn-primary frame-edit-button" disabled="@(_frameEditRunning || string.IsNullOrWhiteSpace(_frameEditPrompt))" @onclick="EditSelectedFrameAsync">AI Edit</button>
                    }
                    else
                    {
                        <div class="empty-state compact">Select a frame.</div>
                    }
                </div>

            </aside>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public WorkbenchView Workbench { get; set; } = null!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [Parameter]
    public EventCallback<ArtAssetView> OnExportAsset { get; set; }

    [Parameter]
    public EventCallback<SpriteSheetDefinitionView> OnAddSheetToReview { get; set; }

    [Parameter]
    public EventCallback<SpriteSheetDefinitionView> OnAddAnimationToReview { get; set; }

    [Parameter]
    public EventCallback<SpriteSheetDefinitionView> OnPreviewSheet { get; set; }

    [Parameter]
    public EventCallback<SpriteSheetDefinitionView> OnPreviewAnimation { get; set; }

    [Parameter]
    public EventCallback<SpriteSheetFrameRecordView> OnPreviewFrame { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<SpriteSheetWorkspace>? _dotNetRef;
    private ElementReference _sourceCanvas;
    private ElementReference _animationCanvas;
    private ElementReference _frameWorkCanvas;
    private CancellationTokenSource? _autosaveCts;
    private bool _disposed;

    private Guid? _loadedSpriteSheetId;
    private DateTime? _loadedSpriteSheetUpdatedAt;
    private string _workingImageDataUrl = string.Empty;
    private int _rows = 1;
    private int _columns = 1;
    private int _cellWidth = 128;
    private int _cellHeight = 128;
    private int _padding = 8;
    private int _gutter = 16;
    private int _fps = 8;
    private bool _loop = true;
    private string _horizontalAnchor = "center";
    private string _verticalAnchor = "bottom";
    private int _selectedFrameIndex = -1;
    private SpriteEditTool _tool = SpriteEditTool.Select;
    private string _status = string.Empty;
    private string? _error;
    private string _frameWorkImageDataUrl = string.Empty;
    private int _frameWorkImageWidth;
    private int _frameWorkImageHeight;
    private int? _loadedFrameWorkIndex;
    private DateTime? _loadedFrameWorkUpdatedAt;
    private string _frameEditPrompt = string.Empty;
    private bool _frameEditRunning;
    private bool _framePersistenceRunning;
    private SpriteSheetRect? _stabilizationAnchor;
    private int? _stabilizationReferenceFrameNumber;
    private StabilizeSpriteSheetFramesResult? _stabilizationPreview;
    private int _stabilizationSearchPadding = 24;
    private double _stabilizationMinScore = 0.68d;
    private bool _stabilizationRunning;
    private FrameWorkEraseMode _frameEraseMode = FrameWorkEraseMode.None;
    private readonly List<SpriteSheetEditorFrame> _frames = [];

    private bool HasActiveSheet => Workbench.ActiveSpriteSheet is not null && CurrentWorkingAsset() is not null;
    private bool HasSavedStabilization => Workbench.ActiveSpriteSheet?.Stabilization is not null;

    protected override void OnParametersSet()
    {
        var active = Workbench.ActiveSpriteSheet;
        if (active is null || CurrentWorkingAsset(active) is not { } working)
        {
            _loadedSpriteSheetId = null;
            _loadedSpriteSheetUpdatedAt = null;
            _workingImageDataUrl = string.Empty;
            _frameWorkImageDataUrl = string.Empty;
            _frameWorkImageWidth = 0;
            _frameWorkImageHeight = 0;
            _loadedFrameWorkIndex = null;
            _loadedFrameWorkUpdatedAt = null;
            _stabilizationAnchor = null;
            _stabilizationReferenceFrameNumber = null;
            _stabilizationPreview = null;
            ResetFrameEraseMode();
            _frames.Clear();
            _selectedFrameIndex = -1;
            return;
        }

        if (_loadedSpriteSheetId == active.Id && _loadedSpriteSheetUpdatedAt == active.UpdatedAt && _workingImageDataUrl == working.FullImageUrl)
            return;

        LoadSheet(active, working);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender)
        {
            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Sprites/SpriteSheetWorkspace.razor.js");
                if (_disposed)
                {
                    await module.DisposeAsync();
                    return;
                }

                _module = module;
                _dotNetRef = DotNetObjectReference.Create(this);
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }

        await DrawAsync();
        if (SelectedFrame() is { } selected
            && HasWorkingImage(selected)
            && (_loadedFrameWorkIndex != selected.Index || _loadedFrameWorkUpdatedAt != selected.WorkingUpdatedAt || string.IsNullOrWhiteSpace(_frameWorkImageDataUrl)))
        {
            await LoadSelectedFrameWorkAsync();
        }
        await DrawFrameWorkAsync();
    }

    private async Task ImportSourceAsync(InputFileChangeEventArgs args)
    {
        if (args.File is null)
            return;

        _error = null;
        _status = "Importing sprite sheet source...";
        try
        {
            await using var stream = args.File.OpenReadStream(50 * 1024 * 1024);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            var asset = await Workflow.ImportAssetAsync(Workbench.Project.Id, new ImportAssetRequest(
                args.File.Name,
                args.File.ContentType,
                memory.ToArray(),
                Path.GetFileNameWithoutExtension(args.File.Name)));
            await Workflow.StartSpriteSheetEditAsync(Workbench.Project.Id, asset.Id);
            _status = $"Imported {asset.Label}.";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task ImportFramesAsync(InputFileChangeEventArgs args)
    {
        var files = args.GetMultipleFiles(128);
        if (files.Count == 0)
            return;

        _error = null;
        _status = files.Count == 1 ? "Importing sprite frame..." : $"Importing {files.Count} sprite frames...";
        try
        {
            var assetIds = new List<Guid>();
            foreach (var file in files)
            {
                if (!file.ContentType.Equals("image/png", StringComparison.OrdinalIgnoreCase))
                    throw new InvalidOperationException("Sprite frame composition requires PNG images.");

                await using var stream = file.OpenReadStream(50 * 1024 * 1024);
                using var memory = new MemoryStream();
                await stream.CopyToAsync(memory);
                var asset = await Workflow.ImportAssetAsync(Workbench.Project.Id, new ImportAssetRequest(
                    file.Name,
                    file.ContentType,
                    memory.ToArray(),
                    Path.GetFileNameWithoutExtension(file.Name)));
                assetIds.Add(asset.Id);
            }

            var hadActiveSheet = Workbench.ActiveSpriteSheet is not null;
            var sheet = await Workflow.ComposeSpriteSheetFromImagesAsync(Workbench.Project.Id, new ComposeSpriteSheetFromImagesRequest(
                assetIds,
                Workbench.ActiveSpriteSheet?.Id,
                Label: files.Count == 1 ? null : "Imported frame sheet"));
            _loadedSpriteSheetId = null;
            _loadedSpriteSheetUpdatedAt = null;
            _status = hadActiveSheet
                ? $"Added {files.Count} frame(s)."
                : $"Created {sheet.Label} from {files.Count} frame(s).";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task AutoDetectAsync()
    {
        if (CurrentWorkingAsset() is not { } working)
            return;

        _error = null;
        _status = "Detecting sprite frames...";
        try
        {
            var detection = await Workflow.DetectSpriteSheetFramesAsync(
                Workbench.Project.Id,
                new SpriteSheetDetectionRequest(working.Id, null, "rows", "auto"));
            if (detection.Frames.Count == 0)
                throw new InvalidOperationException("No foreground frames were detected.");

            _rows = Math.Max(1, detection.Rows);
            _columns = Math.Max(1, detection.Columns);
            _frames.Clear();
            _frames.AddRange(detection.Frames
                .OrderBy(frame => frame.Index)
                .Select(frame => new SpriteSheetEditorFrame
                {
                    Index = frame.Index,
                    Label = $"Frame {frame.Index + 1}",
                    X = frame.SourceRect.X,
                    Y = frame.SourceRect.Y,
                    Width = frame.SourceRect.Width,
                    Height = frame.SourceRect.Height,
                    ShapePaths = frame.ShapePaths.ToList(),
                    SourceImageAssetId = working.Id,
                    SourceImageRect = frame.SourceRect,
                }));
            FitCellsToFrames();
            _selectedFrameIndex = _frames.Count > 0 ? 0 : -1;
            await AutosaveLayoutNowAsync();
            _status = $"Detected {_frames.Count} frame(s).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
    }

    private async Task ResetToOriginalAsync()
    {
        var active = Workbench.ActiveSpriteSheet;
        if (active is null || _framePersistenceRunning)
            return;

        _error = null;
        _status = "Resetting sprite sheet...";
        _framePersistenceRunning = true;
        _autosaveCts?.Cancel();
        await Task.Yield();
        try
        {
            var reset = await Workflow.ResetSpriteSheetToOriginalAsync(Workbench.Project.Id, active.Id);
            _loadedSpriteSheetId = null;
            _loadedSpriteSheetUpdatedAt = null;
            _frames.Clear();
            _selectedFrameIndex = -1;
            _loadedFrameWorkIndex = null;
            _loadedFrameWorkUpdatedAt = null;
            _frameWorkImageDataUrl = string.Empty;
            _frameWorkImageWidth = 0;
            _frameWorkImageHeight = 0;
            ResetFrameEraseMode();
            _status = $"{reset.Label} reset.";
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _status = string.Empty;
        }
        finally
        {
            _framePersistenceRunning = false;
        }
    }

    private async Task ExportWorkingAsync()
    {
        if (CurrentWorkingAsset() is { } asset)
            await OnExportAsset.InvokeAsync(asset);
    }

    private async Task AddSheetToReviewAsync()
    {
        if (Workbench.ActiveSpriteSheet is { } sheet)
            await OnAddSheetToReview.InvokeAsync(sheet);
    }

    private async Task PreviewSheetAsync()
    {
        if (Workbench.ActiveSpriteSheet is { } sheet)
            await OnPreviewSheet.InvokeAsync(sheet);
    }

    private async Task AddAnimationToReviewAsync()
    {
        if (Workbench.ActiveSpriteSheet is { } sheet)
            await OnAddAnimationToReview.InvokeAsync(sheet);
    }

    private async Task PreviewAnimationAsync()
    {
