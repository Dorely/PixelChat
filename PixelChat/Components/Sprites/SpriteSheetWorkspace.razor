    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposeSpriteBoxEditor", _sourceCanvas, _animationCanvas);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
            catch (OperationCanceledException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }

    private List<SpriteSheetFrameUpdateView> BuildFrameUpdates()
    {
        NormalizeLayout();
        return _frames
            .OrderBy(frame => frame.Index)
            .Select((frame, index) => new SpriteSheetFrameUpdateView(
                index,
                frame.Label,
                new SpriteSheetRect(frame.X, frame.Y, frame.Width, frame.Height),
                frame.ShapePaths,
                frame.SourceImageAssetId,
                frame.SourceImageRect))
            .ToList();
    }

