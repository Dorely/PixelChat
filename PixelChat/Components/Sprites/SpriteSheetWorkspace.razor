            return;
        var updated = await FrameSets.TranslateFrameContentAsync(Workbench.Project.Id, new TranslateFrameContentRequest(set.Id, frameId, x, y));
        ApplyFrameSet(updated);
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task BuildSheetAsync()
    {
        if (_frameSet is not { } set)
            return;

        await RunAsync("Building sheet...", async () =>
        {
            var result = await FrameSets.BuildSheetAsync(Workbench.Project.Id, new BuildSheetRequest(
