@namespace PixelChat.Components.Sprites
@using Microsoft.Extensions.Options
@using PixelChat.Art
@using PixelChat.Chat
@using PixelChat.Models
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IFrameSetService FrameSets
@inject IImageGenerationRuntime ImageRuntime
@inject IOptions<ImageGenerationOptions> ImageOptions
@inject IJSRuntime JS

<div class="sprite-workspace">
    <div class="sprite-toolbar">
        <div class="sprite-toolbar-lead">
            <div class="sprite-title">
                <h1>Sprites</h1>
                <span>@HeaderSummary()</span>
            </div>
            <div class="sprite-history-group" role="group" aria-label="History">
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Undo - coming soon">Undo</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Redo - coming soon">Redo</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="History - coming soon">History</button>
            </div>
        </div>

        <div class="sprite-mode-tabs" role="tablist" aria-label="Editor mode">
            @foreach (var mode in SpriteModes)
            {
                <button type="button" class="@ModeTabClass(mode)" role="tab" aria-selected="@(_mode == mode)" @onclick="() => SetModeAsync(mode)">@ModeLabel(mode)</button>
            }
        </div>

        <div class="sprite-toolbar-actions">
            <label class="sprite-file-control">
                <span>Import Image</span>
                <InputFile OnChange="ImportSourceAsync" accept="image/png,image/jpeg" />
            </label>
        </div>
    </div>

    <div class="sprite-editor-body">
        <div class="sprite-stage-row">
            <nav class="sprite-tool-rail" aria-label="Tools">
                @if (_mode == SpriteMode.Source)
                {
                    <button type="button" class="@ToolButtonClass(_sourceTool, "select")" title="Select/move regions" @onclick='() => SetSourceToolAsync("select")'>Select</button>
                    <button type="button" class="@ToolButtonClass(_sourceTool, "draw")" title="Draw rectangular region" @onclick='() => SetSourceToolAsync("draw")'>Rect</button>
                    <button type="button" class="@ToolButtonClass(_sourceTool, "polygon")" title="Draw polygon region" @onclick='() => SetSourceToolAsync("polygon")'>Poly</button>
                    <button type="button" class="@ToolButtonClass(_sourceTool, "pan")" title="Pan canvas" @onclick='() => SetSourceToolAsync("pan")'>Pan</button>
                    <button type="button" class="sprite-tool-button" title="Edit source with mask and prompt" disabled="@(_busy || SelectedSourceAssetId() is null)" @onclick="OpenSourceEditModalAsync">Edit</button>
                }
                else if (_mode == SpriteMode.Frames)
                {
                    <button type="button" class="@ToolButtonClass(_frameTool, "content")" title="Move frame content" @onclick='() => SetFrameToolAsync("content")'>Move</button>
                    <button type="button" class="@ToolButtonClass(_frameTool, "anchor")" title="Draw anchor rectangle" @onclick='() => SetFrameToolAsync("anchor")'>Anchor</button>
                    <button type="button" class="@ToolButtonClass(_frameTool, "pan")" title="Pan canvas" @onclick='() => SetFrameToolAsync("pan")'>Pan</button>
                    <button type="button" class="sprite-tool-button" title="Edit selected frame with mask and prompt" disabled="@(_busy || SelectedFrame() is null)" @onclick="OpenFrameEditModalAsync">Edit</button>
                }
                else if (_mode == SpriteMode.Sheet)
                {
                    <button type="button" class="sprite-tool-button" title="Build normalized sprite sheet" disabled="@(_busy || _frameSet is null)" @onclick="BuildSheetAsync">Build</button>
                }
                else
                {
                    <span class="sprite-tool-rail-hint">@ToolRailHint()</span>
                }
            </nav>

            <section class="sprite-stage">
                <div class="sprite-section-title-row">
                    <div class="section-title">@StageTitle()</div>
                    @if (_busy)
                    {
                        <span class="sprite-busy-pill">Working...</span>
                    }
                </div>

                <div class="sprite-stage-canvas">
                    @if (_mode == SpriteMode.Source)
                    {
                        @if (SourceImageUrl() is not null)
                        {
                            <canvas class="sprite-canvas" @ref="_sourceCanvas" tabindex="0"></canvas>
                        }
                        else
                        {
                            <div class="empty-state compact">Import an image or choose a source asset.</div>
                        }
                    }
                    else if (_mode == SpriteMode.Frames)
                    {
                        @if (SelectedFrame() is not null)
                        {
                            <canvas class="sprite-canvas" @ref="_frameCanvas" tabindex="0"></canvas>
                        }
                        else
                        {
                            <div class="empty-state compact">Create a frame set, then select a frame.</div>
                        }
                    }
                    else if (_mode == SpriteMode.Sheet)
                    {
                        @if (_builtSheetAssetId is { } builtId)
                        {
                            <img class="sprite-stage-image" src="@AssetFullUrl(builtId)" alt="Built sheet" />
                        }
                        else if (_frameSet?.LatestBuiltSheetAssetId is { } latestBuilt)
                        {
                            <img class="sprite-stage-image" src="@AssetFullUrl(latestBuilt)" alt="Built sheet" />
                        }
                        else
                        {
                            <div class="empty-state compact">Build the sheet to preview it here.</div>
                        }
                    }
                    else
                    {
                        @if (BuiltSheetAssetId() is Guid exportAssetId)
                        {
                            <ExportPanel ProjectId="Workbench.Project.Id" AssetId="exportAssetId" Inline="true" />
                        }
                        else
                        {
                            <div class="sprite-export-pane">
                                <p>Build a sheet before exporting.</p>
                                <p class="sprite-export-note">Background removal, transparency, and edge cleanup happen here after the opaque sheet exists.</p>
                            </div>
                        }
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_status))
                {
                    <div class="sprite-status">@_status</div>
                }
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="sprite-error">@_error</div>
                }
            </section>

            <aside class="sprite-inspector">
                @if (_mode == SpriteMode.Source)
                {
                    <div class="sprite-settings-panel">
                        <div class="section-title">Source</div>
                        @if (SelectedSourceArtAsset() is { } sourceAsset)
                        {
                            <div class="sprite-source-summary">
                                <img src="@sourceAsset.PreviewImageUrl" alt="" />
                                <div>
                                    <strong>@sourceAsset.Label</strong>
                                    <span>@SourceAssetMeta(sourceAsset)</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="sprite-inspector-hint">Import an image or open one from Assets.</p>
                        }
                        <div class="sprite-inspector-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(_busy || SelectedSourceAssetId() is null)" @onclick="DetectRegionsAsync">Detect Regions</button>
                            <button type="button" class="btn btn-sm btn-primary" disabled="@(_busy || SelectedSourceAssetId() is null || _regions.Count == 0)" @onclick="CreateFrameSetFromRegionsAsync">Create Frame Set</button>
                        </div>
                    </div>

                    <div class="sprite-settings-panel">
                        <div class="section-title">Region</div>
                        @if (SelectedRegion() is { } region)
                        {
                            <label>
                                <span>Name</span>
                                <input class="form-control form-control-sm" value="@region.Name" @onchange="(e) => RenameRegionAsync(region.Id, e.Value?.ToString())" />
                            </label>
                            <div class="sprite-grid-controls">
                                <label><span>X</span><input class="form-control form-control-sm" type="number" value="@region.X" @onchange='(e) => UpdateSelectedRegionNumberAsync(region.Id, "x", e)' /></label>
                                <label><span>Y</span><input class="form-control form-control-sm" type="number" value="@region.Y" @onchange='(e) => UpdateSelectedRegionNumberAsync(region.Id, "y", e)' /></label>
                                <label><span>W</span><input class="form-control form-control-sm" type="number" min="1" value="@region.Width" @onchange='(e) => UpdateSelectedRegionNumberAsync(region.Id, "w", e)' /></label>
                                <label><span>H</span><input class="form-control form-control-sm" type="number" min="1" value="@region.Height" @onchange='(e) => UpdateSelectedRegionNumberAsync(region.Id, "h", e)' /></label>
                            </div>
                            <div class="sprite-inspector-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="ExtractSelectedRegionAsAssetAsync">Extract as Asset</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="DeleteSelectedRegionsAsync">Delete</button>
                            </div>
                        }
                        else
                        {
                            <p class="sprite-inspector-hint">Draw or select a region on the source image.</p>
                        }
                    </div>
                }
                else if (_mode == SpriteMode.Frames)
                {
                    <div class="sprite-anim-cluster">
                        <div class="sprite-section-title-row">
                            <div class="section-title">Animation</div>
                            <div class="sprite-section-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(FrameCount() == 0)" @onclick="ToggleAnimationAsync">@(_animPlaying ? "Stop" : "Play")</button>
                            </div>
                        </div>
                        <div class="sprite-anim-stage">
                            @if (AnimationFrame() is { } animFrame)
                            {
                                <img class="sprite-stage-image" src="@FramePreviewUrl(animFrame.Id)" alt="Animation preview" />
                            }
                            else
                            {
                                <div class="empty-state compact">No frames.</div>
                            }
                        </div>
                        <div class="sprite-anim-controls">
                            <label><span>FPS</span><input class="form-control form-control-sm" type="number" min="1" max="60" @bind="_fps" /></label>
                        </div>
                    </div>

                    <div class="sprite-settings-panel">
                        <div class="section-title">Frame Set</div>
                        <div class="sprite-grid-controls">
                            <label><span>Cell W</span><input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellWidth" /></label>
                            <label><span>Cell H</span><input class="form-control form-control-sm" type="number" min="1" max="8192" @bind="_cellHeight" /></label>
                        </div>
                        <div class="sprite-inspector-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(_busy || _frameSet is null)" @onclick="() => NormalizeCellSizeAsync(false)">Normalize</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_busy || _frameSet is null)" @onclick="() => NormalizeCellSizeAsync(true)">Auto Cell</button>
                        </div>
                    </div>

                    <div class="sprite-settings-panel sprite-stabilization-panel">
                        <div class="section-title">Anchor Align</div>
                        <label class="sprite-source-pick">
                            <span>Reference</span>
                            <select class="form-select form-select-sm" value="@AnchorReferenceFrameIdText()" @onchange="SetAnchorReferenceFrameAsync" disabled="@(_busy || _frameSet is null)">
                                @if (_frameSet is { } anchorSet)
                                {
                                    @foreach (var frame in anchorSet.Frames)
                                    {
                                        <option value="@frame.Id">@frame.Name</option>
                                    }
                                }
                            </select>
                        </label>
                        <div class="sprite-grid-controls">
                            <label><span>Search</span><input class="form-control form-control-sm" type="number" min="0" max="512" @bind="_anchorSearchPadding" /></label>
                            <label><span>Min Score</span><input class="form-control form-control-sm" type="number" step="0.01" min="-1" max="1" @bind="_anchorMinScore" /></label>
                        </div>
                        <div class="stabilization-readout">
                            <span>@AnchorRectSummary()</span>
                        </div>
                        <div class="sprite-inspector-actions">
                            <label class="sprite-axis-toggle"><input type="checkbox" @bind="_anchorAxisX" /> X</label>
                            <label class="sprite-axis-toggle"><input type="checkbox" @bind="_anchorAxisY" /> Y</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(!CanRunAnchorAlignment())" @onclick="() => AlignByAnchorRectAsync(false)">Preview</button>
                            <button type="button" class="btn btn-sm btn-primary" disabled="@(!CanRunAnchorAlignment())" @onclick="() => AlignByAnchorRectAsync(true)">Apply</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(_busy || _anchorRect is null)" @onclick="ClearAnchorRectAsync">Clear</button>
                        </div>
                        @if (_anchorDiagnostics is { } diagnostics)
                        {
                            <div class="stabilization-summary">
                                <span>@(diagnostics.Applied ? "Applied" : "Preview")</span>
                                <span>@diagnostics.Matches.Count match(es)</span>
                                <span>@diagnostics.Matches.Count(match => match.LowConfidence) low confidence</span>
                            </div>
                            @if (diagnostics.Warnings.Count > 0)
                            {
                                <ul class="stabilization-warnings">
                                    @foreach (var warning in diagnostics.Warnings.Take(3))
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            }
                            <div class="stabilization-match-list">
                                @foreach (var match in diagnostics.Matches.OrderBy(match => match.FrameIndex))
                                {
                                    <div class="stabilization-match-row @(match.LowConfidence ? "is-low-confidence" : "")">
                                        <span>@(match.FrameIndex + 1)</span>
                                        <span>@match.Score.ToString("0.###")</span>
                                        <span>@match.DeltaX,@match.DeltaY</span>
                                        <span>@match.MatchedAnchorRect.Width x @match.MatchedAnchorRect.Height</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (SelectedFrame() is { } selected)
                    {
                        <div class="sprite-settings-panel">
                            <div class="section-title">Frame: @selected.Name</div>
                            <div class="sprite-grid-controls">
                                <label><span>Offset X</span><input class="form-control form-control-sm" type="number" value="@selected.ContentOffsetX" @onchange='(e) => SetFrameOffsetAsync(selected, "x", e)' /></label>
                                <label><span>Offset Y</span><input class="form-control form-control-sm" type="number" value="@selected.ContentOffsetY" @onchange='(e) => SetFrameOffsetAsync(selected, "y", e)' /></label>
                                <label><span>Duration</span><input class="form-control form-control-sm" type="number" min="1" max="10000" value="@selected.DurationMs" @onchange="(e) => SetFrameDurationAsync(selected.Id, e)" /></label>
                            </div>
                            <div class="sprite-inspector-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="() => NudgeSelectedFrameAsync(-1, 0)">Left</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="() => NudgeSelectedFrameAsync(1, 0)">Right</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="() => NudgeSelectedFrameAsync(0, -1)">Up</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_busy" @onclick="() => NudgeSelectedFrameAsync(0, 1)">Down</button>
                            </div>
                            <div class="sprite-inspector-actions">
                                <label class="sprite-axis-toggle"><input type="checkbox" @bind="_showOnion" @bind:after="RenderCanvasAsync" /> Onion</label>
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled="@_busy" @onclick="() => DeleteFrameAsync(selected.Id)">Delete frame</button>
                            </div>
                        </div>
                    }
                }
                else if (_mode == SpriteMode.Sheet)
                {
                    <div class="sprite-settings-panel">
                        <div class="section-title">Sheet Settings</div>
                        <div class="sprite-grid-controls">
                            <label><span>Rows</span><input class="form-control form-control-sm" type="number" min="1" max="32" @bind="_rows" /></label>
                            <label><span>Columns</span><input class="form-control form-control-sm" type="number" min="0" max="64" @bind="_columns" /></label>
                            <label><span>Gutter</span><input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_gutter" /></label>
                            <label><span>Outer</span><input class="form-control form-control-sm" type="number" min="0" max="2048" @bind="_outerMargin" /></label>
                            <label><span>Ordering</span><select class="form-select form-select-sm" @bind="_ordering"><option value="rowMajor">Row major</option><option value="columnMajor">Column major</option></select></label>
                        </div>
                        <div class="sprite-inspector-actions">
                            <span class="sprite-inspector-hint">Use the Build button in the left rail to rebuild the current layout.</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="sprite-settings-panel">
                        <div class="section-title">Export</div>
                        <p class="sprite-inspector-hint">Produce final engine-ready output. Transparency and background removal are applied at this stage only.</p>
                    </div>
                }
            </aside>
        </div>

        <div class="sprite-agent-strip" role="status">
            <span class="sprite-agent-status">Agent idle</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Undo task - coming soon">Undo task</button>
        </div>

        @if (_mode != SpriteMode.Export)
        {
        <div class="sprite-bottom-strip">
            @if (_mode == SpriteMode.Source)
            {
                <div class="sprite-frame-strip-panel">
                    <div class="frame-list-head"><span>@_regions.Count region(s)</span></div>
                    <div class="sprite-frame-strip">
                        @foreach (var region in _regions.OrderBy(r => r.Order))
                        {
                            <button type="button" class="sprite-region-chip @(_selectedRegionIds.Contains(region.Id) ? "is-selected" : "")" @onclick="() => SelectRegionAsync(region.Id)">
                                <span>@region.Name</span>
                                <small>@region.Width x @region.Height</small>
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="sprite-frame-strip-panel">
                    <div class="frame-list-head"><span>@FrameCount() frame(s)</span></div>
                    <div class="sprite-frame-strip">
                        @if (_frameSet is { } set)
                        {
                            @foreach (var frame in set.Frames)
                            {
                                <div class="sprite-frame-card @(frame.Index == _selectedIndex ? "is-selected" : "")" draggable="true"
                                     @ondragstart="() => _dragFrameId = frame.Id"
                                     @ondragover:preventDefault
                                     @ondrop="() => DropFrameAsync(frame.Index)">
                                    <div class="sprite-frame-card-body">
                                        <button type="button" class="sprite-frame-name" title="@frame.Name" @onclick="() => SelectFrameAsync(frame.Index)">@frame.Name</button>
                                    </div>
                                    <div class="sprite-frame-image-row">
                                        <button type="button" class="sprite-frame-arrow is-left" title="Move earlier" disabled="@(frame.Index == 0 || _busy)" @onclick="() => ReorderFrameAsync(frame.Id, frame.Index - 1)">&lt;</button>
                                        <button type="button" class="frame-thumb" @onclick="() => SelectFrameAsync(frame.Index)">
                                            <img src="@FramePreviewUrl(frame.Id)" alt="@frame.Name" />
                                        </button>
                                        <button type="button" class="sprite-frame-arrow is-right" title="Move later" disabled="@(frame.Index >= set.FrameCount - 1 || _busy)" @onclick="() => ReorderFrameAsync(frame.Id, frame.Index + 1)">&gt;</button>
                                    </div>
                                    <button type="button" class="sprite-frame-onion @(frame.HideFromOnionSkin ? "is-hidden" : "")"
                                            title="@(frame.HideFromOnionSkin ? "Show in onion skin" : "Hide from onion skin")"
                                            disabled="@_busy"
                                            @onclick="() => ToggleFrameOnionSkinAsync(frame)">
                                        @(frame.HideFromOnionSkin ? "Eye off" : "Eye")
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>

            }
        </div>
        }
    </div>
</div>

@if (_editModalOpen)
{
    <div class="sprite-edit-modal-backdrop" role="presentation">
        <div class="sprite-edit-modal" role="dialog" aria-modal="true" aria-labelledby="sprite-edit-title">
            <div class="sprite-edit-modal-head">
                <div>
                    <h2 id="sprite-edit-title">@EditModalTitle()</h2>
                    <span>@EditModalSubtitle()</span>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CloseEditModalAsync">Close</button>
            </div>

            <div class="sprite-edit-modal-body">
                <div class="sprite-edit-canvas-wrap">
                    <canvas class="sprite-edit-canvas" @ref="_editCanvas" tabindex="0"></canvas>
                </div>

                <div class="sprite-edit-controls">
                    <div class="sprite-edit-tool-row" role="group" aria-label="Mask tools">
                        <button type="button" class="@EditToolButtonClass("mask")" disabled="@_editGenerating" @onclick='() => SetEditToolAsync("mask")'>Mask</button>
                        <button type="button" class="@EditToolButtonClass("erase")" disabled="@_editGenerating" @onclick='() => SetEditToolAsync("erase")'>Erase</button>
                        <button type="button" class="@EditToolButtonClass("pan")" disabled="@_editGenerating" @onclick='() => SetEditToolAsync("pan")'>Pan</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_editGenerating" @onclick="ClearEditMaskAsync">Clear</button>
                    </div>

                    <label>
                        <span>Brush</span>
                        <input class="form-range" type="range" min="4" max="128" @bind="_editBrushSize" @bind:after="UpdateEditBrushAsync" />
                    </label>

                    <label>
                        <span>Prompt</span>
                        <textarea class="form-control form-control-sm sprite-edit-prompt" rows="7" @bind="_editPrompt" @bind:event="oninput" @bind:after="PersistEditSessionAsync"></textarea>
                    </label>

                    <label>
                        <span>Candidates</span>
                        <input class="form-control form-control-sm" type="number" min="1" max="@ImageOptions.Value.MaxOutputs" @bind="_editCount" @bind:after="PersistEditSessionAsync" />
                    </label>

                    <button type="button" class="btn btn-sm btn-primary"
                            disabled="@(!CanGenerateEditCandidates())"
                            @onclick="GenerateEditCandidatesAsync">
                        @(_editGenerating ? "Generating..." : "Generate")
                    </button>

                    @if (!string.IsNullOrWhiteSpace(_editModalError))
                    {
                        <div class="sprite-error">@_editModalError</div>
                    }
                </div>
            </div>

            <div class="sprite-edit-results">
                @{
                    var editCandidateOutputs = EditCandidateOutputs();
                }
                <div class="sprite-edit-results-head">
                    <span>@EditResultsLabel()</span>
                    <div class="sprite-section-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!_editPreviewOverlayActive)" @onclick="() => ClearEditPreviewAsync()">Clear Preview</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(editCandidateOutputs.Count == 0)" @onclick="RejectEditCandidatesAsync">Reject</button>
                        <button type="button" class="btn btn-sm btn-primary" disabled="@(!CanAcceptEditCandidate())" @onclick="AcceptEditCandidateAsync">Accept</button>
                    </div>
                </div>
                <div class="sprite-edit-candidate-strip">
                    @if (editCandidateOutputs.Count == 0)
                    {
                        <div class="empty-state compact">No candidates.</div>
                    }
                    else
                    {
                        @foreach (var candidate in editCandidateOutputs)
                        {
                            <button type="button" class="sprite-edit-candidate @(EditCandidateClass(candidate))"
                                    disabled="@(string.IsNullOrWhiteSpace(candidate.ImageUrl))"
                                    @onclick="() => SelectEditCandidateOutputAsync(candidate)">
                                @if (string.IsNullOrWhiteSpace(candidate.ImageUrl))
                                {
                                    <div class="sprite-edit-candidate-placeholder">@candidate.StatusLabel</div>
                                }
                                else
                                {
                                    <img src="@candidate.ImageUrl" alt="@candidate.Label" />
                                }
                                <span>@candidate.Label</span>
                                <small>@candidate.StatusLabel</small>
                                @if (!string.IsNullOrWhiteSpace(candidate.Error))
                                {
                                    <strong>@candidate.Error</strong>
                                }
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public WorkbenchView Workbench { get; set; } = null!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [Parameter]
    public EventCallback<ArtAssetView> OnExportAsset { get; set; }

    [Parameter]
    public Guid? SourceAssetId { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSourceAssetChanged { get; set; }

    [Parameter]
    public EventCallback<WorkspaceSpritesVisibleState> OnVisibleStateChanged { get; set; }

    private static readonly SpriteMode[] SpriteModes = [SpriteMode.Source, SpriteMode.Frames, SpriteMode.Sheet, SpriteMode.Export];

    private IJSObjectReference? _module;
    private DotNetObjectReference<SpriteSheetWorkspace>? _dotNetRef;
    private ElementReference _sourceCanvas;
    private ElementReference _frameCanvas;
    private ElementReference _editCanvas;

    private SpriteMode _mode = SpriteMode.Source;
    private FrameSetView? _frameSet;
    private List<SourceRegionView> _regions = [];
    private readonly HashSet<Guid> _selectedRegionIds = [];
