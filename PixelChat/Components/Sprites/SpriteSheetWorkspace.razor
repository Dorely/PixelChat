    private string EditCandidateSetState()
    {
        if (_editGenerating)
            return "generating";
        var outputs = EditCandidateOutputs();
        if (outputs.Count > 0 && CanAcceptEditCandidate())
            return "candidate-selected";
        if (outputs.Count > 0 && _selectedEditOutputIndex is not null)
            return "partial-selected";
        if (outputs.Count > 0)
            return "candidates-pending";
        return "empty";
    }

