    private async Task RenderCanvasAsync()
    {
        if (_module is null || _dotNetRef is null)
            return;

        if (_mode == SpriteMode.Source && SourceImageUrl() is { } sourceUrl)
        {
            await _module.InvokeVoidAsync(
                "loadSourceCanvas",
                _sourceCanvas,
                _dotNetRef,
                sourceUrl,
                _regions.Select(CanvasRegion.From).ToList(),
                _selectedRegionIds.Select(id => id.ToString()).ToList(),
                _sourceTool);
        }
        else if (_mode == SpriteMode.Frames && SelectedFrame() is { } frame)
        {
            var previous = NeighborOnionFrame(-1);
            var next = NeighborOnionFrame(1);
            await _module.InvokeVoidAsync(
                "loadFrameCanvas",
                _frameCanvas,
                _dotNetRef,
                FrameContentUrl(frame.Id),
                CanvasFrame.From(frame),
                previous is null ? null : FramePreviewUrl(previous.Id),
                next is null ? null : FramePreviewUrl(next.Id),
                _frameTool,
                _showOnion,
                _anchorReferenceFrameId == frame.Id ? _anchorRect : null);
        }
    }

    private async Task RenderEditModalCanvasAsync()
    {
        if (!_editModalOpen || _module is null || _renderedEditCanvasLoadVersion == _editCanvasLoadVersion || _editImageUrl is null)
            return;

        var crop = _editCrop ?? SpriteEditCrop.SourceDefault(SelectedSourceArtAsset());
        await _module.InvokeVoidAsync(
            "loadEditCanvas",
            _editCanvas,
            _editImageUrl,
            _editMaskUrl,
            _editTool,
            _editBrushSize,
            crop.EditSourceWidth,
            crop.EditSourceHeight,
            crop.CropX,
            crop.CropY,
            crop.CropWidth,
            crop.CropHeight);
        _renderedEditCanvasLoadVersion = _editCanvasLoadVersion;
        if (_editPreviewOverlayActive && SelectedEditCandidateOutput()?.ImageUrl is { } overlayUrl)
            await SetEditPreviewOverlayAsync(overlayUrl);
    }

