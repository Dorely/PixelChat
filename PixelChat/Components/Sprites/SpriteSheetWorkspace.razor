    private async Task DeleteSelectedRegionsAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceId || _selectedRegionIds.Count == 0)
            return;
        _regions = _regions.Where(region => !_selectedRegionIds.Contains(region.Id)).ToList();
        _selectedRegionIds.Clear();
        await SaveRegionsAsync(sourceId);
    }

    private async Task RenameRegionAsync(Guid id, string? name)
    {
        if (SelectedSourceAssetId() is not Guid sourceId)
            return;
        _regions = _regions.Select(region => region.Id == id ? region with { Name = string.IsNullOrWhiteSpace(name) ? region.Name : name.Trim() } : region).ToList();
        await SaveRegionsAsync(sourceId);
    }

    private async Task UpdateSelectedRegionNumberAsync(Guid id, string field, ChangeEventArgs args)
    {
        if (SelectedSourceAssetId() is not Guid sourceId || !int.TryParse(args.Value?.ToString(), out var value))
            return;
        _regions = _regions.Select(region => region.Id == id
            ? field switch
            {
                "x" => region with { X = value },
                "y" => region with { Y = value },
                "w" => region with { Width = Math.Max(1, value) },
                "h" => region with { Height = Math.Max(1, value) },
                _ => region
            }
            : region).ToList();
        await SaveRegionsAsync(sourceId);
    }

    private async Task SaveRegionsAsync(Guid sourceId)
    {
        _regions = (await FrameSets.SaveSourceRegionsAsync(Workbench.Project.Id, new SaveSourceRegionsRequest(
            sourceId,
            _regions
                .OrderBy(region => region.Order)
                .Select((region, index) => new SourceRegionEditRequest(
                    region.Id,
                    region.Name,
                    region.X,
                    region.Y,
                    region.Width,
                    region.Height,
                    region.ShapePaths,
                    region.RegionType,
                    index))
                .ToList()))).ToList();
        _rev++;
        await PublishSpritesStateAsync();
        await RenderCanvasAsync();
    }

    private async Task ExportBuiltSheetAsync()
    {
        if (BuiltSheetAssetId() is not Guid assetId)
            return;
        await OnChanged.InvokeAsync();
        var asset = Workbench.Assets.FirstOrDefault(a => a.Id == assetId);
        if (asset is not null)
            await OnExportAsset.InvokeAsync(asset);
    }

    private async Task OpenSourceEditModalAsync()
    {
        if (SelectedSourceAssetId() is not Guid sourceAssetId)
            return;

        if (await OpenPendingEditSessionAsync())
            return;

        ResetEditModal();
        _editModalOpen = true;
        _editTargetKind = SpriteEditTargetKind.Source;
        _editTargetSourceAssetId = sourceAssetId;
        _editImageUrl = AssetFullUrl(sourceAssetId);
        _editCrop = SpriteEditCrop.SourceDefault(SelectedSourceArtAsset());
        _editCanvasLoadVersion++;
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenFrameEditModalAsync()
    {
        if (_frameSet is not { } set || SelectedFrame() is not { } frame || set.SourceAssetId is not Guid sourceAssetId)
            return;

        if (await OpenPendingEditSessionAsync())
            return;

        ResetEditModal();
        var padding = FrameEditPadding(frame);
        _editModalOpen = true;
        _editTargetKind = SpriteEditTargetKind.Frame;
        _editTargetSourceAssetId = sourceAssetId;
        _editTargetFrameSetId = set.Id;
        _editTargetFrameId = frame.Id;
        _editImageUrl = FramePreviewUrl(frame.Id);
        _editMaskUrl = frame.HasMask ? FrameMaskUrl(frame.Id) : null;
        _editCrop = new SpriteEditCrop(
            frame.LogicalWidth + (padding * 2),
            frame.LogicalHeight + (padding * 2),
            padding,
            padding,
            frame.LogicalWidth,
            frame.LogicalHeight);
        _editCanvasLoadVersion++;
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseEditModalAsync()
    {
        _editModalOpen = false;
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> OpenPendingEditSessionAsync()
    {
        if (_editSessionId is null)
            await LoadPendingEditSessionAsync();
        if (_editSessionId is null)
            return false;

        _editModalOpen = true;
        RefreshEditImageUrls();
        RefreshEditGeneratingState();
        _editCanvasLoadVersion++;
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
        await InvokeAsync(StateHasChanged);
        return true;
    }

    private async Task LoadPendingEditSessionAsync()
    {
        try
        {
            var session = await FrameSets.GetPendingSpriteEditSessionAsync(Workbench.Project.Id);
            if (session is null)
                return;

            if (session.TargetFrameSetId is Guid frameSetId && _frameSet?.Id != frameSetId)
            {
                var set = await FrameSets.GetFrameSetAsync(Workbench.Project.Id, frameSetId);
                ApplyFrameSet(set);
            }
            if (session.TargetSourceAssetId is Guid sourceAssetId && _appliedSourceAssetId != sourceAssetId)
                await SelectSourceAssetAsync(sourceAssetId, clearMismatchedFrameSet: false);

            ApplyEditSession(session);
            RefreshEditCandidatesFromWorkbench();
            RefreshEditGeneratingState();
            await PublishSpritesStateAsync();
        }
        catch (Exception ex)
        {
            _editModalError = ex.Message;
        }
    }

    private void ApplyEditSession(SpriteEditSessionView session)
    {
        _editSessionId = session.Id;
        _editModalOpen = session.ModalOpen;
        _editTargetKind = string.Equals(session.TargetKind, "frame", StringComparison.OrdinalIgnoreCase)
            ? SpriteEditTargetKind.Frame
            : SpriteEditTargetKind.Source;
        _editTargetSourceAssetId = session.TargetSourceAssetId;
        _editTargetFrameSetId = session.TargetFrameSetId;
        _editTargetFrameId = session.TargetFrameId;
        _editBatchId = session.BatchId;
        _editMaskId = session.MaskId;
        _selectedEditCandidateId = session.SelectedCandidateAssetId;
        _selectedEditOutputIndex = session.SelectedOutputIndex;
        _editPreviewOverlayActive = session.PreviewOverlayActive;
        _editPrompt = session.Prompt;
        _editCount = Math.Clamp(session.Count, 1, Math.Max(1, ImageOptions.Value.MaxOutputs));
        _editCrop = session.Crop is null
            ? null
            : new SpriteEditCrop(
                session.Crop.EditSourceWidth,
                session.Crop.EditSourceHeight,
                session.Crop.CropX,
                session.Crop.CropY,
                session.Crop.CropWidth,
                session.Crop.CropHeight);
        _editCandidateAssetIds = session.CandidateAssetIds.ToList();
        _editPersistedOutputStates = session.OutputStates.ToList();
        _observedEditTerminalOutputs = session.OutputStates
            .Where(state => IsTerminalGenerationOutputStatus(state.Status))
            .Select(state => state.OutputIndex)
            .ToHashSet();
        _editModalError = null;
        RefreshEditImageUrls();
        _editCanvasLoadVersion++;
        _renderedEditCanvasLoadVersion = -1;
    }

    private async Task SetEditToolAsync(string tool)
    {
        _editTool = tool;
        if (_module is not null && _editModalOpen)
            await _module.InvokeVoidAsync("setEditTool", _editCanvas, _editTool);
    }

    private async Task UpdateEditBrushAsync()
    {
        if (_module is not null && _editModalOpen)
            await _module.InvokeVoidAsync("setEditBrushSize", _editCanvas, _editBrushSize);
    }

    private async Task ClearEditMaskAsync()
    {
        if (_module is not null && _editModalOpen)
            await _module.InvokeVoidAsync("clearEditMask", _editCanvas);
        _editMaskId = null;
        await PersistEditSessionAsync();
    }

    private bool CanGenerateEditCandidates() =>
        _editModalOpen
        && !_editGenerating
        && _editBatchId is null
        && _editCandidateAssetIds.Count == 0
        && _module is not null
        && _editTargetSourceAssetId is not null
        && !string.IsNullOrWhiteSpace(_editPrompt)
        && !ImageRuntime.HasRunningBatch(Workbench.Project.Id);

    private async Task GenerateEditCandidatesAsync()
    {
        if (!CanGenerateEditCandidates() || _editTargetSourceAssetId is not Guid sourceAssetId || _module is null)
            return;

        _editModalError = null;
        _editGenerating = true;
        try
        {
            await ClearEditPreviewAsync(persist: false);
            var hasPaint = await _module.InvokeAsync<bool>("hasEditMaskPaint", _editCanvas);
            var sourceDataUrl = await _module.InvokeAsync<string>("exportEditSourcePng", _editCanvas);
            var maskDataUrl = hasPaint
                ? await _module.InvokeAsync<string>("exportEditMaskPng", _editCanvas)
                : null;
            var count = Math.Clamp(_editCount, 1, Math.Max(1, ImageOptions.Value.MaxOutputs));
            _editCount = count;
            var batch = await ImageRuntime.StartEditImageAsync(Workbench.Project.Id, new EditImageRequest(
                sourceAssetId,
                _editPrompt,
                "auto",
                count,
                "opaque",
                null,
                sourceDataUrl,
                maskDataUrl,
                [],
                SwitchToCompare: false));
            _editBatchId = batch.Id;
            _editMaskId = batch.InputMaskIds.FirstOrDefault() is Guid maskId && maskId != Guid.Empty ? maskId : null;
            _editCandidateAssetIds = [];
            _editPersistedOutputStates = Enumerable.Range(0, count)
                .Select(index => new GenerationOutputStateView(index, GenerationOutputStatus.Queued, Message: "Waiting for image request."))
                .ToList();
            _observedEditTerminalOutputs = [];
            await Workflow.SetWorkspaceModeAsync(Workbench.Project.Id, WorkspaceMode.Sprites);
            _generationRuntimeSnapshot = ImageRuntime.GetSnapshot();
            RefreshEditGeneratingState();
            await PersistEditSessionAsync();
            await PublishSpritesStateAsync();
        }
        catch (Exception ex)
        {
            _editModalError = ex.Message;
            _editGenerating = false;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SelectEditCandidateOutputAsync(SpriteEditCandidateOutput candidate)
    {
        if (string.IsNullOrWhiteSpace(candidate.ImageUrl))
            return;

        if (_selectedEditOutputIndex == candidate.OutputIndex && _editPreviewOverlayActive)
        {
            await ClearEditPreviewAsync();
            return;
        }

        _selectedEditOutputIndex = candidate.OutputIndex;
        _selectedEditCandidateId = candidate.AssetId;
        _editPreviewOverlayActive = true;
        await SetEditPreviewOverlayAsync(candidate.ImageUrl);
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
    }

    private async Task ClearEditPreviewAsync(bool persist = true)
    {
        _selectedEditOutputIndex = null;
        _selectedEditCandidateId = null;
        _editPreviewOverlayActive = false;
        await SetEditPreviewOverlayAsync(null);
        if (persist)
        {
            await PersistEditSessionAsync();
            await PublishSpritesStateAsync();
        }
    }

    private async Task RejectEditCandidatesAsync()
    {
        await ClearEditPreviewAsync(persist: false);
        _editCandidateAssetIds = [];
        _editPersistedOutputStates = [];
        _observedEditTerminalOutputs = [];
        _editBatchId = null;
        _editMaskId = null;
        _editModalError = null;
        _editGenerating = false;
        await PersistEditSessionAsync();
        await PublishSpritesStateAsync();
    }

    private async Task AcceptEditCandidateAsync()
    {
        var selected = SelectedEditCandidateOutput();
        if (selected?.AssetId is not Guid candidateId)
            return;

        _editModalError = null;
        _editGenerating = true;
        var sessionId = _editSessionId;
        try
        {
            if (_editTargetKind == SpriteEditTargetKind.Source)
            {
                await SelectSourceAssetAsync(candidateId, clearMismatchedFrameSet: true);
                if (sessionId is Guid id)
                    await FrameSets.CompleteSpriteEditSessionAsync(Workbench.Project.Id, id, "accepted");
                ResetEditModal();
                _status = "Applied edited source candidate.";
                await PublishSpritesStateAsync();
                if (OnSourceAssetChanged.HasDelegate)
                    await OnSourceAssetChanged.InvokeAsync(candidateId);
                else
                    await OnChanged.InvokeAsync();
            }
            else if (_editTargetFrameSetId is Guid frameSetId
                && _editTargetFrameId is Guid frameId
                && _editCrop is { } crop)
            {
                var updated = await FrameSets.ApplyFrameEditCandidateAsync(Workbench.Project.Id, new ApplyFrameEditCandidateRequest(
                    frameSetId,
                    frameId,
                    candidateId,
                    crop.EditSourceWidth,
                    crop.EditSourceHeight,
                    crop.CropX,
                    crop.CropY,
                    crop.CropWidth,
                    crop.CropHeight));
                ApplyFrameSet(updated);
                if (sessionId is Guid id)
                    await FrameSets.CompleteSpriteEditSessionAsync(Workbench.Project.Id, id, "accepted");
                ResetEditModal();
                _status = "Applied edited frame candidate.";
                await OnChanged.InvokeAsync();
                await PublishSpritesStateAsync();
                await RenderCanvasAsync();
            }
        }
        catch (Exception ex)
        {
            _editModalError = ex.Message;
        }
        finally
        {
            _editGenerating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

