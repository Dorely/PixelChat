    private static string NormalizeDraftBackground(string? background, string current) =>
        background?.Trim().ToLowerInvariant() switch
        {
            "transparent" => "removable",
            "removable" or "removablecolor" or "removable-color" or "chroma" or "chromakey" or "chroma-key" => "removable",
            "opaque" => "opaque",
            "auto" => "auto",
            _ => current,
        };

    private int NormalizeDraftCount(int? count, int current) =>
