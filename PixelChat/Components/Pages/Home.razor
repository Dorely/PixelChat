    private RenderFragment RenderRunCandidateCard(AssetAnimationRunCandidateView candidate) => __builder =>
    {
        var asset = candidate.OutputAssetId is Guid assetId ? _workbench!.Assets.FirstOrDefault(item => item.Id == assetId) : null;
        var batch = candidate.GenerationBatchId is Guid batchId ? _workbench!.Batches.FirstOrDefault(item => item.Id == batchId) : null;
        var outputIndex = asset?.BatchOutputIndex ?? Math.Max(0, candidate.CandidateIndex);
        var runtimeOutput = candidate.GenerationBatchId is Guid runtimeBatchId
            ? _generationRuntimeSnapshot.Batches
                .FirstOrDefault(item => item.BatchId == runtimeBatchId)
                ?.Outputs
                .FirstOrDefault(output => output.OutputIndex == outputIndex)
            : null;
        <article class="run-candidate-card">
            <div class="asset-title-row">
                <strong>@($"Candidate {candidate.CandidateIndex + 1}")</strong>
                <span class="@RunStatusClass(candidate.RawQaStatus)">@candidate.RawQaStatus</span>
            </div>
            @if (asset is not null)
            {
                <button type="button" class="run-candidate-thumb" @onclick="() => OpenAssetReviewPreview(asset)">
                    <LazyImage Src="@asset.PreviewImageUrl" Alt="@asset.Label" />
                </button>
                <p>@($"{candidate.State} / {FormatDimensions(asset)}")</p>
            }
            else if (!string.IsNullOrWhiteSpace(runtimeOutput?.PartialImageDataUrl))
            {
                <button type="button"
                        class="run-candidate-thumb"
                        @onclick="() => OpenGenerationPartialReviewPreview(new GenerationOutputStateView(outputIndex, runtimeOutput.Status, runtimeOutput.Attempt, runtimeOutput.Message), runtimeOutput.PartialImageDataUrl!, runtimeOutput.Status.ToString())">
                    <img src="@runtimeOutput.PartialImageDataUrl" alt="@($"Partial candidate {candidate.CandidateIndex + 1}")" />
                </button>
                <p>@runtimeOutput.Message</p>
            }
            else
            {
                <div class="run-candidate-pending">@((batch is null ? "No batch" : batch.Status.ToString()))</div>
            }
            <small>@(batch is null ? "No generation batch" : $"{batch.Label} / {batch.Status}")</small>
        </article>
    };

    private RenderFragment RenderRunBatchesSection() => __builder =>
    {
        var batches = _workbench!.Batches.Take(6).ToList();
        <section class="run-section">
            <div class="section-title">Generation Batches</div>
            @if (batches.Count == 0)
            {
                <div class="empty-context">No generation batches yet.</div>
            }
            else
            {
                <div class="run-generation-batches">
                    @foreach (var batch in batches)
                    {
                        var outputAssetsByIndex = batch.OutputAssetIds
                            .Select(assetId => _workbench.Assets.FirstOrDefault(asset => asset.Id == assetId))
                            .OfType<ArtAssetView>()
                            .Select((asset, fallbackIndex) => new
                            {
                                Asset = asset,
                                OutputIndex = asset.BatchOutputIndex ?? fallbackIndex,
                            })
                            .Where(item => item.OutputIndex >= 0 && item.OutputIndex < batch.Count)
                            .GroupBy(item => item.OutputIndex)
                            .ToDictionary(group => group.Key, group => group.OrderByDescending(item => item.Asset.CreatedAt).First().Asset);
                        var outputStatesByIndex = batch.OutputStates
                            .Where(state => state.OutputIndex >= 0 && state.OutputIndex < batch.Count)
                            .GroupBy(state => state.OutputIndex)
                            .ToDictionary(group => group.Key, group => group.Last());
                        var runtimeOutputsByIndex = _generationRuntimeSnapshot.Batches
                            .FirstOrDefault(item => item.BatchId == batch.Id)
                            ?.Outputs
                            .Where(output => output.OutputIndex >= 0 && output.OutputIndex < batch.Count)
                            .GroupBy(output => output.OutputIndex)
                            .ToDictionary(group => group.Key, group => group.Last())
                            ?? [];

                        <article class="run-batch-card">
                            <button type="button" class="run-batch-head" @onclick="() => SelectBatchAsync(batch.Id)">
                                <strong>@batch.Label</strong>
                                <span class="@RunStatusClass(batch.Status.ToString())">@batch.Status</span>
                                <small>@($"{batch.Count} image(s) / {batch.Size}")</small>
                            </button>
                            <div class="run-batch-output-grid">
                                @for (var index = 0; index < batch.Count; index++)
                                {
                                    if (outputAssetsByIndex.TryGetValue(index, out var asset))
                                    {
                                        <button type="button" class="run-batch-output" @onclick="() => OpenAssetReviewPreview(asset)">
                                            <LazyImage Src="@asset.PreviewImageUrl" Alt="@asset.Label" />
                                        </button>
                                    }
                                    else
                                    {
                                        var outputState = ResolveOutputState(index, outputStatesByIndex, runtimeOutputsByIndex);
                                        var runtimeOutput = runtimeOutputsByIndex.GetValueOrDefault(index);
                                        if (!string.IsNullOrWhiteSpace(runtimeOutput?.PartialImageDataUrl))
                                        {
                                            <button type="button"
                                                    class="run-batch-output"
                                                    @onclick="() => OpenGenerationPartialReviewPreview(outputState, runtimeOutput.PartialImageDataUrl!, outputState.Status.ToString())">
                                                <img src="@runtimeOutput.PartialImageDataUrl" alt="@($"Partial image {index + 1}")" />
                                            </button>
                                        }
                                        else
                                        {
                                            <div class="run-batch-output-placeholder">@outputState.Status</div>
                                        }
                                    }
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    };

    private RenderFragment RenderCompareWorkspace() => __builder =>
    {
        var activeBatch = _workbench!.ActiveBatch;
        var outputAssetsByIndex = new Dictionary<int, ArtAssetView>();
        var outputErrorsByIndex = new Dictionary<int, GenerationOutputErrorView>();
        var outputStatesByIndex = new Dictionary<int, GenerationOutputStateView>();
        var runtimeOutputsByIndex = new Dictionary<int, ImageGenerationOutputRuntimeView>();

        if (activeBatch is not null)
        {
            outputAssetsByIndex = activeBatch.OutputAssetIds
                .Select(assetId => _workbench.Assets.FirstOrDefault(asset => asset.Id == assetId))
                .OfType<ArtAssetView>()
                .Select((asset, fallbackIndex) => new
                {
                    Asset = asset,
                    OutputIndex = asset.BatchOutputIndex ?? fallbackIndex,
                })
                .Where(item => item.OutputIndex >= 0 && item.OutputIndex < activeBatch.Count)
                .GroupBy(item => item.OutputIndex)
                .ToDictionary(
                    group => group.Key,
                    group => group
                        .OrderByDescending(item => item.Asset.CreatedAt)
                        .First()
                        .Asset);
            outputErrorsByIndex = activeBatch.OutputErrors
                .Where(error => error.OutputIndex >= 0 && error.OutputIndex < activeBatch.Count)
                .GroupBy(error => error.OutputIndex)
                .ToDictionary(group => group.Key, group => group.Last());
            outputStatesByIndex = activeBatch.OutputStates
                .Where(state => state.OutputIndex >= 0 && state.OutputIndex < activeBatch.Count)
                .GroupBy(state => state.OutputIndex)
                .ToDictionary(group => group.Key, group => group.Last());
            runtimeOutputsByIndex = _generationRuntimeSnapshot.Batches
                .FirstOrDefault(batch => batch.BatchId == activeBatch.Id)
                ?.Outputs
                .Where(output => output.OutputIndex >= 0 && output.OutputIndex < activeBatch.Count)
                .GroupBy(output => output.OutputIndex)
                .ToDictionary(group => group.Key, group => group.Last())
                ?? [];
        }

        <div class="workspace-panel compare-panel">
            <div class="panel-head">
                <div>
                    <h1>Compare</h1>
                    <span>@(activeBatch?.Label ?? "No active batch")</span>
                </div>
                @if (activeBatch is not null)
                {
                    <div class="panel-actions">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => AddBatchToReviewAsync(activeBatch)">Add to Review</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => SetModeAsync(WorkspaceMode.Generate)">New Batch</button>
                    </div>
                }
            </div>

            @RenderCompareReviewSet()

            @if (activeBatch is null)
            {
                <div class="empty-state">Generate or edit images to create a batch.</div>
            }
            else
            {
                <div class="batch-summary">
                    <span>@activeBatch.Status</span>
                    <span>@activeBatch.ImageModel</span>
                    <span>@activeBatch.Size</span>
                    <span>@BackgroundLabel(activeBatch.Background)</span>
                    <span>@activeBatch.Count image(s)</span>
                </div>
                <p class="batch-prompt">@activeBatch.Prompt</p>
                @if (!string.IsNullOrWhiteSpace(activeBatch.Error))
                {
                    <div class="provider-warning">@activeBatch.Error</div>
                }

                <div class="compare-grid">
                    @for (var index = 0; index < activeBatch.Count; index++)
                    {
                        @if (outputAssetsByIndex.TryGetValue(index, out var asset))
                        {
                            @RenderAssetCard(asset, compact: false)
                        }
                        else if (outputErrorsByIndex.TryGetValue(index, out var outputError))
                        {
                            @RenderGenerationErrorCard(outputError)
                        }
                        else
                        {
                            var outputState = ResolveOutputState(index, outputStatesByIndex, runtimeOutputsByIndex);
                            if (IsFailedOutputStatus(outputState.Status))
                            {
                                @RenderGenerationErrorCard(OutputErrorFromState(outputState, runtimeOutputsByIndex.GetValueOrDefault(index)))
                            }
                            else if (outputErrorsByIndex.TryGetValue(index, out var persistedOutputError))
                            {
                                @RenderGenerationErrorCard(persistedOutputError)
                            }
                            else if (IsTerminalGenerationStatus(activeBatch.Status))
                            {
                                @RenderGenerationErrorCard(new GenerationOutputErrorView(index, MissingOutputError(activeBatch.Status)))
                            }
                            else
                            {
                                @RenderGenerationPlaceholderCard(outputState, runtimeOutputsByIndex.GetValueOrDefault(index))
                            }
                        }
                    }
                </div>
            }

            <div class="section-title">Recent Batches</div>
            <div class="batch-list">
                @foreach (var batch in _workbench.Batches.Take(8))
                {
                    <button type="button" class="batch-row @(batch.Id == _workbench.Project.ActiveBatchId ? "is-active" : "")"
                            @onclick="() => SelectBatchAsync(batch.Id)">
                        <span>@batch.Label</span>
                        <span>@batch.Status</span>
                    </button>
                }
            </div>
        </div>
    };

