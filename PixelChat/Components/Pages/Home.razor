    private void SetExportPreviewBackground(string background)
    {
        _exportPreviewBackground = background is "black" or "white" or "accent" ? background : "checkerboard";
    }

    private async Task RefreshPendingExportPreviewAsync()
    {
        var asset = _exportAsset;
        if (!_exportModalOpen || asset is null || string.IsNullOrWhiteSpace(_exportCurrentDataUrl))
            return;

        var method = NormalizeExportRemovalMethod(_exportRemovalMethod);
        ClearPendingExportStepPreview();

        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        if (IsNoExportStep(method))
        {
            _exportProcessing = false;
            _exportError = null;
            _exportPreviewDataUrl = _exportCurrentDataUrl;
            _exportStatus = "No processing selected. Download PNG will export the current preview.";
            CompleteExportOperation(operationCts);
            StateHasChanged();
            return;
        }

        if (IsLocalAiRemovalMethod(method))
        {
            _exportProcessing = false;
            _exportError = null;
            _exportPreviewDataUrl = _exportCurrentDataUrl;
            _exportStatus = "Local AI will process the current applied image when you click Apply step.";
            CompleteExportOperation(operationCts);
            StateHasChanged();
            return;
        }

        _exportProcessing = true;
        _exportError = null;
        _exportPreviewDataUrl = _exportCurrentDataUrl;
        _exportStatus = $"Previewing {ExportRemovalMethodLabel(method)}...";
        StateHasChanged();

        try
        {
            var output = await PrepareBrowserExportStepOutputAsync(_exportCurrentDataUrl, method, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            _exportPendingStepOutput = output;
            _exportPendingStepSourceHash = _exportCurrentImageSha256;
            _exportPendingStepSelection = method;
            _exportPendingStepOptionsHash = OptionsHashForExportStep(method);
            _exportPreviewDataUrl = output.DataUrl;
            _exportStatus = $"Previewing {ExportRemovalMethodLabel(method)}. Click Apply step to keep it.";
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportPreviewDataUrl = _exportCurrentDataUrl;
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }
    }

    private async Task<ExportStepOutput> PrepareBrowserExportStepOutputAsync(
        string inputDataUrl,
        string method,
        CancellationToken cancellationToken)
    {
        var normalized = NormalizeExportRemovalMethod(method);
        if (normalized == "key-color")
        {
            var cleaned = await PrepareKeyColorCleanupPreviewAsync(inputDataUrl, cleanKeyColor: true, cancellationToken);
            return new ExportStepOutput(
                cleaned.DataUrl,
                string.IsNullOrWhiteSpace(cleaned.Method) ? normalized : cleaned.Method,
                OptionsHashForExportStep(normalized),
                ModelName: string.Empty,
                ActualBackend: string.Empty,
                cleaned.Width,
                cleaned.Height);
        }

        var preview = await PrepareFastExportPreviewAsync(
            inputDataUrl,
            removeBackground: true,
            normalized,
            cleanKeyColor: false,
            cancellationToken);
        return new ExportStepOutput(
            preview.DataUrl,
            string.IsNullOrWhiteSpace(preview.Method) ? normalized : preview.Method,
            OptionsHashForExportStep(normalized),
            ModelName: string.Empty,
            ActualBackend: string.Empty,
            preview.Width,
            preview.Height);
    }

