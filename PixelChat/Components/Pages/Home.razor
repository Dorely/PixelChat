    public async ValueTask DisposeAsync()
    {
        ChatRuntime.StateChanged -= OnChatRuntimeStateChanged;
        ChatRuntime.WorkspaceChanged -= OnChatRuntimeWorkspaceChanged;
        ChatRuntime.FormDraftProposed -= OnChatRuntimeFormDraftProposed;
        ChatRuntime.TurnFinished -= OnChatRuntimeTurnFinished;
        ImageRuntime.StateChanged -= OnImageGenerationRuntimeStateChanged;
        if (_editorModule is not null)
        {
            try
            {
                if (_reviewPreviewEscapeBound)
                    await _editorModule.InvokeVoidAsync("unbindReviewPreviewEscape");
                await _editorModule.DisposeAsync();
            }
            catch { }
        }
        _maskAutosaveCts?.Cancel();
        _maskAutosaveCts?.Dispose();
        _exportProcessingCts?.Cancel();
        _exportProcessingCts?.Dispose();
        _exportTimerCts?.Cancel();
        _exportTimerCts?.Dispose();
        _maskAutosaveLock.Dispose();
        _dotNetRef?.Dispose();
    }
