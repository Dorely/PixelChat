    private IReadOnlyList<RecipeOutputGroup> RecipeOutputGroups(Guid? recipeId) =>
        RecipeOutputAssets(recipeId)
            .GroupBy(asset => asset.SourcePromptRecipeVersion)
            .OrderByDescending(group => group.Key.HasValue)
            .ThenByDescending(group => group.Key ?? 0)
            .Select(group => new RecipeOutputGroup(
                group.Key is int version ? $"v{version}" : "Earlier",
                group.Key,
                group.OrderByDescending(asset => asset.CreatedAt).ToList()))
            .ToList();

