@page "/"
@page "/chat"
@using PixelChat.Art
@using PixelChat.Chat
@using PixelChat.Llm
@using PixelChat.Models
@using Microsoft.Extensions.Options
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IAssistantChatService ChatService
@inject IWorkspaceChatRuntime ChatRuntime
@inject ILlmProviderService ProviderService
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<ImageGenerationOptions> ImageOptions
@inject IJSRuntime JS

<PageTitle>PixelChat</PageTitle>

@if (_workbench is null)
{
    <div class="workbench-loading">Loading PixelChat...</div>
}
else
{
    <div class="art-workbench">
        <header class="workbench-topbar">
            <div class="brand-block">
                <span class="brand-title">PixelChat</span>
                <span class="provider-pill @(_workbench.ImageProviderStatus.Connected ? "provider-pill-ok" : "provider-pill-warn")">
                    @_workbench.ImageProviderStatus.Message
                </span>
            </div>

            <div class="project-controls">
                <select class="form-select form-select-sm" value="@_projectIdText" @onchange="ChangeProjectAsync">
                    @foreach (var project in _workbench.Projects)
                    {
                        <option value="@project.Id">@project.Name</option>
                    }
                </select>
                <input class="form-control form-control-sm" placeholder="New project" @bind="_newProjectName" />
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="CreateProjectAsync">New</button>
            </div>

            <nav class="mode-tabs" aria-label="Workspace mode">
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Generate)" @onclick="() => SetModeAsync(WorkspaceMode.Generate)">Generate</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Compare)" @onclick="() => SetModeAsync(WorkspaceMode.Compare)">Compare</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Edit)" @onclick="() => SetModeAsync(WorkspaceMode.Edit)">Edit</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Recipes)" @onclick="() => SetModeAsync(WorkspaceMode.Recipes)">Recipes</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Assets)" @onclick="() => SetModeAsync(WorkspaceMode.Assets)">Assets</button>
            </nav>

            <a class="btn btn-sm btn-outline-secondary" href="settings/providers">Providers</a>
        </header>

        <section class="workbench-main">
            <aside class="chat-pane">
                <ChatSurface Title="Assistant"
                             Subtitle="@_providerSubtitle"
                             Loading="@_loadingChat"
                             Messages="@_messages"
                             Live="@_live"
                             Error="@_error"
                             Input="@_input"
                             InputChanged="OnInputChanged"
                             Placeholder="Ask for image analysis, recipe design, or a form draft..."
                             Running="@_running"
                             ComposerDisabled="@(_loadingChat || !_hasWorkingProvider)"
                             SendDisabled="@(_loadingChat || _running || !_hasWorkingProvider || string.IsNullOrWhiteSpace(_input))"
                             CssClass="workbench-chat"
                             ForceScrollKey="@_forceScrollKey"
                             ScrollKey="@_scrollKey"
                             ResetComposerKey="@_resetComposerKey"
                             OnSend="SendAsync"
                             OnStop="StopAsync"
                             OnClearError="ClearError">
                    <HeaderActions>
                        <button type="button" class="btn btn-sm btn-outline-danger" disabled="@_running" @onclick="ResetChatAsync">Reset</button>
                    </HeaderActions>
                    <BeforeComposer>
                        @RenderChatAttachments()
                    </BeforeComposer>
                </ChatSurface>
            </aside>

            <main class="workspace-center">
                @if (!string.IsNullOrWhiteSpace(_busyText))
                {
                    <div class="busy-strip">@_busyText</div>
                }

                @switch (_workbench.Project.ActiveWorkspaceMode)
                {
                    case WorkspaceMode.Generate:
                        @RenderGenerateWorkspace()
                        break;
                    case WorkspaceMode.Compare:
                        @RenderCompareWorkspace()
                        break;
                    case WorkspaceMode.Edit:
                        @RenderEditWorkspace()
                        break;
                    case WorkspaceMode.Recipes:
                        @RenderRecipesWorkspace()
                        break;
                    case WorkspaceMode.Assets:
                        @RenderAssetsWorkspace()
                        break;
                }
            </main>
        </section>
    </div>
}

@code {
    private readonly List<ChatRenderableMessage> _messages = [];
    private readonly HashSet<Guid> _draftReferenceAssetIds = [];
    private readonly HashSet<Guid> _recipeExampleAssetIds = [];
    private readonly SemaphoreSlim _generationFailureLock = new(1, 1);

    private WorkbenchView? _workbench;
    private ChatLiveTurn? _live;
    private IJSObjectReference? _editorModule;
    private ElementReference _editorCanvas;
    private Guid? _loadedEditorAssetId;
    private CancellationTokenSource? _generationCts;

    private string _projectIdText = string.Empty;
    private string _newProjectName = string.Empty;
    private string _input = string.Empty;
    private string? _error;
    private string _providerSubtitle = "Checking provider status...";
    private bool _loadingChat = true;
    private bool _running;
    private bool _hasWorkingProvider;
    private string? _pendingUserText;
    private Guid? _optimisticUserMessageId;
    private int _forceScrollKey;
    private int _scrollKey;
    private int _resetComposerKey;

    private string _busyText = string.Empty;
    private string _generatePrompt = string.Empty;
    private string _negativePrompt = string.Empty;
    private string _generateSize = "auto";
    private int _generateCount = 1;
    private string _selectedRecipeText = string.Empty;
    private Guid? _editingRecipeId;
    private string _recipeName = string.Empty;
    private string _recipeAssetType = "sprite";
    private string _recipePromptTemplate = string.Empty;
    private string _recipeStyleRules = string.Empty;
    private string _recipeAvoidRules = string.Empty;
    private string _recipeNotes = string.Empty;
    private string _recipePreferredSize = "auto";
    private string _editPrompt = string.Empty;
    private string _editSize = "auto";
    private int _editCount = 1;
    private int _brushSize = 36;
    private string _editorTool = "mask";
    private string _assetOrganization = "latest";
    private Guid? _editAssetId;
    private Guid? _assetDeleteCandidateId;
    private Guid? _runningGenerationBatchId;

    protected override async Task OnInitializedAsync()
    {
        ChatRuntime.StateChanged += OnChatRuntimeStateChanged;
        ChatRuntime.WorkspaceChanged += OnChatRuntimeWorkspaceChanged;
        ChatRuntime.FormDraftProposed += OnChatRuntimeFormDraftProposed;
        ChatRuntime.TurnFinished += OnChatRuntimeTurnFinished;
        await ReloadAllAsync();
        ApplyChatRuntimeSnapshot(ChatRuntime.GetSnapshot());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _editorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");

        await LoadEditorAssetIfNeededAsync();
    }

    private async Task ReloadAllAsync()
    {
        await ReloadWorkbenchAsync();
        await ReloadChatAsync();
        StateHasChanged();
    }

    private async Task ReloadWorkbenchAsync()
    {
        _workbench = await Workflow.GetWorkbenchAsync(ParseProjectIdOrNull(_projectIdText));
        _projectIdText = _workbench.Project.Id.ToString();
        _loadedEditorAssetId = _workbench.Project.ActiveWorkspaceMode == WorkspaceMode.Edit ? _loadedEditorAssetId : null;
        if (_editAssetId is Guid editAssetId && !_workbench.Assets.Any(asset => asset.Id == editAssetId))
            _editAssetId = null;
        _draftReferenceAssetIds.RemoveWhere(assetId => !_workbench.Assets.Any(asset => asset.Id == assetId));
        _recipeExampleAssetIds.RemoveWhere(assetId => !_workbench.Assets.Any(asset => asset.Id == assetId));
    }

    private async Task ReloadChatAsync()
    {
        if (_workbench is null)
            return;

        _loadingChat = true;
        _messages.Clear();

        var conversation = await ChatService.GetOrCreateAsync(_workbench.Project.Id);
        var persistedMessages = await ChatService.LoadMessagesAsync(conversation.Id);
        _messages.AddRange(ToRenderable(persistedMessages));

        var availability = await ProviderService.GetDefaultChatProviderAvailabilityAsync();
        _hasWorkingProvider = availability.IsAvailable && availability.Provider is not null;
        _providerSubtitle = _hasWorkingProvider
            ? $"{availability.Provider!.DisplayName ?? availability.Provider.Name} / {availability.Provider.ModelId}"
            : availability.Message;

        _loadingChat = false;
        _forceScrollKey++;
    }

    private async Task ChangeProjectAsync(ChangeEventArgs args)
    {
        _projectIdText = args.Value?.ToString() ?? string.Empty;
        _input = string.Empty;
        _loadedEditorAssetId = null;
        _draftReferenceAssetIds.Clear();
        _editAssetId = null;
        _assetDeleteCandidateId = null;
        ClearRecipeEditor();
        await ReloadAllAsync();
    }

    private async Task CreateProjectAsync()
    {
        var project = await Workflow.CreateProjectAsync(_newProjectName);
        _newProjectName = string.Empty;
        _projectIdText = project.Id.ToString();
        await ReloadAllAsync();
    }

    private async Task SetModeAsync(WorkspaceMode mode)
    {
        if (_workbench is null)
            return;

        await Workflow.SetWorkspaceModeAsync(_workbench.Project.Id, mode);
        await ReloadWorkbenchAsync();
    }

    private RenderFragment RenderGenerateWorkspace() => __builder =>
    {
        <div class="workspace-panel generate-panel">
            <div class="panel-head">
                <div>
                    <h1>Generate</h1>
                    <span>@ReferenceSummary()</span>
                </div>
                <button type="button" class="btn btn-primary"
                        disabled="@(!_workbench!.ImageProviderStatus.Connected || !CanGenerate)"
                        @onclick="GenerateAsync">
                    Generate
                </button>
            </div>

            @if (!_workbench.ImageProviderStatus.Connected)
            {
                <div class="provider-warning">@_workbench.ImageProviderStatus.Message</div>
            }

            <div class="form-stack">
                <label>
                    <span>Prompt</span>
                    <textarea class="form-control prompt-box" rows="8" @bind="_generatePrompt"></textarea>
                </label>

                <div class="form-grid">
                    <label>
                        <span>Recipe</span>
                        <select class="form-select" value="@_selectedRecipeText" @onchange="OnGenerateRecipeChanged">
                            <option value="">None</option>
                            @foreach (var recipe in _workbench.Recipes)
                            {
                                <option value="@recipe.Id">@recipe.Name</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Size</span>
                        <select class="form-select" @bind="_generateSize">
                            <option value="auto">Auto</option>
                            <option value="1024x1024">1024 x 1024</option>
                            <option value="1024x1536">1024 x 1536</option>
                            <option value="1536x1024">1536 x 1024</option>
                        </select>
                    </label>
                    <label>
                        <span>Count</span>
                        <input class="form-control" type="number" min="1" max="@ImageOptions.Value.MaxOutputs" @bind="_generateCount" />
                    </label>
                </div>

                <label>
                    <span>Avoid</span>
                    <textarea class="form-control" rows="3" @bind="_negativePrompt"></textarea>
                </label>

                @if (DraftReferenceAssets().Count > 0)
                {
                    <div class="draft-reference-list">
                        <span>Draft references</span>
                        @foreach (var asset in DraftReferenceAssets())
                        {
                            <button type="button" class="context-chip" @onclick="() => RemoveDraftReference(asset.Id)">
                                <span>Ref</span>
                                <strong>@asset.Label</strong>
                                <span>x</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    };

    private RenderFragment RenderCompareWorkspace() => __builder =>
    {
        var activeBatch = _workbench!.ActiveBatch;
        var outputAssets = activeBatch is null
            ? []
            : activeBatch.OutputAssetIds
                .Select(assetId => _workbench.Assets.FirstOrDefault(asset => asset.Id == assetId))
                .OfType<ArtAssetView>()
                .ToList();
        var outputErrors = activeBatch?.OutputErrors ?? [];
        var pendingCount = activeBatch is null ? 0 : Math.Max(0, activeBatch.Count - outputAssets.Count - outputErrors.Count);

        <div class="workspace-panel compare-panel">
            <div class="panel-head">
                <div>
                    <h1>Compare</h1>
                    <span>@(activeBatch?.Label ?? "No active batch")</span>
                </div>
                @if (activeBatch is not null)
                {
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => SetModeAsync(WorkspaceMode.Generate)">New Batch</button>
                }
            </div>

            @if (activeBatch is null)
            {
                <div class="empty-state">Generate or edit images to create a batch.</div>
            }
            else
            {
                <div class="batch-summary">
                    <span>@activeBatch.Status</span>
                    <span>@activeBatch.ImageModel</span>
                    <span>@activeBatch.Size</span>
                    <span>@activeBatch.Count image(s)</span>
                </div>
                <p class="batch-prompt">@activeBatch.Prompt</p>
                @if (!string.IsNullOrWhiteSpace(activeBatch.Error))
                {
                    <div class="provider-warning">@activeBatch.Error</div>
                }

                <div class="compare-grid">
                    @foreach (var asset in outputAssets)
                    {
                        @RenderAssetCard(asset, compact: false)
                    }
                    @foreach (var outputError in outputErrors)
                    {
                        @RenderGenerationErrorCard(outputError)
                    }
                    @for (var index = 0; index < pendingCount; index++)
                    {
                        @RenderGenerationPlaceholderCard(outputAssets.Count + outputErrors.Count + index)
                    }
                </div>
            }

            <div class="section-title">Recent Batches</div>
            <div class="batch-list">
                @foreach (var batch in _workbench.Batches.Take(8))
                {
                    <button type="button" class="batch-row @(batch.Id == _workbench.Project.ActiveBatchId ? "is-active" : "")"
                            @onclick="() => SelectBatchAsync(batch.Id)">
                        <span>@batch.Label</span>
                        <span>@batch.Status</span>
                    </button>
                }
            </div>
        </div>
    };

    private RenderFragment RenderEditWorkspace() => __builder =>
    {
        var asset = CurrentEditAsset();

        <div class="workspace-panel edit-panel">
            <div class="panel-head">
                <div>
                    <h1>Edit</h1>
                    <span>@(asset?.Label ?? "Select or import an asset")</span>
                </div>
                <InputFile OnChange="ImportAssetAsync" accept="image/png,image/jpeg" />
            </div>

            @if (asset is null)
            {
                <div class="empty-state">Import an image or choose Edit from an asset card.</div>
            }
            else
            {
                <div class="editor-layout">
                    <div class="editor-stage">
                        <canvas class="editor-canvas" @ref="_editorCanvas"></canvas>
                    </div>
                    <div class="editor-tools">
                        <div class="segmented">
                            <button type="button" class="@EditorToolClass("mask")" @onclick='() => SetEditorToolAsync("mask")'>Mask</button>
                            <button type="button" class="@EditorToolClass("erase")" @onclick='() => SetEditorToolAsync("erase")'>Erase</button>
                            <button type="button" class="@EditorToolClass("crop")" @onclick='() => SetEditorToolAsync("crop")'>Crop</button>
                        </div>
                        <label>
                            <span>Brush</span>
                            <input type="range" min="6" max="120" @bind="_brushSize" @bind:after="UpdateBrushAsync" />
                        </label>
                        <div class="tool-button-row">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearMaskAsync">Clear Mask</button>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="SaveMaskAsync">Save Mask</button>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="CropAsync">Crop</button>
                        </div>
                        <label>
                            <span>Edit prompt</span>
                            <textarea class="form-control" rows="5" @bind="_editPrompt"></textarea>
                        </label>
                        <div class="form-grid">
                            <label>
                                <span>Size</span>
                                <select class="form-select" @bind="_editSize">
                                    <option value="auto">Auto</option>
                                    <option value="1024x1024">1024 x 1024</option>
                                    <option value="1024x1536">1024 x 1536</option>
                                    <option value="1536x1024">1536 x 1024</option>
                                </select>
                            </label>
                            <label>
                                <span>Count</span>
                                <input class="form-control" type="number" min="1" max="@ImageOptions.Value.MaxOutputs" @bind="_editCount" />
                            </label>
                        </div>
                        <button type="button" class="btn btn-primary"
                                disabled="@(!_workbench!.ImageProviderStatus.Connected || string.IsNullOrWhiteSpace(_editPrompt))"
                                @onclick="EditImageAsync">
                            Send Masked Edit
                        </button>
                    </div>
                </div>
            }
        </div>
    };

    private RenderFragment RenderRecipesWorkspace() => __builder =>
    {
        var selectedRecipe = SelectedRecipeForEditor();
        var exampleAssets = RecipeExampleAssets().ToList();
        var outputAssets = RecipeOutputAssets(selectedRecipe?.Id ?? _editingRecipeId).ToList();
        var relatedBatches = RecipeBatches(selectedRecipe?.Id ?? _editingRecipeId).ToList();

        <div class="workspace-panel recipes-panel">
            <div class="panel-head">
                <div>
                    <h1>Recipes</h1>
                    <span>@_workbench!.Recipes.Count saved recipe(s)</span>
                </div>
                <button type="button" class="btn btn-outline-primary" @onclick="NewRecipeDraft">New Recipe</button>
            </div>

            <div class="recipes-layout">
                <section class="recipe-list-panel">
                    @if (_workbench.Recipes.Count == 0)
                    {
                        <div class="empty-state">No prompt recipes saved yet.</div>
                    }
                    else
                    {
                        <div class="recipe-list">
                            @foreach (var recipe in _workbench.Recipes)
                            {
                                <button type="button"
                                        class="recipe-row @(recipe.Id == _editingRecipeId ? "is-active" : "")"
                                        @onclick="() => LoadRecipeEditor(recipe)">
                                    <span>@recipe.Name</span>
                                    <small>@(string.IsNullOrWhiteSpace(recipe.AssetType) ? "Unspecified" : recipe.AssetType)</small>
                                </button>
                            }
                        </div>
                    }
                </section>

                <section class="recipe-detail-panel">
                    <div class="form-stack">
                        <div class="form-grid recipe-management-grid">
                            <label>
                                <span>Name</span>
                                <input class="form-control" @bind="_recipeName" />
                            </label>
                            <label>
                                <span>Asset Type</span>
                                <input class="form-control" @bind="_recipeAssetType" />
                            </label>
                            <label>
                                <span>Preferred Size</span>
                                <select class="form-select" @bind="_recipePreferredSize">
                                    <option value="auto">Auto</option>
                                    <option value="1024x1024">1024 x 1024</option>
                                    <option value="1024x1536">1024 x 1536</option>
                                    <option value="1536x1024">1536 x 1024</option>
                                </select>
                            </label>
                            <label class="recipe-template-field">
                                <span>Prompt Template</span>
                                <textarea class="form-control" rows="6" @bind="_recipePromptTemplate"></textarea>
                            </label>
                            <label>
                                <span>Style Rules</span>
                                <textarea class="form-control" rows="5" @bind="_recipeStyleRules"></textarea>
                            </label>
                            <label>
                                <span>Avoid Rules</span>
                                <textarea class="form-control" rows="5" @bind="_recipeAvoidRules"></textarea>
                            </label>
                            <label class="recipe-notes">
                                <span>Notes</span>
                                <textarea class="form-control" rows="4" @bind="_recipeNotes"></textarea>
                            </label>
                        </div>

                        <div class="recipe-action-row">
                            <button type="button" class="btn btn-primary" disabled="@(!CanSaveRecipe)" @onclick="SaveRecipeAsync">
                                @(_editingRecipeId is null ? "Save Recipe" : "Update Recipe")
                            </button>
                            <button type="button" class="btn btn-outline-secondary" disabled="@(_editingRecipeId is null)" @onclick="DuplicateRecipeAsync">Duplicate</button>
                            <button type="button" class="btn btn-outline-danger" disabled="@(_editingRecipeId is null)" @onclick="DeleteRecipeAsync">Delete</button>
                            @if (selectedRecipe is not null)
                            {
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => UseRecipeInGenerate(selectedRecipe)">Use in Generate</button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => AttachRecipeAsync(selectedRecipe)">Attach To Chat</button>
                            }
                        </div>
                    </div>

                    <div class="recipe-related-layout">
                        <section>
                            <div class="section-title">Example Images</div>
                            @if (_workbench.Assets.Count == 0)
                            {
                                <div class="empty-context">No assets available.</div>
                            }
                            else
                            {
                                <div class="recipe-example-picker">
                                    @foreach (var asset in _workbench.Assets.Take(24))
                                    {
                                        <label class="recipe-example-option @(IsRecipeExample(asset.Id) ? "is-selected" : "")">
                                            <input type="checkbox"
                                                   checked="@IsRecipeExample(asset.Id)"
                                                   @onchange="args => ToggleRecipeExample(asset.Id, args)" />
                                            <img src="@asset.PreviewDataUrl" alt="@asset.Label" />
                                            <span>@asset.Label</span>
                                        </label>
                                    }
                                </div>
                            }
                        </section>

                        <section>
                            <div class="section-title">Images Used By Recipe</div>
                            @if (exampleAssets.Count == 0)
                            {
                                <div class="empty-context">No example images selected.</div>
                            }
                            else
                            {
                                <div class="recipe-image-grid">
                                    @foreach (var asset in exampleAssets)
                                    {
                                        @RenderAssetCard(asset, compact: true)
                                    }
                                </div>
                            }
                        </section>

                        <section>
                            <div class="section-title">Generated Outputs</div>
                            @if (outputAssets.Count == 0)
                            {
                                <div class="empty-context">No generated or edited outputs linked to this recipe.</div>
                            }
                            else
                            {
                                <div class="recipe-image-grid">
                                    @foreach (var asset in outputAssets)
                                    {
                                        @RenderAssetCard(asset, compact: true)
                                    }
                                </div>
                            }
                        </section>

                        <section>
                            <div class="section-title">Recipe Batches</div>
                            @if (relatedBatches.Count == 0)
                            {
                                <div class="empty-context">No batches linked to this recipe.</div>
                            }
                            else
                            {
                                <div class="batch-list">
                                    @foreach (var batch in relatedBatches)
                                    {
                                        <button type="button" class="batch-row" @onclick="() => SelectBatchAsync(batch.Id)">
                                            <span>@batch.Label</span>
                                            <span>@batch.Status</span>
                                        </button>
                                    }
                                </div>
                            }
                        </section>
                    </div>
                </section>
            </div>
        </div>
    };

    private RenderFragment RenderChatAttachments() => __builder =>
    {
        if (_workbench!.Attachments.Count == 0)
            return;

        <div class="chat-attachment-bar">
            <div class="chat-attachment-head">
                <span>Attached to chat</span>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearContextAsync">Clear</button>
            </div>
            <div class="chat-attachment-list">
                @foreach (var attachment in _workbench.Attachments)
                {
                    var asset = AttachmentAsset(attachment);
                    var mask = AttachmentMask(attachment);
                    <span class="chat-attachment-chip">
                        @if (asset is not null)
                        {
                            <img src="@asset.PreviewDataUrl" alt="@asset.Label" />
                        }
                        else if (mask is not null)
                        {
                            <img src="@mask.PreviewDataUrl" alt="@mask.Label" />
                        }
                        <span>
                            <small>@AttachmentKindLabel(attachment)</small>
                            <strong>@attachment.Label</strong>
                        </span>
                        <button type="button" title="Remove" @onclick="() => RemoveContextAsync(attachment.Id)">x</button>
                    </span>
                }
            </div>
        </div>
    };

    private RenderFragment RenderAssetsWorkspace() => __builder =>
    {
        var latestAssets = AssetsByLatest().ToList();
        <div class="workspace-panel assets-panel">
            <div class="panel-head">
                <div>
                    <h1>Assets</h1>
                    <span>@_workbench!.Assets.Count asset(s)</span>
                </div>
                <div class="asset-filters">
                    <button type="button" class="@AssetOrganizationClass("latest")" @onclick='() => SetAssetOrganization("latest")'>Latest</button>
                    <button type="button" class="@AssetOrganizationClass("recipe")" @onclick='() => SetAssetOrganization("recipe")'>Recipe</button>
                </div>
            </div>

            @if (_workbench.Assets.Count == 0)
            {
                <div class="empty-state">No assets yet. Generate or import images to build the library.</div>
            }
            else if (_assetOrganization == "recipe")
            {
                <div class="asset-group-stack">
                    @foreach (var group in AssetRecipeGroups())
                    {
                        <section class="asset-group">
                            <div class="section-title">@group.Label</div>
                            <div class="asset-grid">
                                @foreach (var asset in group.Assets)
                                {
                                    @RenderAssetCard(asset, compact: false)
                                }
                            </div>
                        </section>
                    }
                </div>
            }
            else
            {
                <div class="asset-grid">
                    @foreach (var asset in latestAssets)
                    {
                        @RenderAssetCard(asset, compact: false)
                    }
                </div>
            }

            @RenderDeleteConfirmation()
        </div>
    };

    private RenderFragment RenderAssetCard(ArtAssetView asset, bool compact) => __builder =>
    {
        <article class="asset-card @(compact ? "asset-card-compact" : "")">
            <button type="button"
                    class="asset-favorite @(asset.IsFavorite ? "is-on" : "")"
                    title="Favorite"
                    aria-label="Favorite"
                    @onclick="() => MarkAssetAsync(asset.Id, !asset.IsFavorite)">
                &#9829;
            </button>
            <div class="asset-thumb">
                <img src="@asset.PreviewDataUrl" alt="@asset.Label" />
            </div>
            <div class="asset-card-body">
                <div class="asset-title-row">
                    <strong>@asset.Label</strong>
                    <span>@asset.Kind</span>
                </div>
                @if (!compact)
                {
                    <p>@(string.IsNullOrWhiteSpace(asset.Prompt) ? FormatDimensions(asset) : asset.Prompt)</p>
                }
                <div class="asset-actions">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AttachAssetAsync(asset)">Attach</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AddGenerationReferenceAsync(asset.Id)">Reference</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => EditAssetAsync(asset.Id)">Edit</button>
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => AskDeleteAsset(asset.Id)">Delete</button>
                    <a class="btn btn-sm btn-outline-primary" href="@asset.PreviewDataUrl" download="@asset.FileName">Export</a>
                </div>
            </div>
        </article>
    };

