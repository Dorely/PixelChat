    private async Task PersistMaskAutosaveAsync(Guid assetId, long version, CancellationToken cancellationToken)
    {
        await _maskAutosaveLock.WaitAsync(cancellationToken);
        try
        {
            var asset = CurrentEditAsset();
            if (!_maskAutosaveDirty
                || version != _maskAutosaveVersion
                || _workbench is null
                || asset is null
                || asset.Id != assetId
                || _editorModule is null)
            {
                return;
            }

            var maskDataUrl = await _editorModule.InvokeAsync<string>("exportMaskPng", _editorCanvas);
            cancellationToken.ThrowIfCancellationRequested();
            asset = CurrentEditAsset();
            if (version != _maskAutosaveVersion
                || _workbench is null
                || asset is null
                || asset.Id != assetId)
            {
                return;
            }

            await Workflow.UpsertAssetMaskAsync(
                _workbench.Project.Id,
                assetId,
                maskDataUrl,
                $"{asset.Label} mask",
                cancellationToken);
            if (version == _maskAutosaveVersion)
                _maskAutosaveDirty = false;
            await ReloadWorkbenchAsync();
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
        finally
        {
            _maskAutosaveLock.Release();
        }
    }

    private void CancelMaskAutosave()
    {
        _maskAutosaveVersion++;
        _maskAutosaveDirty = false;
        _maskAutosaveCts?.Cancel();
        _maskAutosaveCts = null;
    }

