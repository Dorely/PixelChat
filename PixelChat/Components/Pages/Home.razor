    [JSInvokable]
    public Task OnEditorMaskChanged()
    {
        ScheduleMaskAutosave();
        return Task.CompletedTask;
    }

    private void ScheduleMaskAutosave()
    {
        var asset = CurrentEditAsset();
        if (_workbench is null || asset is null || _editorModule is null)
            return;

        _maskAutosaveDirty = true;
        _maskAutosaveVersion++;
        _maskAutosaveCts?.Cancel();
        var cancellation = new CancellationTokenSource();
        _maskAutosaveCts = cancellation;
        var assetId = asset.Id;
        var version = _maskAutosaveVersion;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromMilliseconds(650), cancellation.Token);
                await PersistMaskAutosaveAsync(assetId, version, cancellation.Token);
            }
            catch (OperationCanceledException)
            {
            }
            finally
            {
                if (ReferenceEquals(_maskAutosaveCts, cancellation))
                    _maskAutosaveCts = null;
                cancellation.Dispose();
            }
        });
    }

    private async Task FlushMaskAutosaveAsync()
    {
        var asset = CurrentEditAsset();
        if (!_maskAutosaveDirty || _workbench is null || asset is null || _editorModule is null)
            return;

        _maskAutosaveCts?.Cancel();
        _maskAutosaveCts = null;
        var version = ++_maskAutosaveVersion;
        await PersistMaskAutosaveAsync(asset.Id, version, CancellationToken.None);
    }

    private async Task PersistMaskAutosaveAsync(Guid assetId, long version, CancellationToken cancellationToken)
    {
        await _maskAutosaveLock.WaitAsync(cancellationToken);
        try
        {
            var asset = CurrentEditAsset();
            if (!_maskAutosaveDirty
                || version != _maskAutosaveVersion
                || _workbench is null
                || asset is null
                || asset.Id != assetId
                || _editorModule is null)
            {
                return;
            }

            var maskDataUrl = await _editorModule.InvokeAsync<string>("exportMaskPng", _editorCanvas);
            cancellationToken.ThrowIfCancellationRequested();
            asset = CurrentEditAsset();
            if (version != _maskAutosaveVersion
                || _workbench is null
                || asset is null
                || asset.Id != assetId)
            {
                return;
            }

            await Workflow.UpsertAssetMaskAsync(
                _workbench.Project.Id,
                assetId,
                maskDataUrl,
                $"{asset.Label} mask",
                cancellationToken);
            if (version == _maskAutosaveVersion)
                _maskAutosaveDirty = false;
            await ReloadWorkbenchAsync();
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
        finally
        {
            _maskAutosaveLock.Release();
        }
    }

    private void CancelMaskAutosave()
    {
        _maskAutosaveVersion++;
        _maskAutosaveDirty = false;
        _maskAutosaveCts?.Cancel();
        _maskAutosaveCts = null;
    }

    private async Task ClearMaskAsync()
    {
        var asset = CurrentEditAsset();
        CancelMaskAutosave();
        try
        {
            if (_editorModule is not null)
                await _editorModule.InvokeVoidAsync("clearMask", _editorCanvas);
            if (_workbench is not null && asset is not null)
            {
                await Workflow.ClearAssetMaskAsync(_workbench.Project.Id, asset.Id);
                await ReloadWorkbenchAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task CropAsync()
    {
        var asset = CurrentEditAsset();
        if (_workbench is null || asset is null || _editorModule is null)
            return;

        await FlushMaskAutosaveAsync();
        await RunWorkflowAsync("Cropping asset...", async () =>
        {
            var cropDataUrl = await _editorModule.InvokeAsync<string?>("exportCropPng", _editorCanvas);
            if (string.IsNullOrWhiteSpace(cropDataUrl))
                throw new InvalidOperationException("Select a crop area first.");

            var crop = await Workflow.CreateCropAssetAsync(_workbench.Project.Id, new CropAssetRequest(
                asset.Id,
                cropDataUrl,
                $"{asset.Label} crop"));
            _editAssetId = crop.Id;
        });
    }

    private async Task EditImageAsync()
    {
        var asset = CurrentEditAsset();
        if (_workbench is null || asset is null || _editorModule is null || string.IsNullOrWhiteSpace(_editPrompt))
            return;

        await RunWorkflowAsync("Sending edit...", async () =>
        {
            var hasPaint = await _editorModule.InvokeAsync<bool>("hasMaskPaint", _editorCanvas);
            if (hasPaint)
                await FlushMaskAutosaveAsync();
            else
                CancelMaskAutosave();

            var sourceDataUrl = await _editorModule.InvokeAsync<string>("exportSourcePng", _editorCanvas);
            var maskDataUrl = hasPaint
                ? await _editorModule.InvokeAsync<string>("exportMaskPng", _editorCanvas)
                : null;
            await Workflow.EditImageAsync(_workbench.Project.Id, new EditImageRequest(
                asset.Id,
                _editPrompt,
                _editSize,
                _editCount,
                _editBackground,
                sourceDataUrl,
                maskDataUrl,
                CurrentReferenceAssetIds().Where(id => id != asset.Id).ToList()));
        });
    }

    private async Task AttachAssetAsync(ArtAssetView asset)
    {
        if (_workbench is null)
