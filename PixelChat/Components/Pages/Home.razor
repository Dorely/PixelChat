    private static GenerationOutputStateView ResolveOutputState(
        int outputIndex,
        IReadOnlyDictionary<int, GenerationOutputStateView> outputStatesByIndex,
        IReadOnlyDictionary<int, ImageGenerationOutputRuntimeView> runtimeOutputsByIndex)
    {
        if (runtimeOutputsByIndex.TryGetValue(outputIndex, out var runtimeOutput))
            return new GenerationOutputStateView(
                outputIndex,
                runtimeOutput.Status,
                runtimeOutput.Attempt,
                runtimeOutput.Message,
                runtimeOutput.Error,
                runtimeOutput.ErrorKind,
                runtimeOutput.RequestId,
                runtimeOutput.ResponseId,
                runtimeOutput.CallId,
                runtimeOutput.LastEventType,
                runtimeOutput.EventCount);

        return outputStatesByIndex.TryGetValue(outputIndex, out var outputState)
            ? outputState
            : new GenerationOutputStateView(outputIndex, GenerationOutputStatus.Queued, Message: "Waiting for earlier image requests.");
    }

    private static GenerationOutputErrorView OutputErrorFromState(
        GenerationOutputStateView outputState,
        ImageGenerationOutputRuntimeView? runtimeOutput)
    {
        var error = !string.IsNullOrWhiteSpace(runtimeOutput?.Error)
            ? runtimeOutput.Error
            : !string.IsNullOrWhiteSpace(outputState.Error)
                ? outputState.Error
                : "Image request failed.";
        return new GenerationOutputErrorView(
            outputState.OutputIndex,
            error,
            runtimeOutput?.ErrorKind ?? outputState.ErrorKind,
            runtimeOutput?.RequestId ?? outputState.RequestId,
            runtimeOutput?.ResponseId ?? outputState.ResponseId,
            runtimeOutput?.CallId ?? outputState.CallId,
            LastEventType: runtimeOutput?.LastEventType ?? outputState.LastEventType,
            EventCount: runtimeOutput?.EventCount ?? outputState.EventCount);
    }

    private static string GenerationErrorDetails(GenerationOutputErrorView outputError)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(outputError.ErrorKind))
            parts.Add(outputError.ErrorKind);
        if (!string.IsNullOrWhiteSpace(outputError.RequestId))
            parts.Add($"request {outputError.RequestId}");
        if (!string.IsNullOrWhiteSpace(outputError.ResponseId))
            parts.Add($"response {outputError.ResponseId}");
        if (!string.IsNullOrWhiteSpace(outputError.LastEventType))
            parts.Add($"last event {outputError.LastEventType}");
        if (outputError.EventCount > 0)
            parts.Add($"{outputError.EventCount} event(s)");
        return string.Join(" | ", parts);
    }

