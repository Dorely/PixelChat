    private async Task SaveRecipeAsync()
    {
        if (_workbench is null || !CanSaveRecipe)
            return;

        var request = new SavePromptRecipeRequest(
            _recipeName,
            RecipePromptForSave(),
            _recipeNotes);

        await RunWorkflowAsync(_editingRecipeId is null ? "Saving recipe..." : "Updating recipe...", async () =>
        {
            PromptRecipeView saved;
            if (_editingRecipeId is Guid recipeId)
            {
                saved = await Workflow.UpdatePromptRecipeAsync(_workbench.Project.Id, recipeId, new UpdatePromptRecipeRequest(
                    request.Name,
                    request.Prompt,
                    request.Notes));
            }
            else
            {
                saved = await Workflow.SavePromptRecipeAsync(_workbench.Project.Id, request);
            }

            saved = await Workflow.ReplacePromptRecipeAttachmentsAsync(_workbench.Project.Id, saved.Id, RecipeAttachmentRequests(_recipeAttachments));
            LoadRecipeEditor(saved);
            await LoadRecipeVersionsAsync(saved.Id);
        });
    }

    private void NewRecipeDraft()
    {
        ClearRecipeEditor();
        _recipePrompt = string.IsNullOrWhiteSpace(_generatePrompt) ? string.Empty : _generatePrompt;
        foreach (var assetId in CurrentReferenceAssetIds())
            _recipeAttachments.Add(new RecipeAttachmentDraft { AssetId = assetId, Role = RecipeAssetAttachmentRoles.Example });
        MarkRecipeEditorDirty();
    }

