    private void OnImageGenerationRuntimeStateChanged(object? sender, EventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            var previousSnapshot = _generationRuntimeSnapshot;
            var projectId = _workbench?.Project.Id;
            var previousRunningBatchIds = previousSnapshot.Batches
                .Where(batch => batch.IsRunning && (projectId is null || batch.ProjectId == projectId.Value))
                .Select(batch => batch.BatchId)
                .ToHashSet();
            var snapshot = ImageRuntime.GetSnapshot();
            _generationRuntimeSnapshot = snapshot;
            var completedBatch = previousRunningBatchIds.Any(batchId =>
                snapshot.Batches.Any(batch => batch.BatchId == batchId && !batch.IsRunning));
            var completedOutput = projectId is Guid currentProjectId
                && HasNewTerminalGenerationOutput(previousSnapshot, snapshot, currentProjectId);
            if (completedBatch || completedOutput)
                await ReloadWorkbenchAsync();
            StateHasChanged();
        });
    }

    private static bool HasNewTerminalGenerationOutput(
        ImageGenerationRuntimeSnapshot previousSnapshot,
        ImageGenerationRuntimeSnapshot snapshot,
        Guid projectId)
    {
        var previousStatuses = previousSnapshot.Batches
            .Where(batch => batch.ProjectId == projectId)
            .SelectMany(batch => batch.Outputs.Select(output => new
            {
                batch.BatchId,
                output.OutputIndex,
                output.Status,
            }))
            .ToDictionary(output => (output.BatchId, output.OutputIndex), output => output.Status);

        return snapshot.Batches
            .Where(batch => batch.ProjectId == projectId)
            .SelectMany(batch => batch.Outputs.Select(output => new
            {
                batch.BatchId,
                output.OutputIndex,
                output.Status,
            }))
            .Any(output =>
                IsTerminalGenerationOutputStatus(output.Status)
                && (!previousStatuses.TryGetValue((output.BatchId, output.OutputIndex), out var previous)
                    || !IsTerminalGenerationOutputStatus(previous)));
    }

    private static bool IsTerminalGenerationOutputStatus(GenerationOutputStatus status) =>
        status is GenerationOutputStatus.Succeeded or GenerationOutputStatus.Failed;

    private void ApplyChatRuntimeSnapshot(WorkspaceChatRuntimeSnapshot snapshot)
    {
        _running = snapshot.Running;
        _live = snapshot.Live;
        _pendingUserText = snapshot.PendingUserText;
        if (snapshot.TokenCount is not null || snapshot.Running)
            _tokenCount = snapshot.TokenCount;
        _error = snapshot.Error;
    }

    private static string FormatTokenCount(TokenContextEstimate estimate)
    {
        var prefix = estimate.IsExact ? string.Empty : "~";
        return $"{prefix}{estimate.TokenCount.ToString("N0", CultureInfo.InvariantCulture)} tokens";
    }

    private void CommitFinishedTurn(WorkspaceChatTurnFinished turn)
    {
        if (_workbench?.Project.Id != turn.ProjectId)
            return;

        ReconcileOptimisticUserMessage(turn.UserMessageId, turn.UserMessageVisuals);

        if (turn.AssistantMessageIds.Count > 0)
        {
            var assistantIds = turn.AssistantMessageIds.ToHashSet();
            _messages.RemoveAll(message => message.Role == ChatMessageRole.Assistant && assistantIds.Contains(message.Id));
        }

        var liveMessages = turn.Live.Messages
            .Where(message => message.Parts.Count > 0)
            .ToList();

        if (liveMessages.Count == 0)
        {
            if (turn.Status != ChatMessageStatus.Completed && turn.AssistantMessageIds.Count > 0)
            {
                _messages.Add(new ChatRenderableMessage(
                    turn.AssistantMessageIds[0],
                    ChatMessageRole.Assistant,
                    turn.Status,
                    []));
            }
        }
        else
        {
            for (var index = 0; index < liveMessages.Count; index++)
            {
                var status = index == liveMessages.Count - 1
                    ? turn.Status
                    : ChatMessageStatus.Completed;
                _messages.Add(new ChatRenderableMessage(
                    MessageIdForLiveMessage(turn.AssistantMessageIds, index),
                    ChatMessageRole.Assistant,
                    status,
                    CloneFinishedParts(liveMessages[index], status, turn.Error)));
            }
        }

        _running = false;
        _live = null;
        _pendingUserText = null;
        _error = turn.Error;
        _scrollKey++;
    }

    private void ReconcileOptimisticUserMessage(Guid? persistedUserMessageId, IReadOnlyList<ChatImageVisual> visuals)
    {
        if (_optimisticUserMessageId is not Guid optimisticUserMessageId)
            return;

        var messageIndex = _messages.FindIndex(message => message.Id == optimisticUserMessageId);
        if (messageIndex >= 0)
        {
            if (persistedUserMessageId is Guid userMessageId)
            {
                var parts = _messages[messageIndex].Parts.ToList();
                AppendVisualParts(parts, visuals);
                _messages[messageIndex] = _messages[messageIndex] with { Id = userMessageId, Parts = parts };
            }
            else
            {
                _messages.RemoveAt(messageIndex);
            }
        }

        _optimisticUserMessageId = null;
    }

    private static Guid MessageIdForLiveMessage(IReadOnlyList<Guid> messageIds, int index) =>
        index < messageIds.Count ? messageIds[index] : Guid.NewGuid();

    private static List<ChatMessagePart> CloneFinishedParts(
        ChatLiveMessage liveMessage,
        ChatMessageStatus status,
        string? error)
    {
        var parts = liveMessage.CloneParts();
        if (status is ChatMessageStatus.Failed or ChatMessageStatus.Cancelled)
            MarkIncompleteToolChips(parts, status, error);

        return parts;
    }

    private static void MarkIncompleteToolChips(
        IReadOnlyList<ChatMessagePart> parts,
        ChatMessageStatus status,
        string? error)
    {
        var fallbackError = !string.IsNullOrWhiteSpace(error)
            ? error
            : status == ChatMessageStatus.Cancelled ? "Cancelled." : "Tool call did not complete.";

        foreach (var chip in parts
            .OfType<ChatToolPart>()
            .Select(part => part.Chip)
            .Where(chip => !chip.Completed))
        {
            chip.Completed = true;
            chip.Error ??= fallbackError;
            chip.MarkArgumentsComplete();
        }
    }

    private static void AppendVisualParts(List<ChatMessagePart> parts, IReadOnlyList<ChatImageVisual> visuals)
    {
        foreach (var visual in visuals)
            parts.Add(new ChatImagePart(visual));
    }

    private async Task ApplyFormDraftAsync(AssistantFormDraft draft)
    {
        switch (draft.Target)
        {
            case AssistantFormDraftTarget.Generate:
                _generatePrompt = draft.Prompt ?? _generatePrompt;
                _negativePrompt = draft.NegativePrompt ?? _negativePrompt;
                _generateSize = NormalizeDraftSize(draft.Size, _generateSize);
                _generateBackground = NormalizeDraftBackground(draft.Background, _generateBackground);
                _generateCount = NormalizeDraftCount(draft.Count, _generateCount);
                _generateRecipeText = ValidRecipeId(draft.PromptRecipeId)?.ToString() ?? _generateRecipeText;
                _generateAnimationRecipeText = ValidAnimationRecipeId(draft.AnimationRecipeId)?.ToString() ?? _generateAnimationRecipeText;
                if (draft.ReferenceAssetIds is not null)
                    SetDraftReferences(draft.ReferenceAssetIds);
                await Workflow.SetWorkspaceModeAsync(_workbench!.Project.Id, WorkspaceMode.Generate);
                await ReloadWorkbenchAsync();
                break;

            case AssistantFormDraftTarget.Edit:
                _editPrompt = draft.Prompt ?? _editPrompt;
                _editSize = NormalizeDraftSize(draft.Size, _editSize);
                _editBackground = NormalizeDraftBackground(draft.Background, _editBackground);
                _editCount = NormalizeDraftCount(draft.Count, _editCount);
                _editRecipeText = ValidRecipeId(draft.PromptRecipeId)?.ToString() ?? _editRecipeText;
                await Workflow.SetWorkspaceModeAsync(_workbench!.Project.Id, WorkspaceMode.Edit);
                await ReloadWorkbenchAsync();
                break;

            case AssistantFormDraftTarget.Recipe:
                ClearRecipeEditor();
                _recipeName = draft.RecipeName ?? string.Empty;
                _recipePrompt = draft.Prompt ?? string.Empty;
                _recipeNotes = draft.Notes ?? string.Empty;
                _recipeEditorDirty = true;
                _recipeChangedExternally = false;
                _loadedRecipeSnapshot = string.Empty;
                await Workflow.SetWorkspaceModeAsync(_workbench!.Project.Id, WorkspaceMode.Recipes);
                await ReloadWorkbenchAsync();
                break;

        }
    }

