    private async Task SaveRecipeAsync()
    {
        if (_workbench is null || !CanSaveRecipe)
            return;

        var request = new SavePromptRecipeRequest(
            _recipeName,
            _recipeAssetType,
            RecipePromptTemplateForSave(),
            SplitLines(_recipeStyleRules),
            SplitLines(_recipeAvoidRules),
            _recipeExampleAssetIds.ToList(),
            "openai-account",
            string.Empty,
            _recipePreferredSize,
            _recipeNotes);

        await RunWorkflowAsync(_editingRecipeId is null ? "Saving recipe..." : "Updating recipe...", async () =>
        {
            if (_editingRecipeId is Guid recipeId)
            {
                var updated = await Workflow.UpdatePromptRecipeAsync(_workbench.Project.Id, recipeId, new UpdatePromptRecipeRequest(
                    request.Name,
                    request.AssetType,
                    request.PromptTemplate,
                    request.StyleRules,
                    request.AvoidRules,
                    request.ExampleAssetIds,
                    request.PreferredProvider,
                    request.PreferredModel,
                    request.PreferredSize,
                    request.Notes));
                LoadRecipeEditor(updated);
            }
            else
            {
                var created = await Workflow.SavePromptRecipeAsync(_workbench.Project.Id, request);
                LoadRecipeEditor(created);
            }
        });
    }

