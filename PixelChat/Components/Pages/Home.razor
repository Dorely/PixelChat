    private async Task EditImageAsync()
    {
        var asset = CurrentEditAsset();
        if (_workbench is null || asset is null || _editorModule is null || !CanEditImage)
            return;

        _busyText = "Starting edit...";
        _error = null;
        StateHasChanged();
        try
        {
            var hasPaint = await _editorModule.InvokeAsync<bool>("hasMaskPaint", _editorCanvas);
            if (hasPaint)
                await FlushMaskAutosaveAsync();
            else
                CancelMaskAutosave();

            var sourceDataUrl = await _editorModule.InvokeAsync<string>("exportSourcePng", _editorCanvas);
            var maskDataUrl = hasPaint
                ? await _editorModule.InvokeAsync<string>("exportMaskPng", _editorCanvas)
                : null;
            var projectId = _workbench.Project.Id;
            var batch = await ImageRuntime.StartEditImageAsync(projectId, new EditImageRequest(
                asset.Id,
                _editPrompt,
                _editSize,
                _editCount,
                _editBackground,
                SelectedEditRecipeIdOrNull(),
                sourceDataUrl,
                maskDataUrl,
                CurrentReferenceAssetIds().Where(id => id != asset.Id).ToList()));
            await ReloadWorkbenchAsync();
            Logger.LogDebug(
                "Image edit background batch scheduled: projectId={ProjectId}, batchId={BatchId}, sourceAssetId={SourceAssetId}, count={Count}, size={Size}, promptChars={PromptChars}, referenceImages={ReferenceImageCount}, hasMask={HasMask}",
                projectId,
                batch.Id,
                asset.Id,
                batch.Count,
                batch.Size,
                _editPrompt.Trim().Length,
                CurrentReferenceAssetIds().Count(id => id != asset.Id),
                hasPaint);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Image edit batch setup failed.");
            _error = ex.Message;
        }
        finally
        {
            _busyText = string.Empty;
            _loadedEditorAssetId = null;
            StateHasChanged();
        }
    }

