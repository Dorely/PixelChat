    private static List<ChatRenderableMessage> ToRenderable(IReadOnlyList<AssistantMessage> messages, Guid projectId)
    {
        var toolRowsByCallId = messages
            .Where(message => message.Role == AssistantMessageRole.Tool && !string.IsNullOrWhiteSpace(message.ToolCallId))
            .GroupBy(message => message.ToolCallId!, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.Last(), StringComparer.Ordinal);

        var renderable = new List<ChatRenderableMessage>(messages.Count);
        foreach (var message in messages)
        {
            if (message.Role is AssistantMessageRole.System or AssistantMessageRole.Tool)
                continue;

            renderable.Add(new ChatRenderableMessage(
                message.Id,
                ToChatRole(message.Role),
                ToChatStatus(message.Status),
                BuildMessageParts(message, toolRowsByCallId, projectId)));
        }

        return renderable;
    }

    private static List<ChatMessagePart> BuildMessageParts(
        AssistantMessage message,
        IReadOnlyDictionary<string, AssistantMessage> toolRowsByCallId,
        Guid projectId)
    {
        if (message.Role != AssistantMessageRole.Assistant)
        {
            var userParts = new List<ChatMessagePart>();
            if (!string.IsNullOrEmpty(message.Content))
                userParts.Add(new ChatTextPart(message.Content));
            AppendVisualParts(
                userParts,
                message.Visuals
                    .Where(visual => string.IsNullOrWhiteSpace(visual.ToolCallId))
                    .OrderBy(visual => visual.SortOrder)
                    .Select(visual => ToChatVisual(projectId, visual))
                    .ToList());
            return userParts;
        }

        var calls = ChatTranscriptHelpers.ReadPersistedCalls(message.ToolCallsJson);
        if (calls.Count == 0)
            return string.IsNullOrEmpty(message.Content) ? [] : [new ChatTextPart(message.Content)];

        var assistantParts = new List<ChatMessagePart>();
        var text = message.Content ?? string.Empty;
        var cursor = 0;
        foreach (var item in calls
            .Select((call, index) => new { Call = call, Index = index })
            .OrderBy(item => item.Call.TextOffset ?? int.MaxValue)
            .ThenBy(item => item.Index))
        {
            var offset = Math.Clamp(item.Call.TextOffset ?? text.Length, 0, text.Length);
            if (offset > cursor)
                assistantParts.Add(new ChatTextPart(text[cursor..offset]));

            assistantParts.Add(new ChatToolPart(BuildToolChip(item.Call, toolRowsByCallId, projectId)));
            cursor = Math.Max(cursor, offset);
        }

        if (cursor < text.Length)
            assistantParts.Add(new ChatTextPart(text[cursor..]));

        return assistantParts;
    }

    private static ChatToolChip BuildToolChip(
        ChatPersistedToolCall call,
        IReadOnlyDictionary<string, AssistantMessage> toolRowsByCallId,
        Guid projectId)
    {
        var chip = new ChatToolChip(call.CallId, call.Name, call.ArgumentsJson, argumentsComplete: true, call.ExplicitDisplayTitle);
        if (!toolRowsByCallId.TryGetValue(call.CallId, out var toolRow))
            return chip;

        chip.Completed = toolRow.Status != AssistantMessageStatus.Pending;
        chip.Result = toolRow.Content;
        if (toolRow.Status == AssistantMessageStatus.Failed)
        {
            chip.Error = string.IsNullOrWhiteSpace(toolRow.ErrorMessage)
                ? "Tool call failed."
                : toolRow.ErrorMessage;
        }

        chip.Visuals.AddRange(toolRow.Visuals
            .OrderBy(visual => visual.SortOrder)
            .Select(visual => ToChatVisual(projectId, visual)));

        return chip;
    }

    private static ChatImageVisual ToChatVisual(Guid projectId, AssistantMessageVisual visual) =>
        new(
            visual.Id,
            visual.Title,
            visual.Caption,
            ChatVisualPreviewImageUrl(projectId, visual),
            ChatVisualFullImageUrl(projectId, visual),
            visual.Width,
            visual.Height,
            visual.ToolCallId);

    private static string ChatVisualPreviewImageUrl(Guid projectId, AssistantMessageVisual visual) =>
        $"/media/projects/{projectId:D}/chat-visuals/{visual.Id:D}/preview{ChatVisualVersionQuery(visual)}";

    private static string ChatVisualFullImageUrl(Guid projectId, AssistantMessageVisual visual) =>
        $"/media/projects/{projectId:D}/chat-visuals/{visual.Id:D}/full{ChatVisualVersionQuery(visual)}";

    private static string ChatVisualVersionQuery(AssistantMessageVisual visual)
    {
        var createdAt = visual.CreatedAt.Kind == DateTimeKind.Utc
            ? visual.CreatedAt
            : DateTime.SpecifyKind(visual.CreatedAt, DateTimeKind.Utc);
        return $"?v={createdAt.Ticks.ToString(CultureInfo.InvariantCulture)}";
    }

    private static string ChatVisualSubtitle(ChatImageVisual visual)
    {
        if (visual.Width is int width && visual.Height is int height)
        {
            return string.IsNullOrWhiteSpace(visual.Caption)
                ? $"{width} x {height}"
                : $"{visual.Caption} - {width} x {height}";
        }

        return visual.Caption;
    }

