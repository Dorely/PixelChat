    private async Task OpenExportAsync(ArtAssetView asset)
    {
        if (_workbench is null)
            return;

        var refreshPreview = false;
        var version = ++_exportRequestVersion;
        var operationCts = BeginExportOperation();
        _exportModalOpen = true;
        _exportAsset = null;
        _exportProcessing = true;
        _exportLocalAiRunning = false;
        _exportLocalAiResultAvailable = false;
        _exportTolerance = 24;
        _exportRemovalMethod = "key-color";
        _exportLocalAiModel = DefaultLocalAiModel();
        _exportActualBackend = string.Empty;
        _exportOriginalDataUrl = string.Empty;
        _exportCurrentDataUrl = string.Empty;
        _exportCurrentImageSha256 = string.Empty;
        _exportPreviewBackground = "checkerboard";
        _exportAppliedMethod = string.Empty;
        _exportSpriteManifestAvailable = false;
        _exportCurrentWidth = asset.Width;
        _exportCurrentHeight = asset.Height;
        ClearPendingExportStepPreview();
        _exportSteps.Clear();
        _exportElapsed = TimeSpan.Zero;
        _exportStartedAt = null;
        _exportFileName = DefaultExportFileName(asset.FileName, asset.Label);
        _exportPreviewDataUrl = asset.PreviewImageUrl;
        _exportStatus = "Loading export asset...";
        _exportError = null;
        StateHasChanged();

        try
        {
            var exportAsset = await Workflow.GetAssetForExportAsync(_workbench.Project.Id, asset.Id);
            if (version != _exportRequestVersion)
                return;

            _exportAsset = exportAsset;
            _exportFileName = DefaultExportFileName(exportAsset.FileName, exportAsset.Label);
            _exportOriginalDataUrl = exportAsset.DataUrl;
            _exportCurrentDataUrl = exportAsset.DataUrl;
            _exportPreviewDataUrl = exportAsset.DataUrl;
            _exportCurrentImageSha256 = Sha256DataUrl(exportAsset.DataUrl);
            _exportCurrentWidth = exportAsset.Width;
            _exportCurrentHeight = exportAsset.Height;
            _exportSpriteManifestAvailable = await Workflow.BuildSpriteSheetManifestJsonAsync(
                _workbench.Project.Id,
                exportAsset.Id,
                _exportFileName,
                operationCts.Token) is not null;
            _exportStatus = "Loading applied export steps...";
            if (version != _exportRequestVersion)
                return;

            var cachedSteps = await Workflow.GetExportStepCacheAsync(_workbench.Project.Id, exportAsset.Id, operationCts.Token);
            if (version != _exportRequestVersion)
                return;

            ApplyExportStepStack(exportAsset, cachedSteps);
            _exportStatus = cachedSteps.Count > 0
                ? $"Restored {cachedSteps.Count.ToString("N0", CultureInfo.InvariantCulture)} applied export step(s)."
                : "Original image ready. Choose a step and click Apply step.";
            refreshPreview = true;
        }
        catch (OperationCanceledException)
        {
            if (version == _exportRequestVersion)
                _exportStatus = "Export cancelled.";
        }
        catch (Exception ex)
        {
            if (version == _exportRequestVersion)
            {
                _exportError = ex.Message;
                _exportStatus = string.Empty;
            }
        }
        finally
        {
            if (version == _exportRequestVersion)
            {
                _exportProcessing = false;
                CompleteExportOperation(operationCts);
                StateHasChanged();
            }
        }

        if (refreshPreview && version == _exportRequestVersion)
            await RefreshPendingExportPreviewAsync();
    }

    private async Task OnExportRemovalMethodChanged(ChangeEventArgs args)
    {
        if (_exportLocalAiRunning)
            CancelExportProcessing();

        _exportRemovalMethod = NormalizeExportRemovalMethod(args.Value?.ToString());
