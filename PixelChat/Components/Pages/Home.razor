    private RenderFragment RenderCompareReviewItem(CompareReviewSetItemView item) => __builder =>
    {
        if (item.Kind == CompareReviewItemKind.Asset && ReviewAsset(item) is { } asset)
        {
            @RenderReviewImageCard(
                item,
                "Asset",
                asset.PreviewImageUrl,
                asset.Label,
                FormatDimensions(asset),
                () => OpenImageReviewPreview(asset.Label, asset.FullImageUrl, FormatDimensions(asset)))
        }
        else if (item.Kind == CompareReviewItemKind.SpriteFrame && ReviewSpriteFrame(item) is { } frame)
        {
            @RenderReviewImageCard(
                item,
                "Frame",
                frame.PreviewImageUrl,
                frame.Label,
                $"{frame.PreviewWidth} x {frame.PreviewHeight}",
                () => OpenImageReviewPreview(frame.Label, frame.PreviewImageUrl, $"{frame.PreviewWidth} x {frame.PreviewHeight}"))
        }
        else if (item.Kind == CompareReviewItemKind.SpriteSheet && ReviewSpriteSheet(item) is { } sheet)
        {
            var sheetAsset = ReviewSpriteSheetAsset(sheet);
            if (sheetAsset is not null)
            {
                @RenderReviewImageCard(
                    item,
                    "Sprite Sheet",
                    sheetAsset.PreviewImageUrl,
                    sheet.Label,
                    $"{sheet.Frames.Count} frame(s) - {sheet.Fps} FPS",
                    () => OpenImageReviewPreview(sheet.Label, sheetAsset.FullImageUrl, FormatDimensions(sheetAsset)))
            }
            else
            {
                @RenderReviewMissingCard(item)
            }
        }
        else if (item.Kind == CompareReviewItemKind.SpriteAnimation && ReviewSpriteSheet(item) is { } animationSheet)
        {
            <article class="review-card" @key="item.Id">
                <button type="button" class="review-thumb review-animation-thumb" @onclick="() => OpenAnimationReviewPreview(animationSheet)">
                    <SpriteAnimationPreview Sheet="@animationSheet" CssClass="review-animation-canvas" Title="@item.Label" />
                </button>
                <div class="review-card-body">
                    <div class="asset-title-row">
                        <strong>@item.Label</strong>
                        <span>Animation</span>
                    </div>
                    <p>@($"{animationSheet.Frames.Count} frame(s) - {animationSheet.Fps} FPS")</p>
                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                    {
                        <p>@item.Notes</p>
                    }
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveReviewItemAsync(item.Id)">Remove</button>
                </div>
            </article>
        }
        else if (item.Kind == CompareReviewItemKind.GenerationBatch && ReviewBatch(item) is { } batch)
        {
            @RenderReviewBatchCard(item, batch)
        }
        else
        {
            @RenderReviewMissingCard(item)
        }
    };

