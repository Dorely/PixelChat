@page "/"
@page "/chat"
@using System.Globalization
@using System.Security.Cryptography
@using PixelChat.Art
@using PixelChat.Chat
@using PixelChat.Llm
@using PixelChat.Models
@using PixelChat.Tokens
@using Microsoft.Extensions.Options
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IArtWorkflowService Workflow
@inject IAssistantChatService ChatService
@inject IWorkspaceChatRuntime ChatRuntime
@inject IWorkspaceVisibleStateStore VisibleState
@inject IImageGenerationRuntime ImageRuntime
@inject IBackgroundRemovalService BackgroundRemoval
@inject ILlmProviderService ProviderService
@inject IOptions<ImageGenerationOptions> ImageOptions
@inject IOptions<BackgroundRemovalOptions> BackgroundRemovalOptions
@inject ILogger<Home> Logger
@inject IJSRuntime JS

<PageTitle>PixelChat</PageTitle>

@if (_workbench is null)
{
    <div class="workbench-loading">Loading PixelChat...</div>
}
else
{
    <div class="art-workbench">
        <header class="workbench-topbar">
            <div class="brand-block">
                <span class="brand-title">PixelChat</span>
                <span class="provider-pill @(_workbench.ImageProviderStatus.Connected ? "provider-pill-ok" : "provider-pill-warn")">
                    @_workbench.ImageProviderStatus.Message
                </span>
            </div>

            <div class="project-controls">
                <select class="form-select form-select-sm" value="@_projectIdText" @onchange="ChangeProjectAsync">
                    @foreach (var project in _workbench.Projects)
                    {
                        <option value="@project.Id">@project.Name</option>
                    }
                </select>
                <input class="form-control form-control-sm" placeholder="New project" @bind="_newProjectName" />
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="CreateProjectAsync">New</button>
            </div>

            <nav class="mode-tabs" aria-label="Workspace mode">
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Generate)" @onclick="() => SetModeAsync(WorkspaceMode.Generate)">Generate</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Runs)" @onclick="() => SetModeAsync(WorkspaceMode.Runs)">Runs</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Compare)" @onclick="() => SetModeAsync(WorkspaceMode.Compare)">Compare</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Edit)" @onclick="() => SetModeAsync(WorkspaceMode.Edit)">Edit</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Sprites)" @onclick="() => SetModeAsync(WorkspaceMode.Sprites)">Sprites</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Recipes)" @onclick="() => SetModeAsync(WorkspaceMode.Recipes)">Recipes</button>
                <button type="button" class="@ModeButtonClass(WorkspaceMode.Assets)" @onclick="() => SetModeAsync(WorkspaceMode.Assets)">Assets</button>
            </nav>

            <a class="btn btn-sm btn-outline-secondary" href="settings/providers">Providers</a>
        </header>

        <section class="workbench-main">
            <aside class="chat-pane">
                <ChatSurface Title="Assistant"
                             Subtitle="@ChatSubtitle"
                             Loading="@_loadingChat"
                             Messages="@_messages"
                             Live="@_live"
                             Error="@_error"
                             Input="@_input"
                             InputChanged="OnInputChanged"
                             Placeholder="Ask for image analysis, recipe design, or a form draft..."
                             Running="@_running"
                             ComposerDisabled="@(_loadingChat || !_hasWorkingProvider)"
                             SendDisabled="@(_loadingChat || _running || !_hasWorkingProvider || string.IsNullOrWhiteSpace(_input))"
                             CssClass="workbench-chat"
                             ForceScrollKey="@_forceScrollKey"
                             ScrollKey="@_scrollKey"
                             ResetComposerKey="@_resetComposerKey"
                             OnSend="SendAsync"
                             OnStop="StopAsync"
                             OnClearError="ClearError">
                    <HeaderActions>
                        <button type="button" class="btn btn-sm btn-outline-danger" disabled="@_running" @onclick="ResetChatAsync">Reset</button>
                    </HeaderActions>
                    <BeforeComposer>
                        @RenderChatAttachments()
                    </BeforeComposer>
                </ChatSurface>
            </aside>

            <main class="workspace-center">
                @if (!string.IsNullOrWhiteSpace(_busyText))
                {
                    <div class="busy-strip">@_busyText</div>
                }

                @switch (_activeWorkspaceMode)
                {
                    case WorkspaceMode.Generate:
                        @RenderGenerateWorkspace()
                        break;
                    case WorkspaceMode.Runs:
                        @RenderRunsWorkspace()
                        break;
                    case WorkspaceMode.Compare:
                        @RenderCompareWorkspace()
                        break;
                    case WorkspaceMode.Edit:
                        @RenderEditWorkspace()
                        break;
                    case WorkspaceMode.Sprites:
                        @RenderSpritesWorkspace()
                        break;
                    case WorkspaceMode.Recipes:
                        @RenderRecipesWorkspace()
                        break;
                    case WorkspaceMode.Assets:
                        @RenderAssetsWorkspace()
                        break;
                }
            </main>
        </section>

        @RenderExportModal()
        @RenderReviewPreviewModal()
    </div>
}

@code {
    private static readonly string[] DefaultLocalAiModels =
    [
        "birefnet-massive",
        "birefnet-general",
        "birefnet-dis",
        "birefnet-hrsod",
        "isnet-general-use",
        "isnet-anime",
    ];

    private readonly List<ChatRenderableMessage> _messages = [];
    private readonly HashSet<Guid> _draftReferenceAssetIds = [];
    private Guid? _recipeExampleAssetId;
    private WorkbenchView? _workbench;
    private ImageGenerationRuntimeSnapshot _generationRuntimeSnapshot = new([]);
    private WorkspaceMode _activeWorkspaceMode = WorkspaceMode.Generate;
    private Guid? _activeWorkspaceProjectId;
    private Guid? _selectedRunJobId;
    private int _workspaceModePersistRequestVersion;
    private int _workspaceModePersistCompleteVersion;
    private ChatLiveTurn? _live;
    private IJSObjectReference? _editorModule;
    private DotNetObjectReference<Home>? _dotNetRef;
    private ElementReference _editorCanvas;
    private Guid? _loadedEditorAssetId;
    private CancellationTokenSource? _maskAutosaveCts;
    private readonly SemaphoreSlim _maskAutosaveLock = new(1, 1);
    private long _maskAutosaveVersion;
    private bool _maskAutosaveDirty;

    private string _projectIdText = string.Empty;
    private string _newProjectName = string.Empty;
    private string _input = string.Empty;
    private string? _error;
    private string _providerSubtitle = "Checking provider status...";
    private TokenContextEstimate? _tokenCount;
    private bool _loadingChat = true;
    private bool _running;
    private bool _hasWorkingProvider;
    private string? _pendingUserText;
    private Guid? _optimisticUserMessageId;
    private int _forceScrollKey;
    private int _scrollKey;
    private int _resetComposerKey;

    private string ChatSubtitle => _tokenCount is null
        ? _providerSubtitle
        : $"{_providerSubtitle} - {FormatTokenCount(_tokenCount)}";

    private string _busyText = string.Empty;
    private string _generatePrompt = string.Empty;
    private string _negativePrompt = string.Empty;
    private string _generateSize = "auto";
    private string _generateBackground = "removable";
    private int _generateCount = 1;
    private string _generateRecipeText = string.Empty;
    private string _editRecipeText = string.Empty;
    private Guid? _editingRecipeId;
    private IReadOnlyList<PromptRecipeVersionView> _recipeVersions = [];
    private string _loadedRecipeSnapshot = string.Empty;
    private bool _recipeEditorDirty;
    private bool _recipeChangedExternally;
    private string _recipeName = string.Empty;
    private string _recipeAssetType = "sprite";
    private string _recipePromptTemplate = string.Empty;
    private string _recipeStyleRules = string.Empty;
    private string _recipeAvoidRules = string.Empty;
    private string _recipeNotes = string.Empty;
    private string _recipePreferredSize = "auto";
    private string _editPrompt = string.Empty;
    private string _editSize = "auto";
    private string _editBackground = "removable";
    private int _editCount = 1;
    private int _brushSize = 36;
    private string _editorTool = "mask";
    private string _assetOrganization = "latest";
    private Guid? _editAssetId;
    private Guid? _assetDeleteCandidateId;
    private ArtAssetExportView? _exportAsset;
    private readonly List<ExportStepCacheView> _exportSteps = [];
    private CancellationTokenSource? _exportProcessingCts;
    private CancellationTokenSource? _exportTimerCts;
    private bool _exportModalOpen;
    private bool _exportProcessing;
    private bool _exportLocalAiRunning;
    private bool _exportLocalAiResultAvailable;
    private int _exportTolerance = 24;
    private long _exportRequestVersion;
    private string _exportFileName = string.Empty;
    private string _exportRemovalMethod = "key-color";
    private string _exportLocalAiModel = "birefnet-massive";
    private string _exportActualBackend = string.Empty;
    private string _exportOriginalDataUrl = string.Empty;
    private string _exportCurrentDataUrl = string.Empty;
    private string _exportCurrentImageSha256 = string.Empty;
    private string _exportPreviewBackground = "checkerboard";
    private string _exportAppliedMethod = string.Empty;
    private string _exportPreviewDataUrl = string.Empty;
    private bool _exportSpriteManifestAvailable;
    private ExportStepOutput? _exportPendingStepOutput;
    private string _exportPendingStepSourceHash = string.Empty;
    private string _exportPendingStepSelection = string.Empty;
    private string _exportPendingStepOptionsHash = string.Empty;
    private string _exportStatus = string.Empty;
    private string? _exportError;
    private DateTime? _exportStartedAt;
    private TimeSpan _exportElapsed = TimeSpan.Zero;
    private int? _exportCurrentWidth;
    private int? _exportCurrentHeight;
    private ReviewPreviewState? _reviewPreview;
    private bool _reviewPreviewEscapeBound;

    protected override async Task OnInitializedAsync()
    {
        ChatRuntime.StateChanged += OnChatRuntimeStateChanged;
        ChatRuntime.WorkspaceChanged += OnChatRuntimeWorkspaceChanged;
        ChatRuntime.FormDraftProposed += OnChatRuntimeFormDraftProposed;
        ChatRuntime.TurnFinished += OnChatRuntimeTurnFinished;
        ImageRuntime.StateChanged += OnImageGenerationRuntimeStateChanged;
        _generationRuntimeSnapshot = ImageRuntime.GetSnapshot();
        await ReloadAllAsync();
        ApplyChatRuntimeSnapshot(ChatRuntime.GetSnapshot());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _editorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
        }

        await LoadEditorAssetIfNeededAsync();
        await BindReviewPreviewEscapeIfNeededAsync();
    }

    private async Task ReloadAllAsync()
    {
        await ReloadWorkbenchAsync();
        await ReloadChatAsync();
        StateHasChanged();
    }

    private async Task BindReviewPreviewEscapeIfNeededAsync()
    {
        if (_editorModule is null || _dotNetRef is null)
            return;

        if (_reviewPreview is not null && !_reviewPreviewEscapeBound)
        {
            await _editorModule.InvokeVoidAsync("bindReviewPreviewEscape", _dotNetRef);
            _reviewPreviewEscapeBound = true;
        }
        else if (_reviewPreview is null && _reviewPreviewEscapeBound)
        {
            await _editorModule.InvokeVoidAsync("unbindReviewPreviewEscape");
            _reviewPreviewEscapeBound = false;
        }
    }

    private async Task ReloadWorkbenchAsync()
    {
        _workbench = await Workflow.GetWorkbenchAsync(ParseProjectIdOrNull(_projectIdText));
        _projectIdText = _workbench.Project.Id.ToString();
        if (_activeWorkspaceProjectId != _workbench.Project.Id)
        {
            _activeWorkspaceProjectId = _workbench.Project.Id;
            _activeWorkspaceMode = _workbench.Project.ActiveWorkspaceMode;
            _workspaceModePersistRequestVersion = 0;
            _workspaceModePersistCompleteVersion = 0;
        }
        else if (_workspaceModePersistRequestVersion == _workspaceModePersistCompleteVersion)
        {
            _activeWorkspaceMode = _workbench.Project.ActiveWorkspaceMode;
        }

        _loadedEditorAssetId = _activeWorkspaceMode == WorkspaceMode.Edit ? _loadedEditorAssetId : null;
        if (_editAssetId is Guid editAssetId && !_workbench.Assets.Any(asset => asset.Id == editAssetId))
            _editAssetId = null;
        if (_exportAsset is { } exportAsset && !_workbench.Assets.Any(asset => asset.Id == exportAsset.Id))
            ResetExportModal();
        if (_selectedRunJobId is not Guid selectedRunJobId || !_workbench.AnimationRuns.Any(run => run.Id == selectedRunJobId))
            _selectedRunJobId = _workbench.AnimationRuns.FirstOrDefault()?.Id;
        _draftReferenceAssetIds.RemoveWhere(assetId => !_workbench.Assets.Any(asset => asset.Id == assetId));
        if (_recipeExampleAssetId is Guid recipeExampleAssetId && !_workbench.Assets.Any(asset => asset.Id == recipeExampleAssetId))
            _recipeExampleAssetId = null;
        await RefreshRecipeEditorAfterWorkbenchReloadAsync();
        PublishVisibleState();
    }

    private async Task ReloadChatAsync()
    {
        if (_workbench is null)
            return;

        _loadingChat = true;
        _messages.Clear();

        var conversation = await ChatService.GetOrCreateAsync(_workbench.Project.Id);
        if (!ChatRuntime.IsRunning)
            await ChatService.RecoverInterruptedToolCallsAsync(_workbench.Project.Id);
        var persistedMessages = await ChatService.LoadMessagesAsync(conversation.Id);
        _messages.AddRange(ToRenderable(persistedMessages));

        var availability = await ProviderService.GetDefaultChatProviderAvailabilityAsync();
        _hasWorkingProvider = availability.IsAvailable && availability.Provider is not null;
        _providerSubtitle = _hasWorkingProvider
            ? $"{availability.Provider!.DisplayName ?? availability.Provider.Name} / {availability.Provider.ModelId}"
            : availability.Message;
        _tokenCount = _hasWorkingProvider
            ? await ChatService.EstimateNextRequestTokensAsync(_workbench.Project.Id)
            : null;

        _loadingChat = false;
        _forceScrollKey++;
    }

    private async Task RefreshRecipeEditorAfterWorkbenchReloadAsync()
    {
        if (_workbench is null || _editingRecipeId is not Guid recipeId)
            return;

        var recipe = _workbench.Recipes.FirstOrDefault(item => item.Id == recipeId);
        if (recipe is null)
        {
            ClearRecipeEditor();
            return;
        }

        var currentSnapshot = RecipeSnapshot(recipe);
        if (_recipeEditorDirty)
        {
            if (!string.Equals(currentSnapshot, _loadedRecipeSnapshot, StringComparison.Ordinal))
                _recipeChangedExternally = true;
        }
        else if (!string.Equals(currentSnapshot, _loadedRecipeSnapshot, StringComparison.Ordinal))
        {
            LoadRecipeEditor(recipe);
        }

        await LoadRecipeVersionsAsync(recipeId);
    }

    private async Task ChangeProjectAsync(ChangeEventArgs args)
    {
        await FlushMaskAutosaveAsync();
        _projectIdText = args.Value?.ToString() ?? string.Empty;
        _input = string.Empty;
        _loadedEditorAssetId = null;
        _draftReferenceAssetIds.Clear();
        _selectedRunJobId = null;
        _editAssetId = null;
        _assetDeleteCandidateId = null;
        ResetExportModal();
        ClearRecipeEditor();
        await ReloadAllAsync();
    }

    private async Task CreateProjectAsync()
    {
        var project = await Workflow.CreateProjectAsync(_newProjectName);
        _newProjectName = string.Empty;
        _projectIdText = project.Id.ToString();
        await ReloadAllAsync();
    }

    private async Task SetModeAsync(WorkspaceMode mode)
    {
        if (_workbench is null)
            return;

        var capturedMask = _activeWorkspaceMode == WorkspaceMode.Edit && mode != WorkspaceMode.Edit
            ? await CaptureMaskAutosaveAsync()
            : null;

        _activeWorkspaceMode = mode;
        PublishVisibleState();
        StateHasChanged();

        if (capturedMask is not null)
            _ = InvokeAsync(() => PersistCapturedMaskAutosaveAsync(capturedMask));

        var projectId = _workbench.Project.Id;
        var version = ++_workspaceModePersistRequestVersion;
        _ = InvokeAsync(() => PersistWorkspaceModeAsync(projectId, mode, version));
    }

    private RenderFragment RenderGenerateWorkspace() => __builder =>
    {
        <div class="workspace-panel generate-panel">
            <div class="panel-head">
                <div>
                    <h1>Generate</h1>
                    <span>@ReferenceSummary()</span>
                </div>
                <button type="button" class="btn btn-primary"
                        disabled="@(!_workbench!.ImageProviderStatus.Connected || !CanGenerate)"
                        @onclick="GenerateAsync">
                    Generate
                </button>
            </div>

            @if (!_workbench.ImageProviderStatus.Connected)
            {
                <div class="provider-warning">@_workbench.ImageProviderStatus.Message</div>
            }

            <div class="form-stack">
                <label>
                    <span>Prompt</span>
                    <textarea class="form-control prompt-box" rows="8" @bind="_generatePrompt"></textarea>
                </label>

                <div class="form-grid">
                    <label>
                        <span>Recipe</span>
                        <select class="form-select" value="@_generateRecipeText" @onchange="OnGenerateRecipeChanged">
                            <option value="">None</option>
                            @foreach (var recipe in _workbench.Recipes)
                            {
                                <option value="@recipe.Id">@recipe.Name</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Size</span>
                        <select class="form-select" @bind="_generateSize">
                            <option value="auto">Auto</option>
                            <option value="1024x1024">1024 x 1024</option>
                            <option value="1024x1536">1024 x 1536</option>
                            <option value="1536x1024">1536 x 1024</option>
                        </select>
                    </label>
                    <label>
                        <span>Background</span>
                        <select class="form-select" @bind="_generateBackground">
                            <option value="removable">Removable color</option>
                            <option value="auto">Auto</option>
                            <option value="opaque">Opaque</option>
                        </select>
                    </label>
                    <label>
                        <span>Count</span>
                        <input class="form-control" type="number" min="1" max="@ImageOptions.Value.MaxOutputs" @bind="_generateCount" />
                    </label>
                </div>

                <label>
                    <span>Avoid</span>
                    <textarea class="form-control" rows="3" @bind="_negativePrompt"></textarea>
                </label>

                @if (DraftReferenceAssets().Count > 0)
                {
                    <div class="draft-reference-list">
                        <span class="draft-reference-title">Generation references</span>
                        @foreach (var asset in DraftReferenceAssets())
                        {
                            <span class="draft-reference-card">
                                <button type="button"
                                        class="draft-reference-thumb"
                                        title="@($"Preview {asset.Label}")"
                                        aria-label="@($"Preview {asset.Label}")"
                                        @onclick="() => OpenAssetReviewPreview(asset)">
                                    <LazyImage Src="@asset.PreviewImageUrl" Alt="@asset.Label" Width="56" Height="56" />
                                </button>
                                <span>
                                    <small>Reference</small>
                                    <strong>@asset.Label</strong>
                                </span>
                                <button type="button" class="draft-reference-remove" title="Remove" @onclick="() => RemoveDraftReference(asset.Id)">x</button>
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    };

    private RenderFragment RenderRunsWorkspace() => __builder =>
    {
        var runs = _workbench!.AnimationRuns
            .OrderByDescending(run => run.UpdatedAt)
            .ToList();
        var selectedRun = SelectedRun();

        <div class="workspace-panel runs-panel">
            <div class="panel-head">
                <div>
                    <h1>Runs</h1>
                    <span>@($"{runs.Count} animation job(s), {_workbench.Batches.Count} generation batch(es)")</span>
                </div>
                <div class="panel-actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => SetModeAsync(WorkspaceMode.Compare)">Compare</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => SetModeAsync(WorkspaceMode.Generate)">Generate</button>
                </div>
            </div>

            <div class="runs-layout">
                <aside class="runs-sidebar">
                    <div class="section-title">Animation Jobs</div>
                    @if (runs.Count == 0)
                    {
                        <div class="empty-context">No animation jobs yet.</div>
                    }
                    else
                    {
                        @foreach (var run in runs)
                        {
                            <button type="button"
                                    class="run-list-row @(run.Id == selectedRun?.Id ? "is-active" : "")"
                                    @onclick="() => SelectRun(run.Id)">
                                <span class="run-list-title">@run.AnimationKind</span>
                                <span class="@RunStatusClass(run.Status)">@run.Status</span>
                                <small>@($"{run.FrameCount} frames / {run.Fps} fps")</small>
                                @if (!string.IsNullOrWhiteSpace(run.LatestError))
                                {
                                    <small class="run-error-line">@run.LatestError</small>
                                }
                            </button>
                        }
                    }

                    <div class="section-title">Recent Batches</div>
                    <div class="run-batch-list">
                        @foreach (var batch in _workbench.Batches.Take(8))
                        {
                            <button type="button" class="batch-row @(batch.Id == _workbench.Project.ActiveBatchId ? "is-active" : "")"
                                    @onclick="() => SelectBatchAsync(batch.Id)">
                                <span>@batch.Label</span>
                                <span>@batch.Status</span>
                            </button>
                        }
                    </div>
                </aside>

                <section class="runs-detail">
                    @if (selectedRun is null)
                    {
                        <div class="empty-state">Start an animation job or generation batch to see run progress here.</div>
                        @RenderRunBatchesSection()
                    }
                    else
                    {
                        <div class="run-summary">
                            <div>
                                <div class="asset-title-row">
                                    <strong>@selectedRun.AnimationKind</strong>
                                    <span class="@RunStatusClass(selectedRun.Status)">@selectedRun.Status</span>
                                </div>
                                <p>@(string.IsNullOrWhiteSpace(selectedRun.PromptSummary) ? selectedRun.ProfileLabel : selectedRun.PromptSummary)</p>
                            </div>
                            <div class="run-stat-grid">
                                <span><strong>@selectedRun.RecommendedAction</strong><small>Next action</small></span>
                                <span><strong>@($"{selectedRun.GenerationRoundsUsed}/{selectedRun.MaxGenerationRounds}")</strong><small>Budget</small></span>
                                <span><strong>@($"{selectedRun.Columns}x{selectedRun.Rows}")</strong><small>Guide grid</small></span>
                                <span><strong>@selectedRun.TargetCellSize</strong><small>Export cells</small></span>
                                <span><strong>@(string.IsNullOrWhiteSpace(selectedRun.MotionClipId) ? selectedRun.GuideRenderer : selectedRun.MotionClipId)</strong><small>Guide source</small></span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(selectedRun.LatestError))
                        {
                            <div class="provider-warning">@selectedRun.LatestError</div>
                        }

                        @RenderRunArtifacts(selectedRun)

                        <section class="run-section">
                            <div class="section-title">Candidates</div>
                            @if (selectedRun.Candidates.Count == 0)
                            {
                                <div class="empty-context">No completed candidates yet. Running batches appear in Recent Batches while they are active.</div>
                            }
                            else
                            {
                                <div class="run-candidate-grid">
                                    @foreach (var candidate in selectedRun.Candidates)
                                    {
                                        @RenderRunCandidateCard(candidate)
                                    }
                                </div>
                            }
                        </section>

                        <section class="run-section">
                            <div class="section-title">Frames</div>
                            @if (selectedRun.Frames.Count == 0)
                            {
                                <div class="empty-context">No frame decisions have been recorded.</div>
                            }
                            else
                            {
                                <div class="run-frame-table">
                                    <div class="run-frame-header">
                                        <span>Frame</span>
                                        <span>Status</span>
                                        <span>Reason</span>
                                        <span>Source</span>
                                        <span>Attempts</span>
                                    </div>
                                    @foreach (var frame in selectedRun.Frames.OrderBy(frame => frame.Index))
                                    {
                                        var sourceAsset = frame.SourceAssetId is Guid sourceAssetId
                                            ? _workbench.Assets.FirstOrDefault(asset => asset.Id == sourceAssetId)
                                            : null;
                                        <div class="run-frame-row">
                                            <span>@frame.FrameNumber</span>
                                            <span class="@RunStatusClass(frame.Status)">@frame.Status</span>
                                            <span>@(string.IsNullOrWhiteSpace(frame.Reason) ? frame.RecommendedAction : frame.Reason)</span>
                                            <span>
                                                @if (sourceAsset is not null)
                                                {
                                                    <button type="button" class="run-thumb-button" @onclick="() => OpenAssetReviewPreview(sourceAsset)">
                                                        <LazyImage Src="@sourceAsset.PreviewImageUrl" Alt="@sourceAsset.Label" Width="40" Height="40" />
                                                    </button>
                                                }
                                                else
                                                {
                                                    <small>Candidate</small>
                                                }
                                            </span>
                                            <span>@frame.AttemptCount</span>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <section class="run-section">
                            <div class="section-title">Timeline</div>
                            @if (selectedRun.Events.Count == 0)
                            {
                                <div class="empty-context">No timeline entries yet.</div>
                            }
                            else
                            {
                                <div class="run-timeline">
                                    @foreach (var item in selectedRun.Events.OrderByDescending(item => item.CreatedAt))
                                    {
                                        <details class="run-event">
                                            <summary>
                                                <span class="@RunStatusClass(item.Severity)">@item.Severity</span>
                                                <strong>@item.EventType</strong>
                                                <span>@item.Summary</span>
                                                <small>@item.CreatedAt.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</small>
                                            </summary>
                                            @if (!string.IsNullOrWhiteSpace(item.PayloadJson) && item.PayloadJson != "{}")
                                            {
                                                <pre>@item.PayloadJson</pre>
                                            }
                                        </details>
                                    }
                                </div>
                            }
                        </section>

                        <details class="run-details">
                            <summary>Prompt and plan details</summary>
