    private RenderFragment RenderCompareReviewItem(CompareReviewSetItemView item) => __builder =>
    {
        if (item.Kind == CompareReviewItemKind.Asset && ReviewAsset(item) is { } asset)
        {
            @RenderReviewImageCard(
                item,
                "Asset",
                asset.PreviewImageUrl,
                asset.Label,
                FormatDimensions(asset),
                () => OpenImageReviewPreview(asset.Label, asset.FullImageUrl, FormatDimensions(asset)))
        }
        else if (item.Kind == CompareReviewItemKind.Frame)
        {
            var frameUrl = $"/media/projects/{_workbench!.Project.Id:D}/frame-set-frames/{item.RefId:D}/preview";
            @RenderReviewImageCard(
                item,
                "Frame",
                frameUrl,
                item.Label,
                string.Empty,
                () => OpenImageReviewPreview(item.Label, frameUrl, string.Empty))
        }
        else if ((item.Kind == CompareReviewItemKind.ArtRecipe || item.Kind == CompareReviewItemKind.AnimationRecipe)
            && ReviewRecipe(item) is { } recipe)
        {
            @RenderReviewRecipeCard(item, recipe)
        }
        else if (item.Kind == CompareReviewItemKind.Animation && _reviewFrameSets.TryGetValue(item.RefId, out var frameSet) && frameSet.FrameCount > 0)
        {
            <article class="review-card" @key="item.Id">
                <button type="button" class="review-thumb review-animation-thumb" @onclick="() => OpenAnimationReviewPreview(item.RefId)">
                    <SpriteAnimationPreview Frames="@FrameSetPreviewFrames(frameSet)" Fps="@FrameSetFps(frameSet)" Loop="true" PreviewKey="@($"{frameSet.Id:N}:{frameSet.FrameCount}")" CssClass="review-animation-canvas" Title="@item.Label" />
                </button>
                <div class="review-card-body">
                    <div class="asset-title-row">
                        <strong>@item.Label</strong>
                        <span>Animation</span>
                    </div>
                    <p>@($"{frameSet.FrameCount} frame(s) - {FrameSetFps(frameSet)} FPS")</p>
                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                    {
                        <p>@item.Notes</p>
                    }
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveReviewItemAsync(item.Id)">Remove</button>
                </div>
            </article>
        }
        else
        {
            @RenderReviewMissingCard(item)
        }
    };

    private (string Name, string Prompt, bool IsAnimation)? ReviewRecipe(CompareReviewSetItemView item)
    {
        if (item.Kind == CompareReviewItemKind.ArtRecipe
            && _workbench!.Recipes.FirstOrDefault(recipe => recipe.Id == item.RefId) is { } artRecipe)
        {
            return (artRecipe.Name, artRecipe.Prompt, false);
        }

        if (item.Kind == CompareReviewItemKind.AnimationRecipe
            && _workbench!.AnimationRecipes.FirstOrDefault(recipe => recipe.Id == item.RefId) is { } animationRecipe)
        {
            return (animationRecipe.Name, animationRecipe.Prompt, true);
        }

        return null;
    }

