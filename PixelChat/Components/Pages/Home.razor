            return;

        var validIds = _workbench.Assets.Select(asset => asset.Id).ToHashSet();
        foreach (var assetId in assetIds.Where(validIds.Contains).Take(Math.Max(1, ImageOptions.Value.MaxReferenceImages)))
            _draftReferenceAssetIds.Add(assetId);
