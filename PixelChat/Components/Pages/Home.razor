    private async Task GenerateAsync()
    {
        if (_workbench is null || string.IsNullOrWhiteSpace(_generatePrompt))
            return;

        _busyText = "Starting generation...";
        _error = null;
        StateHasChanged();
        try
        {
            var projectId = _workbench.Project.Id;
            var batch = await ImageRuntime.StartGenerateImagesAsync(projectId, new GenerateImagesRequest(
                _generatePrompt,
                _negativePrompt,
                _generateSize,
                _generateCount,
                _generateBackground,
                SelectedGenerateRecipeIdOrNull(),
                SelectedGenerateAnimationRecipeIdOrNull(),
                CurrentReferenceAssetIds(),
                _workbench.Project.ActiveBatchId));
            await ReloadWorkbenchAsync();
            Logger.LogDebug(
                "Image generation background batch scheduled: projectId={ProjectId}, batchId={BatchId}, count={Count}, size={Size}, promptChars={PromptChars}, referenceImages={ReferenceImageCount}",
                projectId,
                batch.Id,
                batch.Count,
                batch.Size,
                _generatePrompt.Trim().Length,
                CurrentReferenceAssetIds().Count);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Image generation batch setup failed.");
            _error = ex.Message;
        }
        finally
        {
            _busyText = string.Empty;
            StateHasChanged();
        }
    }

