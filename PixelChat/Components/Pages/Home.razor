    private static string RecipeAttachmentSummary(IReadOnlyList<RecipeAssetAttachmentView> attachments)
    {
        if (attachments.Count == 0)
            return "No attachments";

        var guideCount = attachments.Count(attachment => string.Equals(attachment.Role, RecipeAssetAttachmentRoles.Guide, StringComparison.OrdinalIgnoreCase));
        var exampleCount = attachments.Count(attachment => string.Equals(attachment.Role, RecipeAssetAttachmentRoles.Example, StringComparison.OrdinalIgnoreCase));
        var otherCount = attachments.Count - guideCount - exampleCount;
        var parts = new List<string>();
        if (exampleCount > 0)
            parts.Add($"{exampleCount} example(s)");
        if (guideCount > 0)
            parts.Add($"{guideCount} guide(s)");
        if (otherCount > 0)
            parts.Add($"{otherCount} other");
        return string.Join(", ", parts);
    }

