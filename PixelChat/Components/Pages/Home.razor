    private RenderFragment RenderGenerationPlaceholderCard(GenerationOutputStateView outputState, ImageGenerationOutputRuntimeView? runtimeOutput) => __builder =>
    {
        var status = runtimeOutput?.Status ?? outputState.Status;
        var isGenerating = status is GenerationOutputStatus.Running or GenerationOutputStatus.Generating;
        var label = status switch
        {
            GenerationOutputStatus.Generating => "Generating",
            GenerationOutputStatus.Running => "Running",
            _ => "Queued",
        };
        var message = !string.IsNullOrWhiteSpace(runtimeOutput?.Message)
            ? runtimeOutput.Message
            : !string.IsNullOrWhiteSpace(outputState.Message)
                ? outputState.Message
                : status == GenerationOutputStatus.Queued
                    ? "Waiting for earlier image requests."
                    : "Waiting for the image request to complete.";
        var partialImageDataUrl = runtimeOutput?.PartialImageDataUrl;
        <article class="asset-card generation-placeholder-card">
            @if (!string.IsNullOrWhiteSpace(partialImageDataUrl))
            {
                <button type="button"
                        class="generation-partial-frame"
                        title="@($"Preview partial image {LabelForIndex(outputState.OutputIndex)}")"
                        aria-label="@($"Preview partial image {LabelForIndex(outputState.OutputIndex)}")"
                        @onclick="() => OpenGenerationPartialReviewPreview(outputState, partialImageDataUrl, label)">
                    <img src="@partialImageDataUrl" alt="@($"Partial preview for Image {LabelForIndex(outputState.OutputIndex)}")" />
                    @if (isGenerating)
                    {
                        <div class="generation-partial-spinner" aria-hidden="true"></div>
                    }
                </button>
            }
            else if (isGenerating)
            {
                <div class="generation-spinner" aria-hidden="true"></div>
            }
            else
            {
                <div class="generation-queued-mark" aria-hidden="true">...</div>
            }
            <div class="asset-card-body">
                <div class="asset-title-row">
                    <strong>Image @LabelForIndex(outputState.OutputIndex)</strong>
                    <span>@label</span>
                </div>
                <p>@message</p>
            </div>
        </article>
    };

