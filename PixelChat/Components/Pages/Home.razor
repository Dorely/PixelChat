    private static List<ChatRenderableMessage> ToRenderable(IReadOnlyList<AssistantMessage> messages)
    {
        var toolRowsByCallId = messages
            .Where(message => message.Role == AssistantMessageRole.Tool && !string.IsNullOrWhiteSpace(message.ToolCallId))
            .GroupBy(message => message.ToolCallId!, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.Last(), StringComparer.Ordinal);

        var renderable = new List<ChatRenderableMessage>(messages.Count);
        foreach (var message in messages)
        {
            if (message.Role is AssistantMessageRole.System or AssistantMessageRole.Tool)
                continue;

            renderable.Add(new ChatRenderableMessage(
                message.Id,
                ToChatRole(message.Role),
                ToChatStatus(message.Status),
                BuildMessageParts(message, toolRowsByCallId)));
        }

        return renderable;
    }

    private static List<ChatMessagePart> BuildMessageParts(
        AssistantMessage message,
        IReadOnlyDictionary<string, AssistantMessage> toolRowsByCallId)
    {
        if (message.Role != AssistantMessageRole.Assistant)
            return string.IsNullOrEmpty(message.Content) ? [] : [new ChatTextPart(message.Content)];

        var calls = ChatTranscriptHelpers.ReadPersistedCalls(message.ToolCallsJson);
        if (calls.Count == 0)
            return string.IsNullOrEmpty(message.Content) ? [] : [new ChatTextPart(message.Content)];

        var parts = new List<ChatMessagePart>();
        var text = message.Content ?? string.Empty;
        var cursor = 0;
        foreach (var item in calls
            .Select((call, index) => new { Call = call, Index = index })
            .OrderBy(item => item.Call.TextOffset ?? int.MaxValue)
            .ThenBy(item => item.Index))
        {
            var offset = Math.Clamp(item.Call.TextOffset ?? text.Length, 0, text.Length);
            if (offset > cursor)
                parts.Add(new ChatTextPart(text[cursor..offset]));

            parts.Add(new ChatToolPart(BuildToolChip(item.Call, toolRowsByCallId)));
            cursor = Math.Max(cursor, offset);
        }

        if (cursor < text.Length)
            parts.Add(new ChatTextPart(text[cursor..]));

        return parts;
    }

    private static ChatToolChip BuildToolChip(
        ChatPersistedToolCall call,
        IReadOnlyDictionary<string, AssistantMessage> toolRowsByCallId)
    {
        var chip = new ChatToolChip(call.CallId, call.Name, call.ArgumentsJson, argumentsComplete: true);
        if (!toolRowsByCallId.TryGetValue(call.CallId, out var toolRow))
            return chip;

        chip.Completed = toolRow.Status != AssistantMessageStatus.Pending;
        chip.Result = toolRow.Content;
        if (toolRow.Status == AssistantMessageStatus.Failed)
        {
            chip.Error = string.IsNullOrWhiteSpace(toolRow.ErrorMessage)
                ? "Tool call failed."
                : toolRow.ErrorMessage;
        }

        return chip;
    }

    private static ChatMessageRole ToChatRole(AssistantMessageRole role) =>
        role == AssistantMessageRole.User ? ChatMessageRole.User : ChatMessageRole.Assistant;

    private static ChatMessageStatus ToChatStatus(AssistantMessageStatus status) => status switch
    {
        AssistantMessageStatus.Failed => ChatMessageStatus.Failed,
        AssistantMessageStatus.Cancelled => ChatMessageStatus.Cancelled,
        AssistantMessageStatus.Pending => ChatMessageStatus.Pending,
        _ => ChatMessageStatus.Completed
    };

