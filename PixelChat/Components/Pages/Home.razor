    private async Task SendAsync()
    {
        if (_workbench is null || _running || string.IsNullOrWhiteSpace(_input))
            return;

        PublishVisibleState();
        var text = _input.Trim();
        _input = string.Empty;
        _resetComposerKey++;
        _error = null;
        _pendingUserText = text;

        var optimisticUserMessageId = Guid.NewGuid();
        _optimisticUserMessageId = optimisticUserMessageId;
        _messages.Add(new ChatRenderableMessage(
            optimisticUserMessageId,
            ChatMessageRole.User,
            ChatMessageStatus.Completed,
            [new ChatTextPart(text)]));
        _scrollKey++;

        try
        {
            await ChatRuntime.StartTurnAsync(_workbench.Project.Id, text);
            ApplyChatRuntimeSnapshot(ChatRuntime.GetSnapshot());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _running = false;
            _pendingUserText = null;
        }
    }

    private Task StopAsync() => ChatRuntime.StopTurnAsync();

    private async Task ResetChatAsync()
    {
        if (_workbench is null || _running)
            return;

        await ChatRuntime.ResetConversationAsync(_workbench.Project.Id);
        _error = null;
        _input = string.Empty;
        _pendingUserText = null;
        _optimisticUserMessageId = null;
        _live = null;
        _resetComposerKey++;
        await ReloadChatAsync();
    }

