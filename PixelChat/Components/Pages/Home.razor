    private static IReadOnlyList<Guid> ReadGuidList(string? json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]")
            return [];

        try
        {
            return JsonSerializer.Deserialize<List<Guid>>(json) ?? [];
        }
        catch (JsonException)
        {
            return [];
        }
    }

    private WorkspaceSpriteAgentStatus? CurrentSpriteAgentStatus()
    {
        var liveChips = SpriteToolChips(_live).ToList();
        var running = liveChips.LastOrDefault(chip => !chip.Completed);
        if (running is not null)
        {
            return new WorkspaceSpriteAgentStatus(
                "running",
                running.Name,
                SpriteToolTargetSummary(running),
                string.Empty);
        }

        var completed = liveChips.LastOrDefault(chip => chip.Completed);

        if (completed is null)
            return null;

        return new WorkspaceSpriteAgentStatus(
            string.IsNullOrWhiteSpace(completed.Error) ? "completed" : "error",
            completed.Name,
            SpriteToolTargetSummary(completed),
            completed.Error ?? string.Empty);
    }

    private static IEnumerable<ChatToolChip> SpriteToolChips(ChatLiveTurn? live) =>
        live?.Messages
            .SelectMany(message => message.Parts)
            .OfType<ChatToolPart>()
            .Select(part => part.Chip)
            .Where(chip => SpriteToolNames.Contains(chip.Name))
        ?? [];

    private static string SpriteToolTargetSummary(ChatToolChip chip)
    {
        if (string.IsNullOrWhiteSpace(chip.ArgumentsJson) || chip.ArgumentsJson == "{}")
            return string.Empty;

        try
        {
            using var document = JsonDocument.Parse(chip.ArgumentsJson);
            var root = document.RootElement;
            foreach (var key in new[] { "frameSetId", "frameId", "sourceAssetId", "assetId", "builtSheetId" })
            {
                if (root.TryGetProperty(key, out var value))
                    return $"{key}: {ShortId(value.ToString())}";
            }
        }
        catch (JsonException)
        {
        }

        return string.Empty;
    }

    private static string ShortId(string value) =>
        Guid.TryParse(value, out var id) ? id.ToString("N")[..8] : value;

