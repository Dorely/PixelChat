    {
        var attachment = RecipeAttachmentDrafts(animation).FirstOrDefault(item => item.Key == key);
        if (attachment is null)
            return;

        attachment.Role = NormalizeRecipeAttachmentRole(role);
        MarkRecipeAttachmentEditorDirty(animation);
    }

    private void UpdateRecipeAttachmentNotes(bool animation, Guid key, string? notes)
    {
        var attachment = RecipeAttachmentDrafts(animation).FirstOrDefault(item => item.Key == key);
        if (attachment is null)
            return;

        attachment.Notes = notes ?? string.Empty;
        MarkRecipeAttachmentEditorDirty(animation);
    }

    private void MoveRecipeAttachment(bool animation, Guid key, int delta)
    {
        var attachments = RecipeAttachmentDrafts(animation);
        var index = attachments.FindIndex(item => item.Key == key);
        if (index < 0)
            return;

        var newIndex = Math.Clamp(index + delta, 0, attachments.Count - 1);
        if (newIndex == index)
            return;

        var attachment = attachments[index];
        attachments.RemoveAt(index);
        attachments.Insert(newIndex, attachment);
        MarkRecipeAttachmentEditorDirty(animation);
    }

    private void RemoveRecipeAttachment(bool animation, Guid key)
    {
        var attachments = RecipeAttachmentDrafts(animation);
        var removed = attachments.RemoveAll(item => item.Key == key) > 0;
        if (removed)
            MarkRecipeAttachmentEditorDirty(animation);
    }

    private List<RecipeAttachmentDraft> RecipeAttachmentDrafts(bool animation) =>
        animation ? _animationRecipeAttachments : _recipeAttachments;

    private void MarkRecipeAttachmentEditorDirty(bool animation)
    {
        if (animation)
            MarkAnimationRecipeEditorDirty();
        else
            MarkRecipeEditorDirty();
    }

    private static IReadOnlyList<RecipeAssetAttachmentRequest> RecipeAttachmentRequests(IEnumerable<RecipeAttachmentDraft> attachments) =>
        attachments
            .Where(attachment => attachment.AssetId != Guid.Empty)
            .Select(attachment => new RecipeAssetAttachmentRequest(
                attachment.AssetId,
                NormalizeRecipeAttachmentRole(attachment.Role),
                attachment.Notes))
            .ToList();

    private static void LoadRecipeAttachmentDrafts(List<RecipeAttachmentDraft> target, IReadOnlyList<RecipeAssetAttachmentView> source)
    {
        target.Clear();
        target.AddRange(source
            .OrderBy(attachment => attachment.SortOrder)
            .Select(attachment => new RecipeAttachmentDraft
            {
                AssetId = attachment.AssetId,
                Role = NormalizeRecipeAttachmentRole(attachment.Role),
                Notes = attachment.Notes,
            }));
    }

    private IReadOnlyList<WorkspaceRecipeAttachmentSummary> VisibleRecipeAttachments(bool animation) =>
        RecipeAttachmentDrafts(animation)
            .Select((attachment, index) => new WorkspaceRecipeAttachmentSummary(
                attachment.Key,
                attachment.AssetId,
                NormalizeRecipeAttachmentRole(attachment.Role),
                index,
                attachment.Notes,
                RecipeAttachmentAsset(attachment.AssetId) is { } asset ? AssetSummary(asset) : null))
            .ToList();

    private static string NormalizeRecipeAttachmentRole(string? role) =>
        string.Equals(role, RecipeAssetAttachmentRoles.Guide, StringComparison.OrdinalIgnoreCase)
            ? RecipeAssetAttachmentRoles.Guide
            : RecipeAssetAttachmentRoles.Example;

    private IEnumerable<ArtAssetView> RecipeOutputAssets(Guid? recipeId) =>
        recipeId is Guid id
            ? _workbench?.Assets.Where(asset => asset.SourcePromptRecipeId == id) ?? Enumerable.Empty<ArtAssetView>()
            : Enumerable.Empty<ArtAssetView>();

    private IReadOnlyList<RecipeOutputGroup> RecipeOutputGroups(Guid? recipeId) =>
        RecipeOutputAssets(recipeId)
            .GroupBy(asset => asset.SourcePromptRecipeVersion)
            .OrderByDescending(group => group.Key.HasValue)
            .ThenByDescending(group => group.Key ?? 0)
            .Select(group => new RecipeOutputGroup(
                group.Key is int version ? $"v{version}" : "Earlier",
                group.Key,
                group.OrderByDescending(asset => asset.CreatedAt).ToList()))
            .ToList();

