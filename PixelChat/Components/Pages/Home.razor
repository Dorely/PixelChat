    private void AddRecipeAttachment(bool animation)
    {
        var assetText = animation ? _newAnimationRecipeAttachmentAssetText : _newRecipeAttachmentAssetText;
        var assetId = ParseOptionalGuid(assetText);
        if (assetId is not Guid id || _workbench?.Assets.Any(asset => asset.Id == id) != true)
            return;

        var role = NormalizeRecipeAttachmentRole(animation ? _newAnimationRecipeAttachmentRole : _newRecipeAttachmentRole);
        RecipeAttachmentDrafts(animation).Add(new RecipeAttachmentDraft
        {
            AssetId = id,
            Role = role,
        });

        if (animation)
        {
            _newAnimationRecipeAttachmentAssetText = string.Empty;
            MarkAnimationRecipeEditorDirty();
        }
        else
        {
            _newRecipeAttachmentAssetText = string.Empty;
            MarkRecipeEditorDirty();
        }
