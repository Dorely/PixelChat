    private async Task GenerateAsync()
    {
        if (_workbench is null || string.IsNullOrWhiteSpace(_generatePrompt))
            return;

        _busyText = "Starting generation...";
        _error = null;
        StateHasChanged();
        try
        {
            var projectId = _workbench.Project.Id;
            var batch = await Workflow.StartGenerateImagesAsync(projectId, new GenerateImagesRequest(
                _generatePrompt,
                _negativePrompt,
                _generateSize,
                _generateCount,
                SelectedRecipeIdOrNull(),
                CurrentReferenceAssetIds(),
                _workbench.Project.ActiveBatchId));
            await ReloadWorkbenchAsync();
            _runningGenerationBatchId = batch.Id;
            _generationCts?.Cancel();
            _generationCts?.Dispose();
            _generationCts = new CancellationTokenSource();
            _ = RunGenerationBatchAsync(projectId, batch.Id, batch.Count, _generationCts.Token);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busyText = string.Empty;
            StateHasChanged();
        }
    }

    private async Task RunGenerationBatchAsync(Guid projectId, Guid batchId, int count, CancellationToken cancellationToken)
    {
        var parallelLimit = Math.Clamp(ImageOptions.Value.MaxParallelRequests, 1, Math.Max(1, ImageOptions.Value.MaxOutputs));
        using var throttler = new SemaphoreSlim(parallelLimit, parallelLimit);
        var tasks = Enumerable.Range(0, count).Select(outputIndex => RunGenerationOutputAsync(
            projectId,
            batchId,
            outputIndex,
            throttler,
            cancellationToken));

        try
        {
            await Task.WhenAll(tasks);
            await CompleteRunningGenerationAsync(projectId, batchId, cancellationToken);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                _error = ex.Message;
                StateHasChanged();
            });
        }
        finally
        {
            if (_runningGenerationBatchId == batchId)
                _runningGenerationBatchId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunGenerationOutputAsync(
        Guid projectId,
        Guid batchId,
        int outputIndex,
        SemaphoreSlim throttler,
        CancellationToken cancellationToken)
    {
        await throttler.WaitAsync(cancellationToken);
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var workflow = scope.ServiceProvider.GetRequiredService<IArtWorkflowService>();
            await workflow.GenerateBatchOutputAsync(projectId, batchId, outputIndex, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            await PersistGenerationFailureAsync(projectId, batchId, outputIndex, ex.Message, cancellationToken);
        }
        finally
        {
            throttler.Release();
        }

        await InvokeAsync(async () =>
        {
            await ReloadWorkbenchAsync();
            StateHasChanged();
        });
    }

    private async Task PersistGenerationFailureAsync(Guid projectId, Guid batchId, int outputIndex, string error, CancellationToken cancellationToken)
    {
        await _generationFailureLock.WaitAsync(cancellationToken);
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var workflow = scope.ServiceProvider.GetRequiredService<IArtWorkflowService>();
            await workflow.MarkGenerationBatchOutputFailedAsync(projectId, batchId, outputIndex, error, cancellationToken);
        }
        finally
        {
            _generationFailureLock.Release();
        }
    }

    private async Task CompleteRunningGenerationAsync(Guid projectId, Guid batchId, CancellationToken cancellationToken)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var workflow = scope.ServiceProvider.GetRequiredService<IArtWorkflowService>();
        await workflow.CompleteGenerationBatchAsync(projectId, batchId, cancellationToken);
        await InvokeAsync(async () =>
        {
            await ReloadWorkbenchAsync();
            StateHasChanged();
        });
    }

