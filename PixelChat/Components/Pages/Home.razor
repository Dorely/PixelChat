    private IReadOnlyList<AssetGroup> AssetRecipeGroups()
    {
        if (_workbench is null)
            return [];

        var groups = new List<AssetGroup>();
        var favorites = _workbench.Assets
            .Where(asset => asset.IsFavorite)
            .OrderByDescending(asset => asset.CreatedAt)
            .ToList();
        if (favorites.Count > 0)
            groups.Add(new AssetGroup("Favorites", favorites));

        var remaining = _workbench.Assets.Where(asset => !asset.IsFavorite).ToList();
        foreach (var recipe in _workbench.Recipes)
        {
            var assets = remaining
                .Where(asset => asset.SourcePromptRecipeId == recipe.Id)
                .OrderByDescending(asset => asset.CreatedAt)
                .ToList();
            if (assets.Count > 0)
                groups.Add(new AssetGroup(recipe.Name, assets));
        }

        var uncategorized = remaining
            .Where(asset => asset.SourcePromptRecipeId is null || !_workbench.Recipes.Any(recipe => recipe.Id == asset.SourcePromptRecipeId))
            .OrderByDescending(asset => asset.CreatedAt)
            .ToList();
        if (uncategorized.Count > 0)
            groups.Add(new AssetGroup("Uncategorized", uncategorized));

        return groups;
    }

