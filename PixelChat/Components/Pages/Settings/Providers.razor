@page "/settings/providers"
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.WebUtilities
@using PixelChat.Llm
@using PixelChat.Models
@rendermode InteractiveServer
@implements IDisposable
@inject ILlmProviderService ProviderService
@inject IOpenAIAccountAuthService OpenAIAuth
@inject IChatClientFactory ChatClientFactory
@inject NavigationManager Nav

<PageTitle>Providers</PageTitle>

<div class="settings-page">
    <header class="settings-header">
        <div class="settings-title">
            <h1>Providers</h1>
            <p>Configure the chat models PixelChat can use. OpenAI account sign-in and OpenAI-compatible API endpoints are supported in this first slice.</p>
        </div>
        <a class="btn btn-outline-secondary settings-back-link" href="">Back to chat</a>
    </header>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="alert alert-@_statusKind alert-dismissible fade show" role="alert">
            @_statusMessage
            <button type="button" class="btn-close" @onclick="ClearStatus"></button>
        </div>
    }

    @if (!_hasWorkingChatProvider)
    {
        <div class="alert alert-warning">
            No working chat provider is configured. Run a successful provider test to enable chat.
        </div>
    }

    <section class="settings-section">
        <div class="section-heading">
            <div class="section-title">
                <h2>OpenAI Account</h2>
                <p>Sign in with your OpenAI account. No API key is stored for this provider.</p>
            </div>
            <div class="section-actions">
                @if (_openAIAccountConnected)
                {
                    <span class="badge text-bg-success">Connected</span>
                    <button type="button" class="btn btn-outline-warning btn-sm" @onclick="DisconnectOpenAIAccountAsync">Disconnect</button>
                }
                else
                {
                    <button type="button" class="btn btn-success" @onclick="ConnectOpenAIAccountAsync">Connect with OpenAI</button>
                }
            </div>
        </div>

        @if (_openAIAccountProvider is not null)
        {
            <div class="openai-provider-form">
                <div class="provider-field openai-model-field">
                    <label class="form-label form-label-sm">Model</label>
                    <input type="text" class="form-control form-control-sm" @bind="_openAIAccountProvider.ModelId" />
                </div>
                <div class="provider-inline-actions">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SaveProviderAsync(_openAIAccountProvider)">Save</button>
                    <button type="button" class="btn btn-sm btn-outline-info"
                            disabled="@(_testingProviderId is not null)"
                            @onclick="() => TestProviderAsync(_openAIAccountProvider)">
                        @(_testingProviderId == _openAIAccountProvider.Id ? "Testing..." : "Test")
                    </button>
                    @RenderDefaultCell(_openAIAccountProvider)
                    <span class="badge-stack">@RenderChatStatus(_openAIAccountProvider)</span>
                </div>
            </div>
        }
    </section>

    <section class="settings-section">
        <div class="section-heading">
            <div class="section-title">
                <h2>OpenAI-Compatible Endpoints</h2>
                <p>Add local or hosted endpoints that expose the OpenAI chat API shape.</p>
            </div>
        </div>

        @if (_endpointParents.Count == 0)
        {
            <div class="empty-state">No endpoint providers configured yet.</div>
        }
        else
        {
            <div class="table-responsive provider-table-shell">
                <table class="table align-middle provider-table mb-0">
                    <thead>
                        <tr>
                            <th class="provider-name-column">Name</th>
                            <th class="provider-endpoint-column">Endpoint</th>
                            <th class="provider-model-column">Model</th>
                            <th class="provider-auth-column">Auth</th>
                            <th class="provider-status-column">Status</th>
                            <th class="provider-default-column">Default</th>
                            <th class="provider-actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var provider in _endpointParents)
                        {
                            <tr>
                                <td class="provider-name-cell">
                                    <input class="form-control form-control-sm provider-name-input" @bind="provider.DisplayName" placeholder="@provider.Name" />
                                    <div class="provider-key">@provider.Name</div>
                                </td>
                                <td class="provider-endpoint-cell">
                                    <input class="form-control form-control-sm endpoint-input" @bind="provider.EndpointUrl" />
                                </td>
                                <td class="provider-model-cell">
                                    <input class="form-control form-control-sm model-input" @bind="provider.ModelId" />
                                </td>
                                <td class="provider-auth-cell">
                                    <div class="badge-stack">@RenderAuthCell(provider)</div>
                                </td>
                                <td class="provider-status-cell">
                                    <div class="badge-stack">@RenderChatStatus(provider)</div>
                                </td>
                                <td class="provider-default-cell">
                                    <div class="default-cell">@RenderDefaultCell(provider)</div>
                                </td>
                                <td class="provider-actions-cell">
                                    <div class="action-row">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SaveProviderAsync(provider)">Save</button>
                                        <button type="button" class="btn btn-sm btn-outline-info"
                                                disabled="@(_testingProviderId is not null)"
                                                @onclick="() => TestProviderAsync(provider)">
                                            @(_testingProviderId == provider.Id ? "Testing..." : "Test")
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ToggleAddChild(provider.Id)">+ Model</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProviderAsync(provider)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                            @if (_children.TryGetValue(provider.Id, out var children))
                            {
                                @foreach (var child in children)
                                {
                                    <tr class="child-row">
                                        <td class="provider-name-cell">
                                            <input class="form-control form-control-sm provider-name-input" @bind="child.DisplayName" placeholder="@child.Name" />
                                            <div class="provider-key">inherits credentials from @(provider.DisplayName ?? provider.Name)</div>
                                        </td>
                                        <td class="provider-endpoint-cell">
                                            <input class="form-control form-control-sm endpoint-input" @bind="child.EndpointUrl" />
                                        </td>
                                        <td class="provider-model-cell">
                                            <input class="form-control form-control-sm model-input" @bind="child.ModelId" />
                                        </td>
                                        <td class="provider-auth-cell">
                                            <div class="badge-stack"><span class="badge text-bg-light inherited-badge">Inherited</span></div>
                                        </td>
                                        <td class="provider-status-cell">
                                            <div class="badge-stack">@RenderChatStatus(child)</div>
                                        </td>
                                        <td class="provider-default-cell">
                                            <div class="default-cell">@RenderDefaultCell(child)</div>
                                        </td>
                                        <td class="provider-actions-cell">
                                            <div class="action-row">
                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SaveProviderAsync(child)">Save</button>
                                                <button type="button" class="btn btn-sm btn-outline-info"
                                                        disabled="@(_testingProviderId is not null)"
                                                        @onclick="() => TestProviderAsync(child)">
                                                    @(_testingProviderId == child.Id ? "Testing..." : "Test")
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProviderAsync(child)">Delete</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            @if (_childForms.TryGetValue(provider.Id, out var draft))
                            {
                                <tr class="child-form-row">
                                    <td colspan="7">
                                        <div class="child-form">
                                            <div class="provider-field">
                                                <label class="form-label form-label-sm">Display Name</label>
                                                <input type="text" class="form-control form-control-sm" placeholder="GPT-5 Mini" @bind="draft.DisplayName" />
                                            </div>
                                            <div class="provider-field">
                                                <label class="form-label form-label-sm">Model ID</label>
                                                <input type="text" class="form-control form-control-sm" placeholder="gpt-5-mini" @bind="draft.ModelId" />
                                            </div>
                                            <div class="child-form-actions">
                                                <button type="button" class="btn btn-sm btn-primary" @onclick="() => AddChildModelAsync(provider, draft)">Add and Test</button>
                                                <button type="button" class="btn btn-sm btn-link" @onclick="() => _childForms.Remove(provider.Id)">Cancel</button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="settings-section">
        <div class="section-heading">
            <div class="section-title">
                <h2>Add Provider</h2>
                <p>Run Test before adding the provider so chat only enables known-working models.</p>
            </div>
        </div>

        <div class="add-provider-grid">
            <div class="provider-field">
                <label class="form-label form-label-sm">Name</label>
                <input type="text" class="form-control form-control-sm" @bind="_newProvider.Name" placeholder="ollama-local" />
            </div>
            <div class="provider-field">
                <label class="form-label form-label-sm">Display Name</label>
                <input type="text" class="form-control form-control-sm" @bind="_newProvider.DisplayName" placeholder="Local Llama" />
            </div>
            <div class="provider-field provider-field-wide">
                <label class="form-label form-label-sm">Endpoint URL</label>
                <input type="text" class="form-control form-control-sm" @bind="_newProvider.EndpointUrl" placeholder="http://localhost:11434/v1" />
            </div>
            <div class="provider-field">
                <label class="form-label form-label-sm">Model ID</label>
                <input type="text" class="form-control form-control-sm" @bind="_newProvider.ModelId" placeholder="llama3" />
            </div>
            <div class="provider-field">
                <label class="form-label form-label-sm">Auth</label>
                <select class="form-select form-select-sm" @bind="_newProvider.AuthType">
                    <option value="@AuthType.None">None</option>
                    <option value="@AuthType.ApiKey">API Key</option>
                </select>
            </div>
            @if (_newProvider.AuthType == AuthType.ApiKey)
            {
                <div class="provider-field provider-field-wide">
                    <label class="form-label form-label-sm">API Key</label>
                    <input type="password" class="form-control form-control-sm" @bind="_newProvider.ApiKey" />
                </div>
            }
            <div class="form-check add-provider-default">
                <input type="checkbox" class="form-check-input" id="newIsDefault" @bind="_newProvider.IsDefault" />
                <label for="newIsDefault" class="form-check-label">Default</label>
            </div>
            <div class="add-provider-actions">
                <button type="button" class="btn btn-outline-info btn-sm"
                        disabled="@(_isTestingNewProvider || _testingProviderId is not null)"
                        @onclick="TestNewProviderAsync">
                    @(_isTestingNewProvider ? "Testing..." : "Test")
                </button>
                <button type="button" class="btn btn-primary btn-sm" disabled="@(!CanAddNewProvider)" @onclick="CreateProviderAsync">Add Provider</button>
            </div>
        </div>
    </section>
</div>

@code {
    private List<LlmProvider> _endpointParents = [];
    private Dictionary<int, List<LlmProvider>> _children = [];
    private Dictionary<int, bool> _oauthStatus = [];
    private Dictionary<int, bool> _chatReadyStatus = [];
    private LlmProvider? _openAIAccountProvider;
    private bool _openAIAccountConnected;
    private bool _hasWorkingChatProvider;

    private readonly Dictionary<int, ChildDraft> _childForms = [];
    private readonly Dictionary<int, string> _apiKeyUpdates = [];
    private NewProviderDraft _newProvider = new();
    private NewProviderConnectionSnapshot? _testedNewProviderSnapshot;
    private bool _isTestingNewProvider;
    private int? _testingProviderId;

    private string? _statusMessage;
    private string _statusKind = "success";

    private bool CanAddNewProvider =>
        !_isTestingNewProvider
        && !string.IsNullOrWhiteSpace(_newProvider.Name)
        && _testedNewProviderSnapshot is not null
        && _testedNewProviderSnapshot == GetNewProviderConnectionSnapshot();

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        ConsumeStatusFromQuery();
        await ReloadAsync();
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ConsumeStatusFromQuery();
        InvokeAsync(StateHasChanged);
    }

    private void ConsumeStatusFromQuery()
    {
        var uri = new Uri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("message", out var msg))
        {
            _statusMessage = msg.ToString();
            _statusKind = query.TryGetValue("statusKind", out var kind) && IsSupportedStatusKind(kind.ToString())
                ? kind.ToString()
                : _statusMessage.Contains("fail", StringComparison.OrdinalIgnoreCase) ? "danger" : "success";
        }
    }

    private static bool IsSupportedStatusKind(string statusKind) =>
        statusKind is "success" or "info" or "warning" or "danger";

    private void ClearStatus()
    {
        _statusMessage = null;
    }

    private async Task ReloadAsync()
    {
        var all = await ProviderService.GetAllAsync();
        _endpointParents = all
            .Where(p => p.CredentialSourceId is null && !OpenAIAccountProvider.IsOpenAIAccount(p))
            .ToList();
        _children = all
            .Where(p => p.CredentialSourceId is int)
            .GroupBy(p => p.CredentialSourceId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(c => c.ModelId).ToList());

        _oauthStatus = [];
        foreach (var provider in all.Where(p => p.AuthType == AuthType.OAuth))
        {
            var token = await OpenAIAuth.GetValidTokenAsync(provider.Id);
            _oauthStatus[provider.Id] = token is not null;
        }

        _chatReadyStatus = [];
        foreach (var provider in all)
            _chatReadyStatus[provider.Id] = await ProviderService.IsChatProviderWorkingAsync(provider.Id);
        _hasWorkingChatProvider = _chatReadyStatus.Values.Any(ready => ready);

        _openAIAccountProvider = all.FirstOrDefault(p => p.Name == OpenAIAccountProvider.Name);
        _openAIAccountConnected = _openAIAccountProvider is not null
            && _oauthStatus.TryGetValue(_openAIAccountProvider.Id, out var connected)
            && connected;
    }

    private async Task CreateProviderAsync()
    {
        var provider = BuildNewProviderOrSetStatus();
        if (provider is null)
            return;

        if (_testedNewProviderSnapshot != GetNewProviderConnectionSnapshot())
        {
            SetStatus("Run Test successfully before adding this provider.", "danger");
            return;
        }

        try
        {
            provider.MarkChatTestSucceeded(DateTime.UtcNow);
            await ProviderService.CreateAsync(provider, _newProvider.AuthType == AuthType.ApiKey ? _newProvider.ApiKey?.Trim() : null);
            if (provider.IsDefault)
                await ProviderService.SetDefaultAsync(provider.Id);
            SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' created.", "success");
            _newProvider = new NewProviderDraft();
            _testedNewProviderSnapshot = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Failed to create provider: {ex.Message}", "danger");
        }
    }

    private async Task TestNewProviderAsync()
    {
        var provider = BuildNewProviderOrSetStatus();
        if (provider is null)
            return;

        _isTestingNewProvider = true;
        _testedNewProviderSnapshot = null;

        try
        {
            await ChatClientFactory.TestModelAsync(provider, _newProvider.AuthType == AuthType.ApiKey ? _newProvider.ApiKey?.Trim() : null);
            _testedNewProviderSnapshot = GetNewProviderConnectionSnapshot();
            provider.MarkChatTestSucceeded(DateTime.UtcNow);
            SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' endpoint and model verified.", "success");
        }
        catch (Exception ex)
        {
            SetStatus($"Provider test failed: {ex.Message}", "danger");
        }
        finally
        {
            _isTestingNewProvider = false;
        }
    }

    private async Task SaveProviderAsync(LlmProvider provider)
    {
        try
        {
            var apiKey = GetApiKeyUpdate(provider.Id);
            await ProviderService.UpdateAsync(provider, apiKey);
            if (!string.IsNullOrWhiteSpace(apiKey))
                _apiKeyUpdates.Remove(provider.Id);
            SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' updated.", "success");
        }
        catch (Exception ex)
        {
            SetStatus($"Save failed: {ex.Message}", "danger");
        }
        await ReloadAsync();
    }

    private async Task TestProviderAsync(LlmProvider provider)
    {
        _testingProviderId = provider.Id;
        var apiKey = GetApiKeyUpdate(provider.Id);

        try
        {
            await ChatClientFactory.TestModelAsync(provider, apiKey);
            await ProviderService.UpdateAsync(provider, apiKey);
            await ProviderService.MarkChatTestSucceededAsync(provider);
            if (!string.IsNullOrWhiteSpace(apiKey))
                _apiKeyUpdates.Remove(provider.Id);
            SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' model '{provider.ModelId}' saved and verified.", "success");
        }
        catch (Exception ex)
        {
            try
            {
                await ProviderService.MarkChatTestFailedAsync(provider, ex.Message);
            }
            catch
            {
                // Keep the original test failure visible.
            }
            SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' test failed: {ex.Message}", "danger");
        }
        finally
        {
            _testingProviderId = null;
            await ReloadAsync();
        }
    }

    private async Task SetDefaultAsync(int id)
    {
        try
        {
            await ProviderService.SetDefaultAsync(id);
            SetStatus("Default provider updated.", "success");
        }
        catch (Exception ex)
        {
            SetStatus($"Default provider update failed: {ex.Message}", "danger");
        }
        await ReloadAsync();
    }

    private async Task DeleteProviderAsync(LlmProvider provider)
    {
        await ProviderService.DeleteAsync(provider.Id);
        SetStatus($"Provider '{provider.DisplayName ?? provider.Name}' deleted.", "success");
        await ReloadAsync();
    }

    private async Task ConnectOpenAIAccountAsync()
    {
        var provider = _openAIAccountProvider;
        if (provider is null)
        {
            provider = new LlmProvider
            {
                Name = OpenAIAccountProvider.Name,
                DisplayName = "OpenAI Account",
                EndpointUrl = OpenAIAccountProvider.ResponsesEndpoint,
                ModelId = OpenAIAccountProvider.DefaultChatModel,
                AuthType = AuthType.OAuth,
                IsDefault = false
            };
            await ProviderService.CreateAsync(provider);
        }

        Nav.NavigateTo($"/auth/start/{provider.Id}", forceLoad: true);
    }

    private async Task DisconnectOpenAIAccountAsync()
    {
        if (_openAIAccountProvider is null)
            return;

        await OpenAIAuth.RevokeTokenAsync(_openAIAccountProvider.Id);
        SetStatus("OpenAI account disconnected.", "success");
        await ReloadAsync();
    }

    private void ToggleAddChild(int parentId)
    {
        if (!_childForms.Remove(parentId))
            _childForms[parentId] = new ChildDraft();
    }

    private async Task AddChildModelAsync(LlmProvider parent, ChildDraft draft)
    {
        var displayName = (draft.DisplayName ?? string.Empty).Trim();
        var modelId = (draft.ModelId ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(displayName) || string.IsNullOrWhiteSpace(modelId))
        {
            SetStatus("Display Name and Model ID are required.", "danger");
            return;
        }

        var child = new LlmProvider
        {
            Name = $"{parent.Name}-{modelId.Replace("/", "-").Replace(":", "-")}",
            DisplayName = displayName,
            EndpointUrl = parent.EndpointUrl,
            ModelId = modelId,
            AuthType = parent.AuthType,
            CredentialSourceId = parent.Id
        };

        try
        {
            await ChatClientFactory.TestModelAsync(child);
            child.MarkChatTestSucceeded(DateTime.UtcNow);
            await ProviderService.CreateAsync(child);
            SetStatus($"Model '{displayName}' ({modelId}) added under {parent.DisplayName ?? parent.Name}.", "success");
            _childForms.Remove(parent.Id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Add failed: {ex.Message}", "danger");
        }
    }

    private bool IsChatReady(LlmProvider provider) =>
        _chatReadyStatus.TryGetValue(provider.Id, out var ready) && ready;

    private string DefaultButtonTitle(LlmProvider provider) =>
        IsChatReady(provider)
            ? "Set as the default chat provider"
            : "Run Test successfully before setting this provider as default.";

    private RenderFragment RenderAuthCell(LlmProvider provider) => __builder =>
    {
        if (provider.AuthType == AuthType.OAuth)
        {
            <span class="badge text-bg-info">OAuth</span>
            if (_oauthStatus.TryGetValue(provider.Id, out var connected) && connected)
            {
                <span class="badge text-bg-success">Connected</span>
            }
            else
            {
                <span class="badge text-bg-warning">Disconnected</span>
            }
            return;
        }

        if (provider.AuthType == AuthType.ApiKey)
        {
            <span class="badge text-bg-secondary">API Key</span>
            <input type="password"
                   class="form-control form-control-sm provider-secret-input"
                   placeholder="New key (leave blank to keep)"
                   value="@GetApiKeyUpdate(provider.Id)"
                   @oninput="args => SetApiKeyUpdate(provider.Id, args.Value?.ToString() ?? string.Empty)" />
            return;
        }

        <span class="badge text-bg-secondary">None</span>
    };

    private RenderFragment RenderChatStatus(LlmProvider provider) => __builder =>
    {
        if (IsChatReady(provider))
        {
            <span class="badge text-bg-success provider-badge" title="This provider is ready for chat.">Ready</span>
            return;
        }

        if (provider.LastChatTestedAt is null)
        {
            <span class="badge text-bg-secondary provider-badge" title="Run Test successfully before using this provider for chat.">Untested</span>
            return;
        }

        if (provider.LastChatTestSucceeded && !provider.HasCurrentChatTestSnapshot)
        {
            <span class="badge text-bg-warning provider-badge" title="Provider settings changed after the last successful test.">Retest</span>
            return;
        }

        <span class="badge text-bg-danger provider-badge" title="@provider.LastChatTestError">Failed</span>
    };

    private RenderFragment RenderDefaultCell(LlmProvider provider) => __builder =>
    {
        if (provider.IsDefault)
        {
            <span class="badge text-bg-primary">Default</span>
            return;
        }

        <button type="button"
                class="btn btn-sm btn-outline-primary default-button"
                disabled="@(!IsChatReady(provider))"
                title="@DefaultButtonTitle(provider)"
                @onclick="() => SetDefaultAsync(provider.Id)">
            Set Default
        </button>
    };

    private LlmProvider? BuildNewProviderOrSetStatus()
    {
        var name = (_newProvider.Name ?? string.Empty).Trim();
        var endpoint = (_newProvider.EndpointUrl ?? string.Empty).Trim();
        var model = (_newProvider.ModelId ?? string.Empty).Trim();
        var apiKey = string.IsNullOrWhiteSpace(_newProvider.ApiKey) ? null : _newProvider.ApiKey.Trim();

        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(endpoint) || string.IsNullOrWhiteSpace(model))
        {
            SetStatus("Name, Endpoint URL, and Model ID are required.", "danger");
            return null;
        }

        if (_newProvider.AuthType == AuthType.ApiKey && string.IsNullOrWhiteSpace(apiKey))
        {
            SetStatus("API Key is required when Auth is API Key.", "danger");
            return null;
        }

        return new LlmProvider
        {
            Name = name,
            DisplayName = string.IsNullOrWhiteSpace(_newProvider.DisplayName) ? null : _newProvider.DisplayName.Trim(),
            EndpointUrl = endpoint,
            ModelId = model,
            AuthType = _newProvider.AuthType,
            IsDefault = _newProvider.IsDefault
        };
    }

    private NewProviderConnectionSnapshot GetNewProviderConnectionSnapshot() =>
        new(
            (_newProvider.EndpointUrl ?? string.Empty).Trim(),
            (_newProvider.ModelId ?? string.Empty).Trim(),
            _newProvider.AuthType,
            _newProvider.AuthType == AuthType.ApiKey ? (_newProvider.ApiKey ?? string.Empty).Trim() : string.Empty);

    private string? GetApiKeyUpdate(int providerId) =>
        _apiKeyUpdates.TryGetValue(providerId, out var apiKey) ? apiKey : null;

    private void SetApiKeyUpdate(int providerId, string apiKey)
    {
        if (string.IsNullOrEmpty(apiKey))
            _apiKeyUpdates.Remove(providerId);
        else
            _apiKeyUpdates[providerId] = apiKey;
    }

    private void SetStatus(string message, string kind)
    {
        _statusMessage = message;
        _statusKind = kind;
    }

    private sealed class NewProviderDraft
    {
        public string? Name { get; set; }
        public string? DisplayName { get; set; }
        public string? EndpointUrl { get; set; }
        public string? ModelId { get; set; }
        public AuthType AuthType { get; set; } = AuthType.None;
        public string? ApiKey { get; set; }
        public bool IsDefault { get; set; }
    }

    private sealed record NewProviderConnectionSnapshot(
        string EndpointUrl,
        string ModelId,
        AuthType AuthType,
        string ApiKey);

    private sealed class ChildDraft
    {
        public string? DisplayName { get; set; }
        public string? ModelId { get; set; }
    }
}
