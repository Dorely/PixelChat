@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <main>
        <article class="content @ContentClass">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private string ContentClass => IsWorkbenchRoute ? "workbench-content" : "scroll-content";

    private bool IsWorkbenchRoute
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.IsNullOrEmpty(path) || string.Equals(path, "chat", StringComparison.OrdinalIgnoreCase);
        }
    }
}
