@namespace PixelChat.Components.Chat
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="chat-surface @CssClass">
    <div class="chat-header">
        <div class="chat-heading">
            <span class="chat-title">@Title</span>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <span class="chat-subtitle">@Subtitle</span>
            }
        </div>
        @if (HeaderActions is not null)
        {
            <div class="chat-header-actions">@HeaderActions</div>
        }
    </div>

    <div class="chat-scroll" @ref="_scrollEl">
        @if (Loading)
        {
            <div class="chat-empty"><em>@LoadingText</em></div>
        }
        else
        {
            @foreach (var message in Messages)
            {
                @RenderMessage(message)
            }
            @if (Live is not null)
            {
                @RenderLive(Live)
            }
        }
        <div class="chat-bottom-sentinel" aria-hidden="true"></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="chat-error">
            <span>@Error</span>
            <button type="button" class="btn-close btn-close-sm" @onclick="OnClearError"></button>
        </div>
    }

    @if (BeforeComposer is not null)
    {
        <div class="chat-before-composer">@BeforeComposer</div>
    }

    <div class="chat-composer">
        @if (PendingImages.Count > 0)
        {
            <div class="chat-pending-images" aria-label="Pasted images">
                @foreach (var image in PendingImages)
                {
                    <span class="chat-pending-image">
                        <span class="chat-pending-thumb">
                            <img src="@image.PreviewImageUrl" alt="@image.FileName" />
                        </span>
                        <span class="chat-pending-meta">
                            <span class="chat-pending-title">@image.FileName</span>
                            <span class="chat-pending-size">@FormatPendingImageMeta(image)</span>
                        </span>
                        <button type="button"
                                class="chat-pending-remove"
                                title="@($"Remove {image.FileName}")"
                                aria-label="@($"Remove {image.FileName}")"
                                @onclick="() => OnPendingImageRemoved.InvokeAsync(image.Id)">x</button>
                    </span>
                }
            </div>
        }
        <textarea class="form-control chat-input" rows="1" placeholder="@Placeholder"
                  @ref="_composerEl"
                  disabled="@ComposerDisabled"
                  @oninput="OnInputAsync"></textarea>
        @if (Running)
        {
            <button type="button" class="btn btn-outline-danger" @onclick="OnStop">Stop</button>
        }
        else
        {
            <button type="button" class="btn btn-primary" data-chat-send="true" disabled="@SendDisabled" @onclick="OnSend">Send</button>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Chat";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Loading...";
    [Parameter] public IReadOnlyList<ChatRenderableMessage> Messages { get; set; } = [];
    [Parameter] public ChatLiveTurn? Live { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string Input { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> InputChanged { get; set; }
    [Parameter] public IReadOnlyList<ChatPendingImageDraft> PendingImages { get; set; } = [];
    [Parameter] public long MaxPasteImageBytes { get; set; } = 50L * 1024 * 1024;
    [Parameter] public string Placeholder { get; set; } = "Type a message...";
    [Parameter] public bool Running { get; set; }
    [Parameter] public bool ComposerDisabled { get; set; }
    [Parameter] public bool SendDisabled { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public int ForceScrollKey { get; set; }
    [Parameter] public int ScrollKey { get; set; }
    [Parameter] public int ResetComposerKey { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }
    [Parameter] public EventCallback OnStop { get; set; }
    [Parameter] public EventCallback OnClearError { get; set; }
    [Parameter] public EventCallback<ChatImageVisual> OnImageOpen { get; set; }
    [Parameter] public EventCallback<ChatPendingImageDraft> OnImagePasted { get; set; }
    [Parameter] public EventCallback<Guid> OnPendingImageRemoved { get; set; }
    [Parameter] public EventCallback<string> OnPasteError { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public RenderFragment? BeforeComposer { get; set; }

    private const string EmptyPreviewImageUrl = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMB/Ur61XkAAAAASUVORK5CYII=";

    private ElementReference _scrollEl;
    private ElementReference _composerEl;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ChatSurface>? _dotNetRef;
    private bool _scrollerAttached;
    private bool _autoSizeAttached;
    private bool _composerAttached;
    private int _seenForceScrollKey;
    private int _seenScrollKey;
    private int _seenResetComposerKey;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Chat/ChatSurface.razor.js");
        }

        if (_module is null)
            return;

        if (!_scrollerAttached)
        {
            try { await _module.InvokeVoidAsync("attachScroller", _scrollEl); _scrollerAttached = true; }
            catch { }
        }

        if (!_autoSizeAttached)
        {
            try { await _module.InvokeVoidAsync("attachAutoSize", _composerEl); _autoSizeAttached = true; }
            catch { }
        }

        if (!_composerAttached)
        {
            try { await _module.InvokeVoidAsync("attachComposer", _composerEl, _dotNetRef); _composerAttached = true; }
            catch { }
        }

        var force = _seenForceScrollKey != ForceScrollKey;
        if (force)
            _seenForceScrollKey = ForceScrollKey;

        var requested = _seenScrollKey != ScrollKey;
        if (requested)
            _seenScrollKey = ScrollKey;

        if (_seenResetComposerKey != ResetComposerKey)
        {
            _seenResetComposerKey = ResetComposerKey;
            try { await _module.InvokeVoidAsync("resetComposer", _composerEl); }
            catch { }
        }

        if (force || requested)
        {
            try { await _module.InvokeVoidAsync("scrollToBottom", _scrollEl, force); }
            catch { }
        }
    }

    private async Task OnInputAsync(ChangeEventArgs args) =>
        await InputChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    [JSInvokable]
    public async Task OnChatImagePasted(
        string? fileName,
        string? contentType,
        long size,
        int? width,
        int? height,
        string? previewDataUrl,
        IJSStreamReference streamReference)
    {
        if (ComposerDisabled || Running)
            return;

        var normalizedContentType = NormalizePastedImageContentType(contentType);
        if (normalizedContentType is null)
        {
            await NotifyPasteErrorAsync("Only PNG and JPEG images can be pasted into chat.");
            return;
        }

        if (size <= 0)
        {
            await NotifyPasteErrorAsync("Pasted image is empty.");
            return;
        }

        if (size > MaxPasteImageBytes)
        {
            await NotifyPasteErrorAsync($"Pasted image is too large. The limit is {FormatBytes(MaxPasteImageBytes)}.");
            return;
        }

        try
        {
            await using var stream = await streamReference.OpenReadStreamAsync(MaxPasteImageBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            var data = memory.ToArray();
            if (data.Length == 0)
            {
                await NotifyPasteErrorAsync("Pasted image is empty.");
                return;
            }

            var safeFileName = CleanPastedFileName(fileName, normalizedContentType);
            await OnImagePasted.InvokeAsync(new ChatPendingImageDraft(
                Guid.NewGuid(),
                safeFileName,
                normalizedContentType,
                data,
                string.IsNullOrWhiteSpace(previewDataUrl)
                    ? EmptyPreviewImageUrl
                    : previewDataUrl,
                data.Length,
                width,
                height));
        }
        catch (Exception ex) when (ex is IOException or InvalidOperationException or JSException)
        {
            await NotifyPasteErrorAsync(ex.Message);
        }
    }

    [JSInvokable]
    public Task OnChatPasteRejected(string message) => NotifyPasteErrorAsync(message);

    private Task NotifyPasteErrorAsync(string message) =>
        OnPasteError.HasDelegate
            ? OnPasteError.InvokeAsync(message)
            : Task.CompletedTask;

    private RenderFragment RenderMessage(ChatRenderableMessage message) => __builder =>
    {
        var bubbleClass = message.Role == ChatMessageRole.User
            ? "chat-msg chat-msg-user"
            : "chat-msg chat-msg-asst";
        <div class="@bubbleClass">
            @RenderParts(message.Parts)
            @if (message.Status == ChatMessageStatus.Failed)
            {
                <div class="chat-msg-status chat-msg-failed">Failed</div>
            }
            else if (message.Status == ChatMessageStatus.Cancelled)
            {
                <div class="chat-msg-status chat-msg-cancelled">Cancelled</div>
            }
        </div>
    };

    private RenderFragment RenderLive(ChatLiveTurn live) => __builder =>
    {
        if (!live.HasContent)
        {
            @RenderThinkingIndicator()
            return;
        }

        foreach (var liveMessage in live.Messages.Where(message => message.Parts.Count > 0))
        {
            var trailingText = liveMessage.Parts.LastOrDefault() as ChatTextPart;
            <div class="chat-msg chat-msg-asst chat-msg-streaming">
                @RenderParts(liveMessage.Parts, trailingText)
            </div>
        }

        if (live.IsThinking)
        {
            @RenderThinkingIndicator()
        }
    };

    private RenderFragment RenderParts(IReadOnlyList<ChatMessagePart> parts, ChatTextPart? trailingText = null) => __builder =>
    {
        foreach (var part in parts)
        {
            @RenderPart(part, ReferenceEquals(part, trailingText))
        }
    };

    private RenderFragment RenderPart(ChatMessagePart part, bool showCursor = false) => __builder =>
    {
        if (part is ChatTextPart textPart)
        {
            var text = textPart.Text.ToString();
            if (!string.IsNullOrEmpty(text))
            {
                <div class="chat-msg-text">@text@if (showCursor) { <span class="chat-cursor">|</span> }</div>
            }
        }
        else if (part is ChatToolPart toolPart)
        {
            <ChatToolChipView Chip="toolPart.Chip" />
            @if (toolPart.Chip.Visuals.Count > 0)
            {
                @RenderVisualStrip(toolPart.Chip.Visuals)
            }
        }
        else if (part is ChatImagePart imagePart)
        {
            @RenderVisualStrip(new[] { imagePart.Visual })
        }
    };

    private RenderFragment RenderVisualStrip(IReadOnlyList<ChatImageVisual> visuals) => __builder =>
    {
        <div class="chat-visual-strip">
            @foreach (var visual in visuals)
            {
                <button type="button" class="chat-visual-card" title="@visual.Title" @onclick="() => OnImageOpen.InvokeAsync(visual)">
                    <span class="chat-visual-thumb">
                        <LazyImage Src="@visual.PreviewImageUrl" Alt="@visual.Title" />
                    </span>
                    <span class="chat-visual-meta">
                        <span class="chat-visual-title">@visual.Title</span>
                        @if (!string.IsNullOrWhiteSpace(visual.Caption))
                        {
                            <span class="chat-visual-caption">@visual.Caption</span>
                        }
                        @if (visual.Width is int width && visual.Height is int height)
                        {
                            <span class="chat-visual-size">@width x @height</span>
                        }
                    </span>
                </button>
            }
        </div>
    };

    private RenderFragment RenderThinkingIndicator() => __builder =>
    {
        <div class="chat-msg chat-msg-asst chat-msg-streaming chat-thinking">
            <span class="chat-typing" aria-hidden="true"><span></span><span></span><span></span></span>
            <span class="chat-thinking-label">Thinking...</span>
        </div>
    };

    private static string? NormalizePastedImageContentType(string? contentType) =>
        contentType?.Trim().ToLowerInvariant() switch
        {
            "image/png" => "image/png",
            "image/jpeg" => "image/jpeg",
            "image/jpg" => "image/jpeg",
            _ => null
        };

    private static string CleanPastedFileName(string? fileName, string contentType)
    {
        var fallback = $"clipboard-image-{DateTime.UtcNow:yyyyMMddHHmmss}.{ExtensionForContentType(contentType)}";
        var candidate = string.IsNullOrWhiteSpace(fileName)
            ? fallback
            : fileName.Trim();
        candidate = System.IO.Path.GetFileName(candidate);
        if (string.IsNullOrWhiteSpace(candidate))
            candidate = fallback;

        var invalid = System.IO.Path.GetInvalidFileNameChars();
        var cleaned = new string(candidate
            .Select(character => invalid.Contains(character) ? '-' : character)
            .ToArray())
            .Trim();
        if (string.IsNullOrWhiteSpace(cleaned))
            cleaned = fallback;

        if (string.IsNullOrWhiteSpace(System.IO.Path.GetExtension(cleaned)))
            cleaned += "." + ExtensionForContentType(contentType);

        return cleaned;
    }

    private static string FormatPendingImageMeta(ChatPendingImageDraft image)
    {
        var size = FormatBytes(image.Size);
        return image.Width is int width && image.Height is int height
            ? $"{width} x {height} - {size}"
            : size;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024)
            return $"{bytes / (1024d * 1024 * 1024):0.#} GB";
        if (bytes >= 1024L * 1024)
            return $"{bytes / (1024d * 1024):0.#} MB";
        if (bytes >= 1024)
            return $"{bytes / 1024d:0.#} KB";
        return $"{Math.Max(0, bytes)} B";
    }

    private static string ExtensionForContentType(string contentType) =>
        contentType.Equals("image/jpeg", StringComparison.OrdinalIgnoreCase) ? "jpg" : "png";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }

        _dotNetRef?.Dispose();
    }
}
