@namespace PixelChat.Components.Chat

@{
    var summaryText = SummaryText;
}

<details class="chat-chip @StateClass">
    <summary>
        <span class="chat-chip-icon">@IconText</span>
        <span class="chat-chip-name">@FormatToolName(Chip.Name)</span>
        @if (!string.IsNullOrWhiteSpace(summaryText))
        {
            <span class="chat-chip-args">@summaryText</span>
        }
        @if (Chip.DurationMs is { } duration)
        {
            <span class="chat-chip-duration">@FormatDuration(duration)</span>
        }
    </summary>
    <div class="chat-chip-body">
        @if (Chip.HasArguments || !Chip.ArgumentsComplete)
        {
            <div class="chat-chip-section">args</div>
            <pre class="chat-chip-pre">@Chip.ArgumentsJson@if (!Chip.ArgumentsComplete) { <span class="chat-cursor">|</span> }</pre>
        }
        @if (Chip.Error is not null)
        {
            <div class="chat-chip-section">error</div>
            <pre class="chat-chip-pre chat-chip-pre-error">@Chip.Error</pre>
        }
        @if (Chip.Result is not null)
        {
            <div class="chat-chip-section">result</div>
            <pre class="chat-chip-pre">@Chip.Result</pre>
        }
        @if (Chip.Result is null && Chip.Error is null)
        {
            <div class="chat-chip-section text-muted"><em>@PendingText</em></div>
        }
    </div>
</details>

@code {
    [Parameter, EditorRequired] public ChatToolChip Chip { get; set; } = null!;

    private string? SummaryText => Chip.HasArguments
        ? ChatTranscriptHelpers.TruncateInline(Chip.ArgumentsJson, 96)
        : null;

    private string StateClass => Chip.Error is not null
        ? "chat-chip-error"
        : Chip.Completed
            ? "chat-chip-ok"
            : Chip.ArgumentsComplete
                ? "chat-chip-running"
                : "chat-chip-receiving";

    private string IconText => Chip.Error is not null
        ? "x"
        : Chip.Completed
            ? "ok"
            : Chip.ArgumentsComplete
                ? "run"
                : "...";

    private string PendingText => Chip.ArgumentsComplete ? "running..." : "receiving args...";

    private static string FormatToolName(string value) =>
        value.Replace('_', ' ');

    private static string FormatDuration(double durationMs) =>
        durationMs >= 1000
            ? $"{durationMs / 1000:0.0}s"
            : $"{durationMs:0}ms";
}
