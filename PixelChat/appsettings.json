{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Desktop": {
    "BindHost": "localhost",
    "HttpPort": 1455
  },
  "Auth": {
    "OpenAIAccount": {
      "RedirectUri": "http://localhost:1455/auth/callback"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=pixelchat.db"
  },
  "Persistence": {
    "Provider": "Sqlite"
  },
  "Blazor": {
    "MaximumReceiveMessageSizeBytes": 67108864
  },
  "Agents": {
    "OpenAIAccountRequestTimeoutSeconds": 600,
    "MaxToolIterations": 10,
    "MaxToolResultCharsForModel": 15000
  },
  "Images": {
    "DefaultMainlineModel": "gpt-5.5",
    "DefaultImageModel": "gpt-image-2",
    "DefaultSize": "auto",
    "DefaultQuality": "auto",
    "DefaultOutputFormat": "png",
    "DefaultBackground": "auto",
    "MaxOutputs": 4,
    "MaxParallelRequests": 1,
    "MaxRequestAttempts": 3,
    "RequestTimeoutSeconds": 600,
    "PartialImages": 2,
    "MaxReferenceImages": 4
  },
  "BackgroundRemoval": {
    "Enabled": true,
    "DefaultMethod": "local-ai",
    "SidecarRoot": "",
    "UvVersion": "0.11.16",
    "UvReleaseBaseUrl": "https://releases.astral.sh/github/uv/releases",
    "UvArchiveSha256": "",
    "PythonVersion": "3.12",
    "RembgPackageVersion": "2.0.75",
    "ModelName": "birefnet-general",
    "AlphaMatting": true,
    "TimeoutSeconds": 180
  }
}
